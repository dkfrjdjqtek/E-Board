<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <packageSources>
    <clear />
    <add key="nuget.org" value="https://api.nuget.org/v3/index.json" protocolVersion="3" />
    <!-- DevExpress 로컬 오프라인 패키지 폴더: 아래 경로를 실제 설치 경로로 수정 -->
    <add key="Dev25" value="C:\Program Files\DevExpress 25.2\Components\System\Components\packages" />
  </packageSources>

  <packageSourceMapping>
    <!-- DevExpress 패키지는 Dev25에서만 찾도록 고정 -->
    <packageSource key="Dev25">
      <package pattern="DevExpress.*" />
    </packageSource>

    <!-- 나머지는 nuget.org -->
    <packageSource key="nuget.org">
      <package pattern="*" />
    </packageSource>
  </packageSourceMapping>
</configuration>