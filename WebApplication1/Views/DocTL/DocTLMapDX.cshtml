                    // ── SelectionChanged 바인딩
                    try {
                        if (inst.SelectionChanged && typeof inst.SelectionChanged.AddHandler === 'function' && !inst.__docTlSelChangedBound) {
                            inst.__docTlSelChangedBound = true;
                            inst.SelectionChanged.AddHandler(function () {
                                const a1 = tryReadDxSelectionA1();
                                if (a1) pushA1ToActiveInput(a1);
                            });
                        }
                    } catch { }

                    try {
                        const host = document.getElementById('dxSheet');
                        if (host && !host.__docTlDxClickBound) {
                            host.__docTlDxClickBound = true;
                            host.addEventListener('click', function () {
                                if (!state.a1Enabled) return;
                                const a1 = tryReadDxSelectionA1();
                                if (a1) pushA1ToActiveInput(a1);
                            }, true);
                        }
                    } catch { }

                    return;
                }

                if (tried < maxTry) requestAnimationFrame(tick);
            }

            requestAnimationFrame(tick);
        }

        function run() {
            const raw = (document.getElementById('desc-json')?.textContent || '{}').trim();
            let desc = {};
            try { desc = JSON.parse(raw); } catch { desc = {}; }

            if (!Array.isArray(desc.Fields)) desc.Fields = [];
            if (!Array.isArray(desc.Approvals)) desc.Approvals = [];
            if (!Array.isArray(desc.Cooperations)) desc.Cooperations = [];

            desc.Fields = collapseFieldsForUi(desc.Fields);

            const fieldsBody = document.getElementById('tblFieldsBody');
            const apprBody = document.getElementById('tblApprBody');
            const coopBody = document.getElementById('tblCoopBody');

            function renderLines(tbody, lines, onChange, onDeleteReindex) {
                tbody.innerHTML = '';

                if (lines.length === 0) {
                    renderEmptyRow(tbody, 6);
                    return;
                }

                lines.forEach(function (a, i) {
                    a = a || {};
                    if (!a.Cell) a.Cell = {};
                    if (!a.ApproverType) a.ApproverType = 'Person';
                    if (a.ApproverValue == null) a.ApproverValue = '';

                    const tr = document.createElement('tr');

                    const tdS = document.createElement('td');
                    const inpS = document.createElement('input');
                    inpS.type = 'number';
                    inpS.min = '1';
                    inpS.className = 'form-control form-control-sm';
                    inpS.value = a.Slot ?? (i + 1);
                    inpS.addEventListener('input', function (e) { onChange(i, 'Slot', parseInt(e.target.value || '1', 10)); });
                    tdS.appendChild(inpS);

                    const tdP = document.createElement('td');
                    const inpP = document.createElement('input');
                    inpP.className = 'form-control form-control-sm';
                    inpP.value = a.Part || '';
                    inpP.addEventListener('input', function (e) { onChange(i, 'Part', e.target.value); });
                    tdP.appendChild(inpP);

                    const tdA1 = document.createElement('td');
                    tdA1.className = 'cell-a1';
                    const grpA1 = document.createElement('div');
                    grpA1.className = 'input-group input-group-sm';
                    const inputA1 = document.createElement('input');
                    inputA1.className = 'form-control';
                    inputA1.placeholder = L.PH_ApprA1;
                    inputA1.value = a.Cell.A1 || '';
                    inputA1.addEventListener('input', function (e) { onChange(i, 'CellA1', e.target.value); });
                    bindA1Picker(inputA1, function (a1) { onChange(i, 'CellA1', a1); });
                    grpA1.append(inputA1);
                    tdA1.appendChild(grpA1);

                    const tdType = document.createElement('td');
                    const selType = buildApproverTypeSelect(a.ApproverType || 'Person');
                    selType.addEventListener('change', function (e) { onChange(i, 'ApproverType', e.target.value); render(); });
                    tdType.appendChild(selType);

                    const tdVal = document.createElement('td');
                    if ((a.ApproverType || 'Person') === 'Person') {
                        const place = document.createElement('div');
                        tdVal.appendChild(place);
                        (async function () {
                            const selUser = await buildUserSelect(a.ApproverValue || '');
                            selUser.addEventListener('change', function (ev) { onChange(i, 'ApproverValue', ev.target.value || ''); });
                            place.replaceChildren(selUser);
                        })();
                    } else {
                        const inpVal = document.createElement('input');
                        inpVal.className = 'form-control form-control-sm';
                        inpVal.placeholder = ((a.ApproverType || 'Person') === 'Role') ? L.PH_RoleCode : L.PH_RuleJson;
                        inpVal.value = a.ApproverValue || '';
                        inpVal.addEventListener('input', function (e) { onChange(i, 'ApproverValue', e.target.value); });
                        tdVal.appendChild(inpVal);
                    }

                    const tdAct = document.createElement('td');
                    const delBtn = document.createElement('button');
                    delBtn.type = 'button';
                    delBtn.className = 'btn btn-outline-danger btn-sm';
                    delBtn.textContent = L.Delete;
                    delBtn.addEventListener('click', function () {
                        lines.splice(i, 1);
                        try { if (typeof onDeleteReindex === 'function') onDeleteReindex(lines); } catch { }
                        render();
                    });
                    tdAct.appendChild(delBtn);

                    tr.append(tdS, tdP, tdA1, tdType, tdVal, tdAct);
                    tbody.appendChild(tr);
                });
            }

            function render() {
                fieldsBody.innerHTML = '';

                if (desc.Fields.length === 0) {
                    renderEmptyRow(fieldsBody, 4);
                } else {
                    desc.Fields.forEach(function (f, i) {
                        f = f || {};
                        if (!f.Cell) f.Cell = {};

                        const tr = document.createElement('tr');

                        const tdKey = document.createElement('td');
                        const inpKey = document.createElement('input');
                        inpKey.className = 'form-control form-control-sm key-input';
                        inpKey.placeholder = L.PH_FieldKey;
                        inpKey.value = f.Key || '';
                        inpKey.addEventListener('input', function (e) { desc.Fields[i].Key = e.target.value; });
                        tdKey.appendChild(inpKey);

                        const tdType = document.createElement('td');
                        const sel = document.createElement('select');
                        sel.className = 'form-select form-select-sm';
                        sel.append(opt('Text', T.TypeText, (f.Type || 'Text') === 'Text'));
                        sel.append(opt('Date', T.TypeDate, (f.Type || 'Text') === 'Date'));
                        sel.append(opt('Num', T.TypeNum, (f.Type || 'Text') === 'Num'));
                        sel.addEventListener('change', function (e) { desc.Fields[i].Type = e.target.value; });
                        tdType.appendChild(sel);

                        const tdA1 = document.createElement('td');
                        tdA1.className = 'cell-a1';
                        const grp = document.createElement('div');
                        grp.className = 'input-group input-group-sm';

                        const inputA1 = document.createElement('input');
                        inputA1.className = 'form-control';
                        inputA1.placeholder = L.PH_FieldA1;
                        inputA1.value = (f.Cell && f.Cell.A1) || '';
                        inputA1.addEventListener('input', function (e) {
                            desc.Fields[i].Cell = desc.Fields[i].Cell || {};
                            desc.Fields[i].Cell.A1 = e.target.value;
                        });

                        bindA1Picker(inputA1, function (a1) {
                            desc.Fields[i].Cell = desc.Fields[i].Cell || {};
                            desc.Fields[i].Cell.A1 = a1;
                        });

                        grp.append(inputA1);
                        tdA1.appendChild(grp);

                        const tdAct = document.createElement('td');
                        const delBtn = document.createElement('button');
                        delBtn.type = 'button';
                        delBtn.className = 'btn btn-outline-danger btn-sm';
                        delBtn.textContent = L.Delete;
                        delBtn.addEventListener('click', function () {
                            desc.Fields.splice(i, 1);
                            render();
                        });
                        tdAct.appendChild(delBtn);

                        tr.append(tdKey, tdType, tdA1, tdAct);
                        fieldsBody.appendChild(tr);
                    });
                }

                renderLines(apprBody, desc.Approvals, function (i, k, v) {
                    desc.Approvals[i] = desc.Approvals[i] || {};
                    const a = desc.Approvals[i];
                    if (k === 'Slot') a.Slot = v;
                    else if (k === 'Part') a.Part = v;
                    else if (k === 'CellA1') { a.Cell = a.Cell || {}; a.Cell.A1 = v; }
                    else if (k === 'ApproverType') a.ApproverType = v;
                    else if (k === 'ApproverValue') a.ApproverValue = v;
                }, function (lines) { reindexSlots(lines); });

                renderLines(coopBody, desc.Cooperations, function (i, k, v) {
                    desc.Cooperations[i] = desc.Cooperations[i] || {};
                    const a = desc.Cooperations[i];
                    if (k === 'Slot') a.Slot = v;
                    else if (k === 'Part') a.Part = v;
                    else if (k === 'CellA1') { a.Cell = a.Cell || {}; a.Cell.A1 = v; }
                    else if (k === 'ApproverType') a.ApproverType = v;
                    else if (k === 'ApproverValue') a.ApproverValue = v;
                }, function (lines) { reindexSlots(lines); });
            }

            document.getElementById('btnAddField')?.addEventListener('click', function () {
                desc.Fields.push({ Key: '', Type: 'Text', Cell: { A1: '' } });
                render();
            });

            document.getElementById('btnAddAppr')?.addEventListener('click', function () {
                const next = getNextSlot(desc.Approvals);
                desc.Approvals.push({ Slot: next, Part: '', Cell: { A1: '' }, ApproverType: 'Person', ApproverValue: '' });
                render();
            });

            document.getElementById('btnAddCoop')?.addEventListener('click', function () {
                const next = getNextSlot(desc.Cooperations);
                desc.Cooperations.push({ Slot: next, Part: '', Cell: { A1: '' }, ApproverType: 'Person', ApproverValue: '' });
                render();
            });

            const btnSave = document.getElementById('btnSave');
            if (btnSave) {
                btnSave.addEventListener('pointerdown', function () {
                    ensureSaveCommitStarted();
                }, true);

                btnSave.addEventListener('mousedown', function () {
                    ensureSaveCommitStarted();
                }, true);

                btnSave.addEventListener('touchstart', function () {
                    ensureSaveCommitStarted();
                }, true);

                btnSave.addEventListener('click', async function () {
                    const payload = JSON.parse(JSON.stringify(desc));
                    payload.Fields = expandFieldsForSave(desc.Fields);

                    const ck = hasDuplicateKeys(payload.Fields);
                    if (!ck.ok) {
                        if (ck.reason === 'empty') alert(L.MsgKeyEmpty);
                        else if (ck.reason === 'dup') alert(L.MsgKeyDup + ' ' + (ck.key || ''));
                        return;
                    }

                    const vAppr = validateOneLine(payload.Approvals || [], 'DTL_Section_Approvals');
                    if (!vAppr.ok) { alert(vAppr.msg); return; }

                    const vCoop = validateOneLine(payload.Cooperations || [], 'DTL_Section_Cooperations');
                    if (!vCoop.ok) { alert(vCoop.msg); return; }

                    await submitDxMapSave(payload);
                });
            }

            document.addEventListener('click', function (e) {
                const a = e.target && e.target.closest ? e.target.closest('a.btn.btn-secondary') : null;
                if (!a) return;

                const href = (a.getAttribute('href') || '').trim().toLowerCase();
                if (href === 'javascript:history.back()') {
                    markIntentionalLeave();
                }
            }, true);

            hookDxEventsWhenReady();
            render();
        }

        if (document.readyState === 'loading') {
            document.addEventListener('DOMContentLoaded', run);
        } else {
            run();
        }
    })();
</script>