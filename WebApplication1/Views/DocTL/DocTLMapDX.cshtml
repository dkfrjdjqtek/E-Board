@* 2026.03.09 Changed: DX Spreadsheet 저장 직전 편집 commit 보강과 필드 그룹 복원 로직을 유지하면서 normalizeA1FromSelectionObject 종료부 오탈자를 제거하여 스크립트 파싱 오류를 수정함 *@
@using System.IO
@using System.Text.Json
@using System.Text.Encodings.Web
@inject Microsoft.AspNetCore.Hosting.IWebHostEnvironment Env
@inject Microsoft.Extensions.Localization.IStringLocalizer<SharedResource> S

@{
    var isAjax = string.Equals(Context.Request.Headers["X-Requested-With"], "XMLHttpRequest", StringComparison.OrdinalIgnoreCase);
    Layout = isAjax ? null : "~/Views/Shared/_Layout.cshtml";

    ViewData["Title"] = ViewBag.TemplateTitle ?? "템플릿";
    ViewData["DisableDxAll"] = true;

    var excelPath = (ViewBag.ExcelPath as string) ?? string.Empty;
    var dxCallbackUrl = (ViewBag.DxCallbackUrl as string) ?? "/DocumentTemplatesDX/dx-callback";

    var workDir = Env.ContentRootPath;

    var openRel = excelPath;
    try
    {
        if (!string.IsNullOrWhiteSpace(excelPath) && System.IO.Path.IsPathRooted(excelPath))
            openRel = System.IO.Path.GetRelativePath(workDir, excelPath);
        else
            openRel = excelPath;
    }
    catch
    {
        openRel = excelPath;
    }

    var postAction = "/DocumentTemplatesDX/map-save";
    var dxHeight = "calc(100vh - 360px)";
}

@if (isAjax)
{
    <script>
        (function () {
            try {
                window.DevExpress = window.DevExpress || {};
                window.DevExpress.trial = window.DevExpress.trial || {};
                if (typeof window.DevExpress.trial.registerTrialPanelComponents !== 'function') {
                    window.DevExpress.trial.registerTrialPanelComponents = function () { };
                }
            } catch (e) { }
        })();
    </script>
    <script src="~/dxresources/js/dx.all.js" asp-append-version="true"></script>
    <link rel="stylesheet" href="~/devex-spreadsheet/dist/dx-aspnetcore-spreadsheet.css" asp-append-version="true" />
    <script src="~/devex-spreadsheet/dist/dx-aspnetcore-spreadsheet.js" asp-append-version="true"></script>
}
else
{
    @section DxHead {
        <script>
            (function () {
                try {
                    window.DevExpress = window.DevExpress || {};
                    window.DevExpress.trial = window.DevExpress.trial || {};
                    if (typeof window.DevExpress.trial.registerTrialPanelComponents !== 'function') {
                        window.DevExpress.trial.registerTrialPanelComponents = function () { };
                    }
                } catch (e) { }
            })();
        </script>
        <script src="~/dxresources/js/dx.all.js" asp-append-version="true"></script>
        <link rel="stylesheet" href="~/devex-spreadsheet/dist/dx-aspnetcore-spreadsheet.css" asp-append-version="true" />
        <script src="~/devex-spreadsheet/dist/dx-aspnetcore-spreadsheet.js" asp-append-version="true"></script>
    }
}

<style>
    html, body {
        height: 100%;
        overflow: hidden;
    }

    .doc-unclip {
        overflow: visible !important;
        contain: none !important;
        transform: none !important;
    }

    #doc-scroll {
        position: fixed;
        top: var(--header-h);
        left: var(--sidebar-w);
        right: 0;
        bottom: var(--footer-h);
        overflow: auto;
        padding: 16px 24px 24px 16px;
        box-sizing: border-box;
    }

        #doc-scroll .row.g-3 > [class*="col-"] {
            align-self: flex-start;
        }

    .flex-eq {
        flex: 1 0 0;
        min-width: 0;
    }

    .table thead th {
        white-space: nowrap;
    }

    .cell-a1 {
        width: 14rem;
    }

    .key-input {
        min-width: 10rem;
    }

    .a1-active {
        box-shadow: 0 0 0 .2rem rgba(13,110,253,.25);
    }

    .cell-a1 .input-group {
        max-width: 14rem;
    }

    .cell-a1 .form-control {
        max-width: 10rem;
    }

    .cell-a1 .btn {
        white-space: nowrap;
    }

    #dxSheet {
        min-height: 520px;
        position: relative;
    }

        #dxSheet .dx-tabs-wrapper {
            position: relative;
        }

        #dxSheet .doc-dx-tab-actions {
            position: absolute;
            right: 10px;
            top: 6px;
            display: flex;
            gap: 8px;
            align-items: center;
            z-index: 2000;
            pointer-events: auto;
        }

        #dxSheet .dxss-tab-container {
            display: none !important;
        }

        #dxSheet .dxss-tab-panel {
            padding-bottom: 0 !important;
        }
            #dxSheet .doc-dx-tab-actions .btn {
                white-space: nowrap;
            }
</style>

<div id="doc-scroll">
    <div class="container-fluid py-3">
        <h5 class="mb-3">@((ViewBag.TemplateTitle as string) ?? S["DTL_Title_NewTemplate"].Value)</h5>

        @{
            var alertMsg = (TempData["Alert"] as string) ?? (ViewBag.Alert as string);
        }
        @if (!string.IsNullOrWhiteSpace(alertMsg))
        {
            <div class="alert alert-danger mb-3">@alertMsg</div>
        }

        <script id="desc-json" type="application/json">
            @Html.Raw((ViewData["DescriptorJson"] as string) ?? (ViewBag.DescriptorJson ?? "{}"))
        </script>

        <form id="mapForm" method="post" action="@postAction">
            @Html.AntiForgeryToken()
            <input type="hidden" name="descriptor" id="descriptor" />
            <input type="hidden" name="excelPath" value="@excelPath" />
            <input type="hidden" name="docCode" value="@ViewBag.DocCode" />

            <input id="dxOpenFile" type="file" accept=".xlsx,.xlsm,.xls" style="display:none" />

            <div class="row g-3">
                <div class="col-12 col-lg-5">
                    <div class="card">
                        <div class="card-header d-flex justify-content-between align-items-center py-2">
                            <span>@S["DTL_Section_Fields"]</span>
                            <button id="btnAddField" type="button" class="btn btn-outline-primary btn-sm">@S["_CM_Add"]</button>
                        </div>
                        <div class="card-body p-2">
                            <div class="table-responsive">
                                <table class="table table-sm align-middle mb-0">
                                    <thead>
                                        <tr>
                                            <th>@S["DTL_Col_FieldKey"]</th>
                                            <th style="width:8rem">@S["DTL_Col_Type"]</th>
                                            <th class="cell-a1">@S["DTL_Col_CellA1"]</th>
                                            <th style="width:4.5rem"></th>
                                        </tr>
                                    </thead>
                                    <tbody id="tblFieldsBody"></tbody>
                                </table>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="col-12 col-lg-7">
                    <div class="card">
                        <div class="card-header d-flex justify-content-between align-items-center py-2">
                            <span>@S["DTL_Section_Approvals"]</span>
                            <button id="btnAddAppr" type="button" class="btn btn-outline-primary btn-sm">@S["_CM_Add"]</button>
                        </div>
                        <div class="card-body p-2">
                            <div class="table-responsive">
                                <table class="table table-sm align-middle mb-0">
                                    <thead>
                                        <tr>
                                            <th style="width:4rem">@S["DTL_Col_Slot"]</th>
                                            <th style="width:6rem">@S["DTL_Col_Part"]</th>
                                            <th class="cell-a1">@S["DTL_Col_CellA1"]</th>
                                            <th style="width:8rem">@S["DTL_Col_ApproverType"]</th>
                                            <th>@S["DTL_Col_AssignValue"]</th>
                                            <th style="width:4.5rem"></th>
                                        </tr>
                                    </thead>
                                    <tbody id="tblApprBody"></tbody>
                                </table>
                            </div>
                        </div>
                    </div>

                    <div class="card mt-3">
                        <div class="card-header d-flex justify-content-between align-items-center py-2">
                            <span>@S["DTL_Section_Cooperations"]</span>
                            <button id="btnAddCoop" type="button" class="btn btn-outline-primary btn-sm">@S["_CM_Add"]</button>
                        </div>
                        <div class="card-body p-2">
                            <div class="table-responsive">
                                <table class="table table-sm align-middle mb-0">
                                    <thead>
                                        <tr>
                                            <th style="width:4rem">@S["DTL_Col_Slot"]</th>
                                            <th style="width:6rem">@S["DTL_Col_Part"]</th>
                                            <th class="cell-a1">@S["DTL_Col_CellA1"]</th>
                                            <th style="width:8rem">@S["DTL_Col_ApproverType"]</th>
                                            <th>@S["DTL_Col_AssignValue"]</th>
                                            <th style="width:4.5rem"></th>
                                        </tr>
                                    </thead>
                                    <tbody id="tblCoopBody"></tbody>
                                </table>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="col-12">
                    @{
                        Html.DevExpress().Spreadsheet("dxSheet")
                        .Height(dxHeight)
                        .Width("100%")
                        .WorkDirectory(workDir)
                        .DocumentRequestHandlerUrl(dxCallbackUrl)
                        .Open(openRel)
                        .ReadOnly(false)
                        .ConfirmOnLosingChanges(c => c.Enabled(false))
                        .WriteTo(ViewContext.Writer, HtmlEncoder.Default);
                    }
                </div>
            </div>

            <div class="d-flex gap-2 mt-3">
                <button id="btnSave" type="button" class="btn btn-primary flex-eq">@S["_CM_Save"]</button>
                <a class="btn btn-secondary flex-eq" href="javascript:history.back()">@S["_CM_Close"]</a>
            </div>

            <input type="text"
                   id="dxCommitSink"
                   tabindex="-1"
                   autocomplete="off"
                   style="position:fixed;left:-10000px;top:-10000px;width:1px;height:1px;opacity:0;pointer-events:none;" />
        </form>
    </div>
</div>

<script>
    (function () {
        'use strict';

        const L = {
            PickCell: @Html.Raw(JsonSerializer.Serialize(S["DTL_Btn_PickCell"].Value)),
            NoRows: @Html.Raw(JsonSerializer.Serialize(S["DTL_Msg_NoRows"].Value)),
            Delete: @Html.Raw(JsonSerializer.Serialize(S["_CM_Delete"].Value)),
            MsgKeyEmpty: @Html.Raw(JsonSerializer.Serialize(S["DTL_Msg_FieldKeyEmpty"].Value)),
            MsgKeyDup: @Html.Raw(JsonSerializer.Serialize(S["DTL_Msg_FieldKeyDup"].Value)),
            Open: @Html.Raw(JsonSerializer.Serialize(S["_CM_Open"].Value)),
            Error: @Html.Raw(JsonSerializer.Serialize(S["_CM_Error"].Value)),
            ApprType_Person: @Html.Raw(JsonSerializer.Serialize(S["DTL_ApproverType_Person"].Value)),
            ApprType_Role: @Html.Raw(JsonSerializer.Serialize(S["DTL_ApproverType_Role"].Value)),
            ApprType_Rule: @Html.Raw(JsonSerializer.Serialize(S["DTL_ApproverType_Rule"].Value)),
            PH_FieldKey: @Html.Raw(JsonSerializer.Serialize(S["DTL_PH_FieldKey"].Value)),
            PH_FieldA1: @Html.Raw(JsonSerializer.Serialize(S["DTL_PH_FieldA1"].Value)),
            PH_ApprA1: @Html.Raw(JsonSerializer.Serialize(S["DTL_PH_ApprA1"].Value)),
            PH_RoleCode: @Html.Raw(JsonSerializer.Serialize(S["DTL_PH_RoleCode"].Value)),
            PH_RuleJson: @Html.Raw(JsonSerializer.Serialize(S["DTL_PH_RuleJson"].Value)),
            V_Appr_SlotInt: @Html.Raw(JsonSerializer.Serialize(S["DTL_V_Appr_SlotInt"].Value)),
            V_Appr_TypeInvalid: @Html.Raw(JsonSerializer.Serialize(S["DTL_V_Appr_TypeInvalid"].Value)),
            V_Appr_PersonRequired: @Html.Raw(JsonSerializer.Serialize(S["DTL_V_Appr_PersonRequired"].Value)),
            V_Appr_RoleRequired: @Html.Raw(JsonSerializer.Serialize(S["DTL_V_Appr_RoleRequired"].Value)),
            V_Appr_RuleRequired: @Html.Raw(JsonSerializer.Serialize(S["DTL_V_Appr_RuleRequired"].Value)),
            V_Appr_RuleJsonInvalid: @Html.Raw(JsonSerializer.Serialize(S["DTL_V_Appr_RuleJsonInvalid"].Value))
        };

        const T = {
            TypeText: @Html.Raw(JsonSerializer.Serialize(S["DTL_Type_Text"].Value)),
            TypeDate: @Html.Raw(JsonSerializer.Serialize(S["DTL_Type_Date"].Value)),
            TypeNum: @Html.Raw(JsonSerializer.Serialize(S["DTL_Type_Num"].Value))
        };

        const USER_API = @Html.Raw(JsonSerializer.Serialize(Url.Action("SearchUser", "DocTLDX")));

        const state = {
            intentionalLeave: false,
            a1Enabled: false,
            a1Input: null,
            lastDxDownAt: 0,
            saveCommitPromise: null,
            isComposing: false,
            pendingSavePayload: null,
            isSaving: false,
            dxSyncDepth: 0,
            dxEditing: false,
            dxDirtySinceLastSync: false,
            dxEventsBound: false
        };

        function $(sel, root) {
            try { return (root || document).querySelector(sel); } catch { return null; }
        }

        function delay(ms) {
            return new Promise(function (resolve) { setTimeout(resolve, ms); });
        }

        function markIntentionalLeave() {
            state.intentionalLeave = true;
            try { window.onbeforeunload = null; } catch { }
        }

        window.addEventListener('beforeunload', function () {
            if (state.intentionalLeave) return;
        }, true);

        document.addEventListener('compositionstart', function () {
            state.isComposing = true;
        }, true);

        document.addEventListener('compositionend', function () {
            state.isComposing = false;

            if (state.pendingSavePayload) {
                const payload = state.pendingSavePayload;
                state.pendingSavePayload = null;
                setTimeout(function () {
                    submitDxMapSave(payload);
                }, 120);
            }
        }, true);

        function getDxInstance() {
            try {
                if (window.dxSheet) return window.dxSheet;
                if (window.dxSpreadsheet) return window.dxSpreadsheet;

                if (window.DevExpress && DevExpress.Spreadsheet && typeof DevExpress.Spreadsheet.getInstance === 'function') {
                    return DevExpress.Spreadsheet.getInstance('dxSheet');
                }
            } catch { }
            return null;
        }

        function bindDxStateEvents(inst) {
            if (!inst || state.dxEventsBound) return;
            state.dxEventsBound = true;

            try {
                if (inst.beginSynchronization && typeof inst.beginSynchronization.AddHandler === 'function') {
                    inst.beginSynchronization.AddHandler(function () {
                        state.dxSyncDepth++;
                    });
                }
            } catch { }

            try {
                if (inst.endSynchronization && typeof inst.endSynchronization.AddHandler === 'function') {
                    inst.endSynchronization.AddHandler(function () {
                        state.dxSyncDepth = Math.max(0, state.dxSyncDepth - 1);
                        if (state.dxSyncDepth === 0) {
                            state.dxDirtySinceLastSync = false;
                        }
                    });
                }
            } catch { }

            try {
                if (inst.documentChanged && typeof inst.documentChanged.AddHandler === 'function') {
                    inst.documentChanged.AddHandler(function () {
                        state.dxDirtySinceLastSync = true;
                    });
                }
            } catch { }

            try {
                if (inst.cellBeginEdit && typeof inst.cellBeginEdit.AddHandler === 'function') {
                    inst.cellBeginEdit.AddHandler(function () {
                        state.dxEditing = true;
                    });
                }
            } catch { }

            try {
                if (inst.cellEndEdit && typeof inst.cellEndEdit.AddHandler === 'function') {
                    inst.cellEndEdit.AddHandler(function () {
                        state.dxEditing = false;
                        state.dxDirtySinceLastSync = true;
                    });
                }
            } catch { }

            try {
                if (inst.cellCancelEdit && typeof inst.cellCancelEdit.AddHandler === 'function') {
                    inst.cellCancelEdit.AddHandler(function () {
                        state.dxEditing = false;
                    });
                }
            } catch { }
        }

        function appendFormValue(fd, key, value) {
            if (value === undefined || value === null) return;

            if (value instanceof Date) {
                fd.append(key, value.toISOString());
                return;
            }

            const t = typeof value;

            if (t === 'string' || t === 'number' || t === 'boolean') {
                fd.append(key, String(value));
                return;
            }

            if (Array.isArray(value)) {
                for (let i = 0; i < value.length; i++) {
                    appendFormValue(fd, key + '[' + i + ']', value[i]);
                }
                return;
            }

            if (t === 'object') {
                for (const k of Object.keys(value)) {
                    appendFormValue(fd, key + '.' + k, value[k]);
                }
            }
        }

        function columnLettersToNumber(col) {
            const s = String(col || '').trim().toUpperCase();
            if (!s || !/^[A-Z]+$/.test(s)) return 0;

            let n = 0;
            for (let i = 0; i < s.length; i++) {
                n = (n * 26) + (s.charCodeAt(i) - 64);
            }
            return n;
        }

        function columnNumberToLetters(num) {
            let n = parseInt(num, 10);
            if (!Number.isFinite(n) || n < 1) return '';

            let s = '';
            while (n > 0) {
                const m = (n - 1) % 26;
                s = String.fromCharCode(65 + m) + s;
                n = Math.floor((n - 1) / 26);
            }
            return s;
        }

        function normalizeSingleA1(a1) {
            const m = String(a1 || '').trim().toUpperCase().match(/^([A-Z]+)(\d+)$/);
            if (!m) return '';
            return m[1] + String(parseInt(m[2], 10));
        }

        function normalizeRangeA1(a1) {
            const m = String(a1 || '').trim().toUpperCase().match(/^([A-Z]+)(\d+):([A-Z]+)(\d+)$/);
            if (!m) return '';

            const c1 = columnLettersToNumber(m[1]);
            const c2 = columnLettersToNumber(m[3]);
            let r1 = parseInt(m[2], 10);
            let r2 = parseInt(m[4], 10);

            if (!c1 || !c2 || !Number.isFinite(r1) || !Number.isFinite(r2)) return '';

            const left = Math.min(c1, c2);
            const right = Math.max(c1, c2);
            const top = Math.min(r1, r2);
            const bottom = Math.max(r1, r2);

            return columnNumberToLetters(left) + top + ':' + columnNumberToLetters(right) + bottom;
        }

        function clampToSingleColumn(a1) {
            const single = normalizeSingleA1(a1);
            if (single) return single;

            const range = normalizeRangeA1(a1);
            if (!range) return '';

            const m = range.match(/^([A-Z]+)(\d+):([A-Z]+)(\d+)$/);
            if (!m) return '';

            const c1 = m[1];
            const r1 = parseInt(m[2], 10);
            const c2 = m[3];
            const r2 = parseInt(m[4], 10);

            if (c1 === c2) {
                return c1 + Math.min(r1, r2) + ':' + c1 + Math.max(r1, r2);
            }

            const leftColNum = Math.min(columnLettersToNumber(c1), columnLettersToNumber(c2));
            const leftCol = columnNumberToLetters(leftColNum);
            const top = Math.min(r1, r2);
            const bottom = Math.max(r1, r2);

            return leftCol + top + ':' + leftCol + bottom;
        }

        function normalizeA1FromSelectionObject(sel) {
            if (!sel) return '';

            if (typeof sel === 'string') {
                const s1 = normalizeSingleA1(sel);
                if (s1) return s1;
                return normalizeRangeA1(sel);
            }

            try {
                if (Array.isArray(sel) && sel.length > 0) {
                    for (let i = 0; i < sel.length; i++) {
                        const v = normalizeA1FromSelectionObject(sel[i]);
                        if (v) return v;
                    }
                }
            } catch { }

            const candidates = [
                sel.a1, sel.A1, sel.address, sel.Address, sel.range, sel.Range,
                sel.reference, sel.Reference, sel.text, sel.Text
            ];

            for (let i = 0; i < candidates.length; i++) {
                const c = candidates[i];
                if (typeof c === 'string' && c.trim()) {
                    const s2 = normalizeSingleA1(c);
                    if (s2) return s2;
                    const r2 = normalizeRangeA1(c);
                    if (r2) return r2;
                }
            }

            const rowKeys = ['topRowIndex', 'TopRowIndex', 'startRow', 'StartRow', 'rowIndex', 'RowIndex', 'row', 'Row'];
            const colKeys = ['leftColumnIndex', 'LeftColumnIndex', 'startColumn', 'StartColumn', 'columnIndex', 'ColumnIndex', 'col', 'Col'];
            const row2Keys = ['bottomRowIndex', 'BottomRowIndex', 'endRow', 'EndRow', 'toRow', 'ToRow'];
            const col2Keys = ['rightColumnIndex', 'RightColumnIndex', 'endColumn', 'EndColumn', 'toColumn', 'ToColumn'];

            function pickNum(obj, keys) {
                for (let i = 0; i < keys.length; i++) {
                    const v = obj ? obj[keys[i]] : null;
                    if (typeof v === 'number' && Number.isFinite(v)) return v;
                }
                return null;
            }

            const r1 = pickNum(sel, rowKeys);
            const c1 = pickNum(sel, colKeys);
            const r2 = pickNum(sel, row2Keys);
            const c2 = pickNum(sel, col2Keys);

            if (r1 != null && c1 != null) {
                const a1s = columnNumberToLetters(c1 + 1) + String(r1 + 1);
                if (r2 != null && c2 != null) {
                    const a1e = columnNumberToLetters(c2 + 1) + String(r2 + 1);
                    if (a1s === a1e) return a1s;
                    return a1s + ':' + a1e;
                }
                return a1s;
            }

            return '';
        }

        function collapseFieldsForUi(fields) {
            const src = Array.isArray(fields) ? fields : [];

            function parseA1Single(a1) {
                const m = String(a1 || '').trim().toUpperCase().match(/^([A-Z]+)(\d+)$/);
                if (!m) return null;
                return {
                    col: m[1],
                    row: parseInt(m[2], 10)
                };
            }

            function splitKeySuffix(key) {
                const s = String(key || '').trim();
                const m = s.match(/^(.*)_(\d+)$/);
                if (!m) {
                    return {
                        baseKey: s,
                        suffixRow: null
                    };
                }

                return {
                    baseKey: (m[1] || '').trim(),
                    suffixRow: parseInt(m[2], 10)
                };
            }

            function canMergeRange(prev, curr) {
                if (!prev || !curr) return false;
                if (!prev.__pos || !curr.__pos) return false;
                if (!prev.__key || !curr.__key) return false;

                if (prev.Type !== curr.Type) return false;
                if (prev.__key.baseKey !== curr.__key.baseKey) return false;
                if (prev.__pos.col !== curr.__pos.col) return false;
                if (curr.__pos.row !== (prev.__pos.row + 1)) return false;

                if (prev.__key.suffixRow == null || curr.__key.suffixRow == null) return false;
                if (prev.__key.suffixRow !== prev.__pos.row) return false;
                if (curr.__key.suffixRow !== curr.__pos.row) return false;

                return true;
            }

            const normalized = src
                .map(function (f, idx) {
                    const key = String((f && f.Key) || '').trim();
                    const type = String((f && f.Type) || 'Text').trim() || 'Text';
                    const a1 = String((f && f.Cell && f.Cell.A1) || '').trim().toUpperCase();

                    return {
                        __index: idx,
                        __raw: f || {},
                        __key: splitKeySuffix(key),
                        __pos: parseA1Single(a1),
                        Key: key,
                        Type: type,
                        Cell: { A1: a1 }
                    };
                })
                .filter(function (f) {
                    return f.Key || (f.Cell && f.Cell.A1);
                });

            const out = [];
            let i = 0;

            while (i < normalized.length) {
                const cur = normalized[i];

                if (!cur.__pos || cur.__key.suffixRow == null || cur.__key.baseKey === '') {
                    out.push({
                        Key: cur.Key,
                        Type: cur.Type,
                        Cell: { A1: cur.Cell.A1 }
                    });
                    i++;
                    continue;
                }

                let start = cur;
                let end = cur;
                let j = i + 1;

                while (j < normalized.length) {
                    const next = normalized[j];
                    if (!canMergeRange(end, next)) break;
                    end = next;
                    j++;
                }

                if (start.__pos.row !== end.__pos.row) {
                    out.push({
                        Key: start.__key.baseKey,
                        Type: start.Type,
                        Cell: { A1: start.__pos.col + start.__pos.row + ':' + end.__pos.col + end.__pos.row }
                    });
                } else {
                    out.push({
                        Key: start.Key,
                        Type: start.Type,
                        Cell: { A1: start.Cell.A1 }
                    });
                }

