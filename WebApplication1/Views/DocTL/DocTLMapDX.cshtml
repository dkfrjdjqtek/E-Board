        async function getDxSpreadsheetStateObjectAsync() {
            const inst = getDxInstance();
            if (!inst) return null;

            bindDxStateEvents(inst);
            await ensureSaveCommitStarted();
            await waitForDxIdle(1500);

            let readFn = null;
            try {
                if (typeof inst.getSpreadsheetState === 'function') readFn = inst.getSpreadsheetState.bind(inst);
                else if (typeof inst.GetSpreadsheetState === 'function') readFn = inst.GetSpreadsheetState.bind(inst);
            } catch { }

            if (!readFn) return null;

            let lastObj = null;
            let lastJson = '';

            for (let i = 0; i < 5; i++) {
                tryInvokeDxEditorCommit(inst);
                await waitForDxIdle(600);
                await new Promise(requestAnimationFrame);
                await delay(i === 0 ? 120 : 80);

                let curObj = null;
                try {
                    curObj = readFn();
                } catch (e) {
                    console.error(e);
                    curObj = null;
                }

                const curJson = safeStringifyForCompare(curObj);
                if (curObj && curJson && curJson === lastJson) {
                    return curObj;
                }

                lastObj = curObj;
                lastJson = curJson;
            }

            return lastObj;
        }

        async function submitDxMapSave(payload) {
            if (state.isSaving) return;

            if (state.isComposing) {
                state.pendingSavePayload = payload;
                try {
                    const ae = document.activeElement;
                    if (ae && typeof ae.blur === 'function') ae.blur();
                } catch { }
                return;
            }

            const form = document.getElementById('mapForm');
            const btnSave = document.getElementById('btnSave');

            state.isSaving = true;
            if (btnSave) btnSave.disabled = true;

            try {
                const stateObj = await getDxSpreadsheetStateObjectAsync();

                if (!stateObj) {
                    state.isSaving = false;
                    if (btnSave) btnSave.disabled = false;
                    alert(L.Error || 'Spreadsheet state not found.');
                    return;
                }

                const fd = new FormData(form);
                fd.set('descriptor', JSON.stringify(payload));
                appendFormValue(fd, 'spreadsheetState', stateObj);

                const res = await fetch(form.action, {
                    method: 'POST',
