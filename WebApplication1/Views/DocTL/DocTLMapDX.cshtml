        async function fetchUsers(q, take) {
            const url = USER_API + '?q=' + encodeURIComponent(q || '') + '&take=' + encodeURIComponent(String(take || 50));
            const res = await fetch(url, { credentials: 'same-origin' });
            if (!res.ok) return [];

            const json = await res.json();
            if (!Array.isArray(json)) return [];

            return json
                .map(function (x) {
                    const id = (x && (x.id || x.userId || x.value || x.key || x.userID || x.user_id))
                        ? String(x.id || x.userId || x.value || x.key || x.userID || x.user_id)
                        : '';
                    const text = buildUserDisplayText(x) || '';
                    return { id: id, text: text, raw: x };
                })
                .filter(function (x) { return x.id; })
                .map(function (x) { return { id: x.id, text: x.text || x.id, raw: x.raw }; });
        }

