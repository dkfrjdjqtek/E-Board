        }

        function validateOneLine(lines, labelName) {
            const list = Array.isArray(lines) ? lines : [];

            for (let i = 0; i < list.length; i++) {
                const a = list[i] || {};
                const slot = parseInt(a.Slot ?? 1, 10);

                if (!Number.isFinite(slot) || slot < 1) {
                    return { ok: false, msg: labelName + ' #' + (i + 1) + ': ' + L.V_Appr_SlotInt };
                }

                const t = a.ApproverType || 'Person';
                if (['Person', 'Role', 'Rule'].indexOf(t) < 0) {
                    return { ok: false, msg: labelName + ' #' + (i + 1) + ': ' + L.V_Appr_TypeInvalid };
                }

                const v = String(a.ApproverValue || '').trim();

                if (t === 'Person' && !v) {
                    return { ok: false, msg: labelName + ' #' + (i + 1) + ': ' + L.V_Appr_PersonRequired };
                }

                if (t === 'Role' && !v) {
                    return { ok: false, msg: labelName + ' #' + (i + 1) + ': ' + L.V_Appr_RoleRequired };
                }

                if (t === 'Rule') {
                    if (!v) {
                        return { ok: false, msg: labelName + ' #' + (i + 1) + ': ' + L.V_Appr_RuleRequired };
                    }
                    try {
