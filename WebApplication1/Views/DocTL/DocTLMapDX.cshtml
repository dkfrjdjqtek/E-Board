        function parseSingleA1(a1) {
            const m = String(a1 || '').trim().toUpperCase().match(/^([A-Z]+)(\d+)$/);
            if (!m) return null;
            return { col: m[1], row: parseInt(m[2], 10) };
        }

        function tryParseRange(a1) {
            const m = String(a1 || '').trim().toUpperCase().match(/^([A-Z]+)(\d+):([A-Z]+)(\d+)$/);
            if (!m || m[1] !== m[3]) return null;

            let r1 = parseInt(m[2], 10);
            let r2 = parseInt(m[4], 10);
            if (r2 < r1) {
                const tmp = r1;
                r1 = r2;
                r2 = tmp;
            }

            return { col: m[1], r1: r1, r2: r2 };
        }

        function expandFieldsForSave(fields) {
            const out = [];
            const list = Array.isArray(fields) ? fields : [];

            for (let i = 0; i < list.length; i++) {
                const f = list[i];
                if (!f) continue;

                const keyRaw = String(f.Key || '').trim();
                const a1Raw = (f.Cell && f.Cell.A1) ? String(f.Cell.A1).trim() : '';

                if (!keyRaw && !a1Raw) continue;

                const rg = tryParseRange(a1Raw);
                if (!rg) {
                    out.push({
                        Key: keyRaw,
                        Type: f.Type || 'Text',
                        Cell: { A1: a1Raw }
                    });
                    continue;
                }

                let idx = 1;
                for (let r = rg.r1; r <= rg.r2; r++, idx++) {
                    let keyBase = keyRaw || 'Field';
                    let key = keyBase;

                    if (key.indexOf('{n}') >= 0) key = key.replaceAll('{n}', String(idx));
                    if (key.indexOf('{row}') >= 0) key = key.replaceAll('{row}', String(r));
                    if (key === keyBase) key = keyBase + '_' + r;

                    out.push({
                        Key: key,
                        Type: f.Type || 'Text',
                        Cell: { A1: rg.col + r }
                    });
                }
            }

            return out;
        }

        function hasDuplicateKeys(items) {
            const seen = new Set();
            const list = Array.isArray(items) ? items : [];

            for (let i = 0; i < list.length; i++) {
                const it = list[i];
                const k = String((it && it.Key) || '').trim();

                if (!k) return { ok: false, reason: 'empty' };
