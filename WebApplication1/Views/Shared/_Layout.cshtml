<!-- 2026.02.23 Changed: DisableDxAll 플래그는 유지하면서 UseDxSpreadsheet 플래그가 켜진 화면에서는 dx spreadsheet 리소스가 누락되지 않도록 head에서 조건부 로드하여 DevExpress AspNetCore Spreadsheet undefined 오류를 방지 -->
@* 2026.02.09 Changed: Spreadsheet 페이지에서 dx.all.js 중복 로드(E0024) 방지 및 페이지별로 DevExtreme 스크립트 로드 순서를 통제하도록 DisableDxAll 플래그를 적용 *@
@using System.Reflection
@using System.Text.RegularExpressions
@using System.Text.Json
@inject Microsoft.Extensions.Localization.IStringLocalizer<SharedResource> S
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - E-Board</title>

    <!-- Bootstrap -->
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.5/font/bootstrap-icons.css" />
    <link href="https://fonts.googleapis.com/css2?family=Noto+Sans+KR:wght@400;500;600;700&display=swap" rel="stylesheet">

    <!-- DevExtreme (static dxresources) -->
    <link rel="stylesheet" href="~/dxresources/css/dx.common.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/dxresources/css/dx.light.css" asp-append-version="true" />

    @{
        var __disableDxAll = (ViewData["DisableDxAll"] as bool?) ?? false;

        // DX Spreadsheet 위젯을 실제로 렌더링하는 화면에서만 켜는 플래그
        // 예: ViewData["UseDxSpreadsheet"] = true;
        var __useDxSpreadsheet = (ViewData["UseDxSpreadsheet"] as bool?) ?? false;
    }

    @if (!__disableDxAll)
    {
        <!-- 중요: DevExtreme(dx.all.js)는 한 페이지에서 1회만 로드되어야 합니다(E0024 방지). -->
        <script src="~/dxresources/js/dx.all.js" asp-append-version="true"></script>
    }

    @*  Spreadsheet 초기화 스크립트가 찍히는 화면인데 DxHead가 빠져도 동작하도록, (DisableDxAll이 아닌 경우에 한해) 레이아웃에서 Spreadsheet 리소스를 보장 로드 *@
    @if (__useDxSpreadsheet && !__disableDxAll)
    {
        <script>
            (function () {
                try {
                    window.DevExpress = window.DevExpress || {};
                    window.DevExpress.trial = window.DevExpress.trial || {};
                    if (typeof window.DevExpress.trial.registerTrialPanelComponents !== 'function') {
                        window.DevExpress.trial.registerTrialPanelComponents = function () { };
                    }
                } catch (e) { }
            })();
        </script>

        <link rel="stylesheet" href="~/devex-spreadsheet/dist/dx-aspnetcore-spreadsheet.css" asp-append-version="true" />
        <script src="~/devex-spreadsheet/dist/dx-aspnetcore-spreadsheet.js" asp-append-version="true"></script>
    }

    <!-- site -->
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/WebApplication1.styles.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/_custom.css" asp-append-version="true" />

    @RenderSection("Styles", required: false)

    @* 기존 규칙 유지: DisableDxAll=true 인 페이지는 이 섹션에서 dx.all.js/스프레드시트 리소스를 직접 로드하는 방식도 허용 *@
    @RenderSection("DxHead", required: false)
</head>
<body>

    <partial name="_Header" />

    <div id="layout-body" class="d-flex">
        <aside class="sidebar-host flex-shrink-0">
            @await Html.PartialAsync("_Sidebar")
        </aside>

        <main id="main" class="flex-grow-1 container">
            @RenderBody()
        </main>
    </div>

    @{
        var appAsm = Assembly.GetEntryAssembly() ?? typeof(Program).Assembly;

        var infoVerRaw =
        appAsm.GetCustomAttribute<AssemblyInformationalVersionAttribute>()?.InformationalVersion
        ?? "";

        var mBuild = Regex.Match(infoVerRaw, @"\b(?<d>\d{8})\.(?<n>\d{4})\b");
        var d = mBuild.Success ? mBuild.Groups["d"].Value : "";
        var n4 = mBuild.Success ? mBuild.Groups["n"].Value : "";

        var footerBuildText =
        (!string.IsNullOrWhiteSpace(d) && !string.IsNullOrWhiteSpace(n4))
        ? $"{d}.{n4}"
        : "";

        var footerBuildSuffix = string.IsNullOrWhiteSpace(footerBuildText)
        ? ""
        : S["_CM_BuildSuffix", footerBuildText].Value;
    }

    <footer class="border-top footer app-footer text-muted small">
        <div class="container-fluid px-3">
            <div class="d-flex align-items-center justify-content-between flex-nowrap">
                <span class="mb-0">&copy; @DateTime.Now.Year @(S["_CM_MainTitle"])@footerBuildSuffix</span>
                <nav class="d-flex gap-2 text-nowrap">
                    <a asp-controller="Home" asp-action="Privacy">@(S["_CM_PrivacyPolicy"])</a>
                    <a asp-controller="Home" asp-action="Terms">@(S["_CM_TermsofUse"])</a>
                </nav>
            </div>
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>

    <script src="~/js/eb.push.js" asp-append-version="true"></script>
    <script src="~/js/eb-validate.js" asp-append-version="true"></script>

    <script>
        if (!window.EBValidate) {
            console.error("EBValidate가 로드되지 않았습니다. 레이아웃의 스크립트 경로와 파일 존재를 확인하세요. 예상 경로 wwwroot/js/eb-validate.js");
        }
        if (!window.EBPush) {
            console.warn("EBPush가 로드되지 않았습니다. 레이아웃의 스크립트 경로와 파일 존재를 확인하세요. 예상 경로 wwwroot/js/eb.push.js");
        }
    </script>

    @await RenderSectionAsync("Scripts", required: false)

    @if (User?.Identity?.IsAuthenticated ?? false)
    {
        <script>
            (function () {
                if (!window.EBPush) return;

                function safeCall(p) {
                    try { return Promise.resolve(p); } catch (e) { return Promise.reject(e); }
                }

                function showLoginBadgeToast(summaryText) {
                    try {
                        if (!summaryText) return;

                        var container = document.getElementById('loginBadgeToastContainer');
                        if (!container) {
                            container = document.createElement('div');
                            container.id = 'loginBadgeToastContainer';
                            container.className = 'toast-container position-fixed top-0 start-50 translate-middle-x p-3';
                            container.style.zIndex = '1080';
                            document.body.appendChild(container);
                        }

                        var old = document.getElementById('loginBadgeToast');
                        if (old && old.parentNode) old.parentNode.removeChild(old);

                        var toast = document.createElement('div');
                        toast.id = 'loginBadgeToast';
                        toast.className = 'toast border-0';
                        toast.setAttribute('role', 'alert');
                        toast.setAttribute('aria-live', 'assertive');
                        toast.setAttribute('aria-atomic', 'true');
                        toast.setAttribute('data-bs-delay', '3500');
                        toast.style.backgroundColor = '#198754';
                        toast.style.color = '#fff';
                        toast.style.borderColor = 'transparent';

                        toast.innerHTML =
                            '<div class="d-flex">' +
                                '<div class="toast-body"></div>' +
                                '<button type="button" class="btn-close btn-close-white me-2 m-auto" data-bs-dismiss="toast" aria-label="Close"></button>' +
                            '</div>';

                        toast.querySelector('.toast-body').textContent = summaryText;
                        container.appendChild(toast);

                        if (window.bootstrap && window.bootstrap.Toast) {
                            new bootstrap.Toast(toast).show();
                        }
                    } catch (e) {
                        console.warn('[LoginBadgeToast] failed:', e);
                    }
                }

                async function tryShowLoginBadgeOnce() {
                    try {
                        var userId = '@(User?.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value ?? "")';
                        var key = 'EB_LOGIN_BADGE_SHOWN:' + (userId || 'anon');

                        if (sessionStorage.getItem(key) === '1') return;

                        var res = await fetch('/Doc/BoardBadges', { method: 'GET', credentials: 'same-origin', cache: 'no-store' });
                        if (!res.ok) return;

                        var data = await res.json();
                        var created = Number((data && data.created) || 0);
                        var approvalPending = Number((data && data.approvalPending) || 0);
                        var sharedUnread = Number((data && data.sharedUnread) || 0);

                        if (created <= 0 && approvalPending <= 0 && sharedUnread <= 0) {
                            sessionStorage.setItem(key, '1');
                            return;
                        }

                        var fmtCreated  = @Html.Raw(JsonSerializer.Serialize(S["PUSH_CreatedUnread"].Value ?? "작성 미열람 {0}건"));
                        var fmtApproval = @Html.Raw(JsonSerializer.Serialize(S["PUSH_ApprovalPending"].Value ?? "결재 대기 {0}건"));
                        var fmtShared   = @Html.Raw(JsonSerializer.Serialize(S["PUSH_SharedUnread"].Value ?? "공유 미확인 {0}건"));
                        var joiner      = @Html.Raw(JsonSerializer.Serialize(S["PUSH_Joiner"].Value ?? " / "));
                        var title       = @Html.Raw(JsonSerializer.Serialize(S["PUSH_SummaryTitle"].Value ?? "E-BOARD"));

                        var parts = [];
                        if (created > 0) parts.push(String(fmtCreated).replace('{0}', String(created)));
                        if (approvalPending > 0) parts.push(String(fmtApproval).replace('{0}', String(approvalPending)));
                        if (sharedUnread > 0) parts.push(String(fmtShared).replace('{0}', String(sharedUnread)));

                        var msg = String(title) + ' - ' + parts.join(String(joiner));

                        showLoginBadgeToast(msg);
                        sessionStorage.setItem(key, '1');
                    } catch (e) {
                        console.warn('[LoginBadge] fetch failed:', e);
                    }
                }

                window.addEventListener('load', function () {
                    safeCall(EBPush.ensureSubscribed({ sendToServer: true }))
                        .catch(function (e) { console.warn('[EBPush] ensureSubscribed failed:', e); });

                    if (!window.__EBPUSH_PING_TIMER__) {
                        window.__EBPUSH_PING_TIMER__ = window.setInterval(function () {
                            safeCall(EBPush.ping()).catch(function () { });
                        }, 5 * 60 * 1000);
                    }

                    safeCall(tryShowLoginBadgeOnce()).catch(function () { });
                });
            })();
        </script>
    }

    <script>
        (() => {
            const root = document.documentElement;
            function sync() {
                const header = document.querySelector('.navbar.fixed-top, .sticky-top');
                const footer = document.querySelector('footer.footer');
                if (header) root.style.setProperty('--header-h', header.offsetHeight + 'px');
                if (footer) root.style.setProperty('--footer-h', footer.offsetHeight + 'px');
            }
            window.addEventListener('load', sync);
            window.addEventListener('resize', sync);
            if (window.ResizeObserver) {
                const f = document.querySelector('footer.footer');
                if (f) new ResizeObserver(sync).observe(f);
            }
        })();
    </script>

    @if (TempData["StatusMessage"] is string msg)
    {
        <div class="toast-container position-fixed top-0 start-50 translate-middle-x p-3" style="z-index:1080;">
            <div id="statusToast" class="toast border-0"
                 role="alert" aria-live="assertive" aria-atomic="true" data-bs-delay="2500"
                 style="background-color:#198754;color:#fff;border-color:transparent;">
                <div class="d-flex">
                    <div class="toast-body">@msg</div>
                    <button type="button" class="btn-close btn-close-white me-2 m-auto"
                            data-bs-dismiss="toast" aria-label="Close"></button>
                </div>
            </div>
        </div>
        <script>
            (() => {
                const el = document.getElementById('statusToast');
                if (el && window.bootstrap) new bootstrap.Toast(el).show();
            })();
        </script>
    }
</body>
</html>