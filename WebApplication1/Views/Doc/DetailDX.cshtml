</style>

<div id="doc-scroll"
     data-doc-id="@docId"
     data-doc-title="@docTitle"
     data-creator-name="@creatorName"
     data-status="@status"
     data-created-at="@createdAtText"
     data-recalled-at="@recalledAtText"
     data-template-code="@templateCode">

    <div class="page-header">
        <div>
            <h3>
                @formattedTitle
            </h3>

            <div class="doc-detail-actions">
                @if (canRecall)
                {
                    <button type="button" class="btn btn-sm btn-dark me-1" id="btnRecall" data-recall>
                        @S["DOC_Btn_Recall"]
                    </button>
                }

                @if (canPrint)
                {
                    <button type="button" class="btn btn-sm btn-outline-primary" id="btnPrint" title="@S["DOC_Btn_Print"]">
                        <i class="bi bi-printer"></i>
                    </button>
                }

                @if (canExport)
                {
                    <button type="button" class="btn btn-sm btn-outline-primary" id="btnExport" title="@S["DOC_Btn_Export"]">
                        <i class="bi bi-file-earmark-pdf"></i>
                    </button>
                }
            </div>
        </div>
    </div>

    <div id="detail-alert" class="mb-2" aria-live="polite"></div>

    <form id="doc-form" method="post" novalidate style="max-width:100%">
        @Html.AntiForgeryToken()

        <input type="hidden" id="dx-open-rel" value="@openRel" />
        <input type="hidden" id="dx-excel-path" value="@excelPath" />
        <input type="hidden" id="dx-doc-id" value="@dxDocumentId" />

        <script type="application/json" id="DescriptorJson">@Html.Raw(descJson)</script>
        <script type="application/json" id="PreviewJson">@Html.Raw(previewJson)</script>
        <script type="application/json" id="ApprovalsJson">@Html.Raw(approvalsJson)</script>
        <script type="application/json" id="ViewLogsJson">@Html.Raw(viewLogsJson)</script>
        <script type="application/json" id="ApprovalCellsJson">@Html.Raw(approvalCellsJson)</script>
        <script type="application/json" id="CooperationsJson">@Html.Raw(cooperationsJson)</script>            
        <script type="application/json" id="ApprovalTableRowsJson">@Html.Raw(approvalTableRowsJson)</script>

        <script>
            window.__RESX = @Html.Raw(JsonSerializer.Serialize(new {
                DOC_Err_PreviewFailed = S["DOC_Err_PreviewFailed"].Value,
                DOC_Err_SaveFailed = S["DOC_Err_SaveFailed"].Value,
                DOC_Err_LoadFailed = S["DOC_Err_LoadFailed"].Value,
                DOC_Err_RequestFailed = S["DOC_Err_RequestFailed"].Value,
                DOC_Err_DeleteFailed = S["DOC_Err_DeleteFailed"].Value,
                DOC_Err_DocumentNotFound = S["DOC_Err_DocumentNotFound"].Value,
                DOC_Msg_NoComments = S["DOC_Msg_NoComments"].Value,
                DOC_Msg_NoViewLogs = S["DOC_Msg_NoViewLogs"].Value,
                DOC_Msg_Approve_Success = S["DOC_Msg_Approve_Success"].Value,
                DOC_Msg_Recall_Success = S["DOC_Msg_Recall_Success"].Value,
                DOC_Val_Required = S["DOC_Val_Required"].Value,
                DOC_Cmt_Count = S["DOC_Cmt_Count"].Value,
                DOC_Btn_Reply = S["DOC_Btn_Reply"].Value,
                DOC_Btn_Cancel = S["DOC_Btn_Cancel"].Value,
                DOC_Btn_ReplyPost = S["DOC_Btn_ReplyPost"].Value,
                DOC_Placeholder_Reply = S["DOC_Placeholder_Reply"].Value,
                DOC_Status_Pending = S["DOC_Status_Pending"].Value,
                DOC_Status_Approved = S["DOC_Status_Approved"].Value,
                DOC_Status_Rejected = S["DOC_Status_Rejected"].Value,
                DOC_Status_OnHold = S["DOC_Status_OnHold"].Value,
                DOC_Status_Recalled = S["DOC_Status_Recalled"].Value,
                DOC_Status_Created = S["DOC_Status_Created"].Value,
                DOC_Btn_Cooperate = S["DOC_Btn_Cooperate"].Value,
                DOC_Confirm_DeleteComment = S["DOC_Confirm_DeleteComment"].Value,
                DOC_Label_Attachments = S["DOC_Label_Attachments"].Value,
                DOC_Label_AttachmentsCount = S["DOC_Label_AttachmentsCount"].Value,
                DOC_Help_AttachmentsEmpty = S["DOC_Help_AttachmentsEmpty"].Value,
                DOC_Label_Recipients = S["DOC_Label_Recipients"].Value,
                DOC_Btn_RecipientsChange = S["DOC_Btn_RecipientsChange"].Value,
                DOC_Btn_CommentPost = S["DOC_Btn_CommentPost"].Value,
                DOC_Placeholder_Comment = S["DOC_Placeholder_Comment"].Value,
                DOC_Col_Role = S["DOC_Col_Role"].Value,
                DOC_Role_Submit = S["DOC_Role_Submit"].Value,
                DOC_Role_ApprovalFmt = S["DOC_Role_ApprovalFmt"].Value,
                DOC_Role_Cooperation = S["DOC_Role_CooperationFmt"].Value,
                _CM_Edit = S["_CM_Edit"].Value,
                _CM_Delete = S["_CM_Delete"].Value
            }));

            window.__dxOpenRel = @Html.Raw(JsonSerializer.Serialize(openRel ?? string.Empty));
            window.__dxCallbackUrl = @Html.Raw(JsonSerializer.Serialize(dxCallbackUrl ?? "/Doc/dx-callback"));
            window.__dxExcelAbsPath = @Html.Raw(JsonSerializer.Serialize(excelPath ?? string.Empty));
            window.__dxDocumentId = @Html.Raw(JsonSerializer.Serialize(dxDocumentId ?? string.Empty));
            window.__dxRenderUsedLastCellA1 = @Html.Raw(JsonSerializer.Serialize(renderUsedLastCellA1));
            window.__dxRenderLastCellA1 = @Html.Raw(JsonSerializer.Serialize(renderLastCellA1));
            window.__dxRenderMaxRow = @Html.Raw(JsonSerializer.Serialize(renderMaxRow));
            window.__dxRenderMaxCol = @Html.Raw(JsonSerializer.Serialize(renderMaxCol));
            window.__dxRenderWidthPx = @Html.Raw(JsonSerializer.Serialize(renderWidthPx));
            window.__dxRenderHeightPx = @Html.Raw(JsonSerializer.Serialize(renderHeightPx));
            window.__dxRenderPadWidthPx = @Html.Raw(JsonSerializer.Serialize(dxRenderPadWidthPx));
            window.__dxRenderPadHeightPx = @Html.Raw(JsonSerializer.Serialize(dxRenderPadHeightPx));
            window.__dxLayoutWidthPx = @Html.Raw(JsonSerializer.Serialize(dxLayoutWidthPx));
            window.__dxLayoutHeightPx = @Html.Raw(JsonSerializer.Serialize(dxLayoutHeightPx));
            window.__dxRenderDiag = @Html.Raw(renderDiagJson);
            window.__DETAIL_DX_DEBUG__ = new URLSearchParams(window.location.search || '').get('dxdebug') === '1';
            window.__dxDetailPerf = window.__dxDetailPerf || [];
            window.__dxDetailPerfBase = (window.performance && performance.now) ? performance.now() : Date.now();
            window.__dxPerfMark = function (name, data) {
                try {
                    var now = (window.performance && performance.now) ? performance.now() : Date.now();
                    var item = { name: String(name || 'mark'), elapsedMs: now - window.__dxDetailPerfBase, at: now, data: data || null };
                    window.__dxDetailPerf.push(item);
                    if (window.performance && performance.mark) {
                        try { performance.mark('detaildx-' + item.name); } catch (e) { }
                    }
                    if (window.__DETAIL_DX_DEBUG__ && window.console && console.info) {
                        console.info('[DETAILDX-CLIENT-PERF]', item.name, item.elapsedMs, item.data || '');
                    }
                } catch (e) { }
            };
            window.__dxPerfMark('view-script-ready', {
                openRel: window.__dxOpenRel || '',
                callbackUrl: window.__dxCallbackUrl || '',
                renderLastCellA1: window.__dxRenderLastCellA1 || ''
            });
            window.__dxLog = function () {
                if (!window.__DETAIL_DX_DEBUG__ || !window.console || !console.log) return;
                try { console.log.apply(console, arguments); } catch (e) { }
            };
            window.__dxWarn = function () {
                if (!window.__DETAIL_DX_DEBUG__ || !window.console || !console.warn) return;
                try { console.warn.apply(console, arguments); } catch (e) { }
            };
            
            window.__dxDetailInternalHooksInstalled = false;

            function __dxDetailFire(reason) {
                const why = reason || 'dx-unknown';
                if (typeof window.__dxDetailOnEndSyncImpl === 'function') {
                    window.__dxDetailOnEndSyncImpl(why);
                } else {
                    window.__dxDetailOnEndSyncPending = why;
                }
            }

            window.__dxDetailSyncing = false;

            function __dxInstallInternalDocumentHooks(inst) {
                if (!window.__DETAIL_DX_DEBUG__) return;
                if (!inst || window.__dxDetailInternalHooksInstalled) return;
                window.__dxDetailInternalHooksInstalled = true;

                function wrapMethod(name, fireReason) {
                    const original = inst[name];
                    if (typeof original !== 'function' || original.__dxWrapped) return;

                    const wrapped = function () {
                        const result = original.apply(this, arguments);
                        try {
                            window.__dxLog('[DX-INT]', name, {
                                fireReason: fireReason,
                                args: Array.prototype.slice.call(arguments)
                            });
                        } catch (e) { }

                        try {
                            requestAnimationFrame(function () {
                                requestAnimationFrame(function () {
                                    __dxDetailFire(fireReason);
                                });
                            });
                        } catch (e) { }

                        return result;
                    };

                    wrapped.__dxWrapped = true;
                    wrapped.__dxOriginal = original;
                    inst[name] = wrapped;
                }

                wrapMethod('processDocumentResponse', 'dx-process-document-response');
                wrapMethod('onAfterDocumentResponseProcessed', 'dx-after-document-response');
                wrapMethod('documentUploadingComplete', 'dx-document-uploading-complete');

                window.__dxLog('[DX-INT] internal hooks installed');
            }

            window.__dxDetailSyncing = false;

            window.__dxDetailOnInit = function (s, e) {
                try { if (typeof window.__dxPerfMark === 'function') window.__dxPerfMark('dx-init'); } catch (ex0) { }
                try {
                    __dxInstallInternalDocumentHooks(s || window.dxDetailSheet || null);
                } catch (ex) { }

                window.__dxLog('[DX-EVT] Init', {
                    sender: s,
                    args: e,
                    renderUsedLastCellA1: window.__dxRenderUsedLastCellA1,
                    renderLastCellA1: window.__dxRenderLastCellA1
                });

                requestAnimationFrame(function () {
                    requestAnimationFrame(function () {
                        __dxDetailFire('dx-init-raf');
                    });
                });
            };

            window.__dxDetailOnBeforeSend = function (s, e) {
                try { if (typeof window.__dxPerfMark === 'function') window.__dxPerfMark('dx-before-send'); } catch (ex0) { }
                try {
                    __dxInstallInternalDocumentHooks(s || window.dxDetailSheet || null);
                } catch (ex) { }

                window.__dxLog('[DX-EVT] BeforeSend', {
                    sender: s,
                    args: e,
                    dxSyncing: window.__dxDetailSyncing
                });
            };

            window.__dxDetailOnBeginSync = function (s, e) {
                try { if (typeof window.__dxPerfMark === 'function') window.__dxPerfMark('dx-begin-sync'); } catch (ex0) { }
                window.__dxDetailSyncing = true;
                try {
                    if (window.__dxDetailState) window.__dxDetailState.dxSyncing = true;
                } catch (ex) { }

                try {
                    __dxInstallInternalDocumentHooks(s || window.dxDetailSheet || null);
                } catch (ex) { }

                window.__dxLog('[DX-EVT] BeginSynchronization', {
                    sender: s,
                    args: e,
                    dxSyncing: window.__dxDetailSyncing
                });
            };

            window.__dxDetailOnEndSync = function (s, e) {
                try { if (typeof window.__dxPerfMark === 'function') window.__dxPerfMark('dx-end-sync'); } catch (ex0) { }
                window.__dxDetailSyncing = false;
                try {
                    if (window.__dxDetailState) window.__dxDetailState.dxSyncing = false;
                } catch (ex) { }

                try {
                    __dxInstallInternalDocumentHooks(s || window.dxDetailSheet || null);
                } catch (ex) { }

                window.__dxLog('[DX-EVT] EndSynchronization', {
                    sender: s,
                    args: e,
                    dxSyncing: window.__dxDetailSyncing
                });

                __dxDetailFire('dx-end-sync');
            };

            window.__dxDetailOnDocumentChanged = function (s, e) {
                try { if (typeof window.__dxPerfMark === 'function') window.__dxPerfMark('dx-document-changed'); } catch (ex0) { }
                window.__dxLog('[DX-EVT] DocumentChanged', {
                    sender: s,
                    args: e,
                    dxSyncing: window.__dxDetailSyncing
                });
            };

            // 2026.06.12 Changed: ComposeDX와 동일하게 본문에서 Spreadsheet를 직접 렌더링한다.
        </script>

        <div id="dxDetailWrap"
             style="height:@(dxInitialHeightPx)px; min-height:@(dxInitialHeightPx)px; width:@(dxInitialWidthPx)px; min-width:@(dxInitialWidthPx)px;">
            @{
                __MarkDetailDxViewPerf("before-spreadsheet-write");

                var dxSpreadsheet = Html.DevExpress().Spreadsheet("dxDetailSheet")
                    .Height("100%")
                    .Width("100%")
                    .WorkDirectory(workDir)
                    .DocumentRequestHandlerUrl(dxCallbackUrl)
                    .ReadOnly(true)
                    .ConfirmOnLosingChanges(c => c.Enabled(false))
                    .ClientSideEvents(events =>
                    {
                        events.OnInit("__dxDetailOnInit");
                        events.OnBeforeSend("__dxDetailOnBeforeSend");
                        events.OnBeginSynchronization("__dxDetailOnBeginSync");
                        events.OnEndSynchronization("__dxDetailOnEndSync");
                        events.OnDocumentChanged("__dxDetailOnDocumentChanged");
                    });

                if (dxOpenByBytes)
                {
                    __detailDxViewLogger.LogInformation(
                        "DETAILDX-VIEW-PERF open-mode mode=BytesWithExplicitFormat format={Format} docId={DocId} documentId={DocumentId} excelPath={ExcelPath}",
                        DevExpress.Spreadsheet.DocumentFormat.Xlsx,
                        docId ?? string.Empty,
                        dxDocumentId ?? string.Empty,
                        excelPath ?? string.Empty);

                    // 2026.06.22 Added: 암호화된 xlsx 문서 열기 테스트를 위해 Open 직전에 암호 요청 이벤트를 연결 Contents 기존 byte accessor Open 방식은 유지
                    const string dxWorkbookOpenPassword = "qkrwjdghroTlqtoRl";

                    void __DetailDxSpreadsheet_EncryptedFilePasswordRequest(object? sender, DevExpress.Spreadsheet.EncryptedFilePasswordRequestEventArgs e)
                    {
                        try
                        {
                            e.Password = dxWorkbookOpenPassword;
                            e.Handled = true;
                        }
                        catch
                        {
                        }
                    }

                    void __DetailDxSpreadsheet_InitializeDocument(object? sender, DevExpress.Web.ASPxSpreadsheet.SpreadsheetInitializeDocumentEventArgs e)
                    {
                        try
                        {
                            if (e?.Document == null)
                                return;

                            e.Document.EncryptedFilePasswordRequest -= __DetailDxSpreadsheet_EncryptedFilePasswordRequest;
                            e.Document.EncryptedFilePasswordRequest += __DetailDxSpreadsheet_EncryptedFilePasswordRequest;
                        }
                        catch
                        {
                        }
                    }

                    DevExpress.Web.ASPxSpreadsheet.ASPxSpreadsheet.InitializeDocument -= __DetailDxSpreadsheet_InitializeDocument;
                    DevExpress.Web.ASPxSpreadsheet.ASPxSpreadsheet.InitializeDocument += __DetailDxSpreadsheet_InitializeDocument;

                    dxSpreadsheet.Open(
                        dxDocumentId,
                        DevExpress.Spreadsheet.DocumentFormat.Xlsx,
                        dxOpenContentAccessor);
                }
                else
                {
                    __detailDxViewLogger.LogInformation(
                        "DETAILDX-VIEW-PERF open-mode mode=PathFallback openRel={OpenRel} docId={DocId} documentId={DocumentId} excelPath={ExcelPath}",
                        openRel ?? string.Empty,
                        docId ?? string.Empty,
                        dxDocumentId ?? string.Empty,
                        excelPath ?? string.Empty);

                    dxSpreadsheet.Open(openRel);
                }

                dxSpreadsheet.WriteTo(ViewContext.Writer, HtmlEncoder.Default);

                __MarkDetailDxViewPerf("after-spreadsheet-write");
            }
            <div id="dxApprovalOverlay" class="dx-detail-overlay"></div>
        </div>
    </form>

    <section class="doc-section" aria-labelledby="doc-files-title">
        <div id="doc-files-title" class="doc-section-title">
            @S["DOC_Label_Attachments"]
            <span class="doc-section-sub">
                @(string.Format(S["DOC_Label_AttachmentsCount"].Value ?? "{0}", (documentFiles?.Count ?? 0)))
            </span>
        </div>

        @if (documentFiles == null || documentFiles.Count == 0)
        {
            <div class="text-muted">@S["DOC_Help_AttachmentsEmpty"]</div>
        }
        else
        {
            <div class="list-group list-group-flush">
                @foreach (var f in documentFiles)
                {
                    var fk = (f?.FileKey ?? string.Empty).Trim();
                    if (string.IsNullOrWhiteSpace(fk)) { continue; }

                    var on = (f?.OriginalName ?? fk).Trim();
                    var ct = (f?.ContentType ?? string.Empty).Trim();
                    var href1 = "/Doc/Download/" + Uri.EscapeDataString(fk);
                    var isImg = __IsImageAttachment(ct, on);

                    <div class="list-group-item d-flex flex-wrap align-items-start justify-content-between gap-2">
                        <div class="me-2" style="min-width: 240px; max-width: 75%;">
                            <div class="d-flex align-items-center gap-2" style="min-width:0;">
                                <a class="btn btn-sm btn-outline-secondary"
                                   href="@href1"
                                   target="_blank"
                                   rel="noopener">@S["DOC_Btn_Download"]</a>
                                <div class="doc-attach-name text-truncate" title="@on" style="min-width:0;">
                                    @on
                                </div>
                            </div>

                            @if (isImg)
                            {
                                <div class="doc-attach-imgwrap">
                                    <img class="doc-attach-thumb"
                                         src="@href1"
                                         alt=""
                                         data-fullsrc="@href1" />
                                </div>
                            }
                        </div>
                    </div>
                }
            </div>
        }
    </section>

    <div class="mt-3 mb-3">
        <label class="form-label">@S["DOC_Label_Recipients"]</label>

        <div class="d-inline-flex align-items-center gap-2 flex-nowrap">
            <div style="width:420px; max-width:100%;">
                @{
                    var orgNodes = ViewBag.OrgTreeNodes as IEnumerable<OrgTreeNode> ?? Array.Empty<OrgTreeNode>();
                }
                @await Html.PartialAsync(
                "_OrgMultiSelectCombo",
                                orgNodes,
                                new Microsoft.AspNetCore.Mvc.ViewFeatures.ViewDataDictionary(ViewData)
                                {
                                    ["ControlId"] = "doc-recipient-select-detail",
                                    ["FieldName"] = "SelectedRecipientUserIds"
                                })
            </div>

            <button type="button"
