        function renderApprovalOverlayStable(reason, pass) {
            const currentPass = Number(pass || 0);

            state.overlayRefreshRaf = requestAnimationFrame(function () {
                requestAnimationFrame(function () {
                    try { renderApprovalOverlay(); } catch (e) { }

                    if (currentPass < 1) {
                        state.overlayRefreshTimer = window.setTimeout(function () {
                            renderApprovalOverlayStable(reason, currentPass + 1);
                        }, 200);
                    } else {
                        const scroll = document.getElementById('doc-scroll');
                        if (scroll) scroll.classList.add('dx-page-ready');
                    }
                });
            });
        }

        function scheduleOverlayRefresh(reason) {
            cancelOverlayRefresh();
            renderApprovalOverlayStable(reason || 'overlay-refresh', 0);
        }

