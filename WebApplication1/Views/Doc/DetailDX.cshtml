                btnExport.addEventListener('click', async function () {
                    btnExport.disabled = true;
                    btnExport.classList.add('btn-loading');
                    const origHtml = btnExport.innerHTML;
                    btnExport.innerHTML = '<span class="spinner-border spinner-border-sm" role="status" aria-hidden="true"></span>';
                    function restoreBtn() { btnExport.disabled = false; btnExport.classList.remove('btn-loading'); btnExport.innerHTML = origHtml; }
                    function loadScript(url) {
                        return new Promise(function (resolve, reject) {
                            if (url.includes('html2canvas') && typeof window.html2canvas === 'function') { resolve(); return; }
                            if (url.includes('jspdf') && window.jspdf?.jsPDF) { resolve(); return; }
                            var s = document.createElement('script');
                            s.src = url; s.crossOrigin = 'anonymous';
                            s.onload = resolve;
                            s.onerror = () => reject(new Error('스크립트 로드 실패: ' + url));
                            document.head.appendChild(s);
                        });
                    }
                    try {
                        if (typeof window.html2canvas !== 'function')
                            await loadScript('https://cdnjs.cloudflare.com/ajax/libs/html2canvas/1.4.1/html2canvas.min.js');
                        if (!window.jspdf?.jsPDF)
                            await loadScript('https://cdnjs.cloudflare.com/ajax/libs/jspdf/2.5.1/jspdf.umd.min.js');
                        if (typeof window.html2canvas !== 'function') throw new Error('html2canvas 로드 실패');
                        if (!window.jspdf?.jsPDF) throw new Error('jsPDF 로드 실패');

                        const JsPDF = window.jspdf.jsPDF;
                        const target = document.getElementById('dxDetailWrap');
                        if (!target) throw new Error('캡처 대상 요소를 찾을 수 없습니다.');

                        const canvas = await window.html2canvas(target, {
                            scale: 2, useCORS: true, allowTaint: false,
                            backgroundColor: '#ffffff', logging: false,
                            width: target.offsetWidth, height: target.offsetHeight,
                            scrollX: 0, scrollY: 0
                        });

                        const imgData = canvas.toDataURL('image/jpeg', 0.92);
                        const A4_W = 210;
                        const pdfH = (canvas.height / canvas.width) * A4_W;
                        const pdf = new JsPDF({ orientation: 'portrait', unit: 'mm', format: [A4_W, Math.max(pdfH, 297)] });
                        pdf.addImage(imgData, 'JPEG', 0, 0, A4_W, pdfH);
                        const root = document.getElementById('doc-scroll');
                        const titleAttr = (root?.getAttribute('data-doc-title') || '').trim();
                        pdf.save((titleAttr || docId || 'document') + '.pdf');
                    } catch (err) {
                        console.error('[PDF Export] 오류:', err);
                        showAlert('PDF 변환 중 오류가 발생했습니다: ' + (err.message || String(err)), 'alert-danger');
                    } finally { restoreBtn(); }
                });
            }
        }

        function hookDxReady() {
            const wrap = document.getElementById('dxDetailWrap');
            const scroll = document.getElementById('doc-scroll');
            if (!wrap) return;

            let finalized = false;
            let rafId = 0;
            let domObserver = null;
            let sizeObserver = null;
            let stableSignature = '';
            let stableCount = 0;
            let readySignal = false;
            let readyReason = '';
            let adjustKickCount = 0;
            let postFinalizeRaf = 0;
            let resizeRaf = 0;

            function getWbc() {
                return document.getElementById('dxDetailSheet_WBC')
                    || document.querySelector('#dxDetailWrap [id$="_WBC"]');
            }

            function getPage() {
                return wrap.querySelector('.dxss-print-area')
                    || wrap.querySelector('.dxss-page');
            }

            function getInnerScroll() {
                return document.getElementById('dxDetailSheet_ScrollContainer')
                    || document.getElementById('dxDetailSheet_Grid')
                    || document.querySelector('#dxDetailWrap [id$="_ScrollContainer"]')
                    || document.querySelector('#dxDetailWrap [id$="_Grid"]');
            }

            function readBox(el) {
                if (!el) return { width: 0, height: 0 };
                const rect = el.getBoundingClientRect();
                return {
                    width: Math.max(
                        Math.ceil(rect.width || 0),
                        Math.ceil(el.clientWidth || 0),
                        Math.ceil(el.offsetWidth || 0)
                    ),
                    height: Math.max(
                        Math.ceil(rect.height || 0),
                        Math.ceil(el.clientHeight || 0),
                        Math.ceil(el.offsetHeight || 0)
                    )
                };
            }

            function hasVisibleContent() {
                const wbcBox = readBox(getWbc());
                const pageBox = readBox(getPage());

                if ((wbcBox.width > 120 && wbcBox.height > 120) || (pageBox.width > 120 && pageBox.height > 120)) {
                    return true;
                }

                const visibleTargets = wrap.querySelectorAll('[id*="_ctb."], .dxss-ftc');
                for (let i = 0; i < visibleTargets.length; i++) {
                    const r = visibleTargets[i].getBoundingClientRect();
                    if (r.width > 20 && r.height > 10) return true;
                }

                return false;
            }

            function getSignature() {
                const wbcBox = readBox(getWbc());
                const pageBox = readBox(getPage());

                return JSON.stringify({
                    w: wbcBox.width,
                    h: wbcBox.height,
                    pw: pageBox.width,
                    ph: pageBox.height
                });
            }

            function requestLayoutKick(reason) {
                if (!finalized && adjustKickCount < 1) {
                    adjustKickCount++;
                    try {
                        const inst = getDxInstance();
                        if (inst && typeof inst.AdjustControl === 'function') {
                            inst.AdjustControl();
                        }
                    } catch (e) { }
                }

                const inner = getInnerScroll();
                if (inner) {
                    try {
                        if (inner.scrollLeft !== 0) inner.scrollLeft = 0;
                        if (inner.scrollTop !== 0) inner.scrollTop = 0;
                    } catch (e) { }
                }

                window.__dxLog('[DX] requestLayoutKick:', reason || '', 'adjustKickCount=' + adjustKickCount);
            }

            function isReadyReason(reason) {
                const r = String(reason || '').toLowerCase();
                return r.indexOf('dx-end-sync') >= 0
                    || r.indexOf('dx-after-document-response') >= 0
                    || r.indexOf('dx-process-document-response') >= 0
                    || r.indexOf('dx-init-raf') >= 0;
            }

            function cleanupObservers() {
                if (rafId) {
                    cancelAnimationFrame(rafId);
                    rafId = 0;
                }

                if (domObserver) {
                    try { domObserver.disconnect(); } catch (e) { }
                    domObserver = null;
                }

                if (sizeObserver) {
                    try { sizeObserver.disconnect(); } catch (e) { }
                    sizeObserver = null;
                }
            }

            function applyAndRender(reason) {
                state.previewExtent = { width: 0, height: 0 };
                applyDxWrapSize(reason || 'dx-stable');
            }

            function finalize(reason) {
                if (finalized) return;
                finalized = true;
                cleanupObservers();

                applyAndRender(reason || 'dx-stable');
                installOuterScrollOnly();

                requestAnimationFrame(function () {
                    requestAnimationFrame(function () {
                        applyAndRender((reason || 'dx-stable') + '-postoverlay');

                        if (scroll) scroll.classList.add('dx-page-ready');
                        state.overlayReady = true;

                        try {
                            var inst = getDxInstance();
                            if (inst && typeof inst.AdjustControl === 'function') {
                                inst.AdjustControl();
                            }
                        } catch (e) { }

                        requestAnimationFrame(function () {
                            applyAndRender('post-adjust-once');
                        });

                        window.__dxLog('[DX] page shown by', reason || 'dx-stable');
                    });
                });
            }

            function evaluateStable(reason) {
                if (finalized) return;
                if (state.dxSyncing) return;
                if (!readySignal) return;
                if (!hasVisibleContent()) return;

                const sig = getSignature();
                const parsed = JSON.parse(sig);

                if (parsed.w <= 0 || parsed.h <= 0) return;

                if (sig === stableSignature) {
                    stableCount++;
                } else {
                    stableSignature = sig;
                    stableCount = 1;
                }

                window.__dxLog('[DX] stable-check:', {
                    reason: reason || '',
                    readyReason: readyReason,
                    stableCount: stableCount,
                    signature: parsed
                });

                if (stableCount >= 1) {
                    finalize(readyReason || reason || 'dx-stable');
                    return;
                }

                rafId = requestAnimationFrame(function () {
                    rafId = requestAnimationFrame(function () {
                        evaluateStable((reason || 'dx-stable') + '-raf');
                    });
                });
            }

            function scheduleEvaluate(reason) {
                if (!readySignal && !isReadyReason(reason)) return;

                if (rafId) cancelAnimationFrame(rafId);
                rafId = requestAnimationFrame(function () {
                    rafId = requestAnimationFrame(function () {
                        evaluateStable(reason || 'dx-eval');
                    });
                });
            }

            function schedulePostFinalizeRefresh(reason) {
                if (!finalized) return;
                if (postFinalizeRaf) return;

                postFinalizeRaf = requestAnimationFrame(function () {
                    postFinalizeRaf = requestAnimationFrame(function () {
                        postFinalizeRaf = 0;
                        applyAndRender('post-finalize:' + (reason || ''));
                    });
                });
            }

            domObserver = new MutationObserver(function () {
                if (!finalized) scheduleEvaluate('dx-dom-mutation');
            });

            domObserver.observe(wrap, {
                childList: true,
                subtree: true,
                attributes: false
            });

            if (typeof ResizeObserver !== 'undefined') {
                sizeObserver = new ResizeObserver(function () {
                    if (!finalized) scheduleEvaluate('dx-resize-observer');
                });

                [wrap, getWbc(), getPage()].filter(Boolean).forEach(function (el) {
                    try { sizeObserver.observe(el); } catch (e) { }
                });
            }

            window.__dxDetailOnEndSyncImpl = function (reason) {
                state.dxSyncing = false;

                if (isReadyReason(reason)) {
                    readySignal = true;
                    readyReason = reason || '';
                    stableCount = 0;
                    stableSignature = '';
                    window.__dxLog('[DX] ready-signal accepted:', readyReason);
                } else {
                    window.__dxLog('[DX] ready-signal ignored:', reason || '');
                }

                if (finalized) {
                    schedulePostFinalizeRefresh(reason || 'dx-end-sync');
                    return;
                }

                // 2026.06.23 Removed: DevExpress 동기화 완료 시 자동 Backfill 호출 중지 Contents 문서 열람 안정화 후 승인 협조 이벤트에서만 스탬프 저장을 수행한다

                requestLayoutKick(reason || 'dx-end-sync');
                scheduleEvaluate(reason || 'dx-end-sync');
            };

            if (window.__dxDetailOnEndSyncPending) {
                const pendingReason = window.__dxDetailOnEndSyncPending;
                window.__dxDetailOnEndSyncPending = null;
                requestLayoutKick(pendingReason || 'pending-sync');
                scheduleEvaluate(pendingReason || 'pending-sync');
            } else {
                requestLayoutKick('hook-start');
            }

            if (!window.__DETAIL_DX_RESIZE_BOUND__) {
                window.__DETAIL_DX_RESIZE_BOUND__ = true;
                window.addEventListener('resize', function () {
                    if (resizeRaf) cancelAnimationFrame(resizeRaf);
                    resizeRaf = requestAnimationFrame(function () {
                        resizeRaf = 0;
                        if (state.overlayReady) {
                            applyAndRender('window-resize');
                        } else {
                            scheduleEvaluate('window-resize');
                        }
                    });
                }, { passive: true });
            }
        }

        function run() {
            clearAlert();

            state.preview = readJsonFromScript('PreviewJson', {}) || {};
            state.descriptor = readJsonFromScript('DescriptorJson', {}) || {};

            state.approvalsData = Array.isArray(readJsonFromScript('ApprovalsJson', []))
                ? readJsonFromScript('ApprovalsJson', [])
                : [];

            state.cooperationsData = Array.isArray(readJsonFromScript('CooperationsJson', []))
                ? readJsonFromScript('CooperationsJson', [])
                : [];

            // 2026.06.23 Removed: 기존 DOM 좌표 계산 제거 Contents 스탬프 위치는 서버에서 대상 A1 범위로 직접 처리한다
            state.approvalCellMap = { byStep: {}, byRoleKey: {} };
            state.cooperationCellMap = { byStep: {}, byRoleKey: {} };

            applyDxWrapSize();

            renderViewLogs();
            renderApprovalsTable();
            initRecipientsFromSelected();
            initRecipientsChangeButton();
            initDocFileImageOverlay();
            initComments();
            initApproveButtons();
            initRecallButton();
            initPrintExport();
            hookDxReady();
            installDetailDxSelectionChromeHider();

            (function installDetailDxStampBackfillAfterOpen() {
            if (window.__DETAIL_DX_STAMP_BACKFILL_AFTER_OPEN_INSTALLED__) return;
            window.__DETAIL_DX_STAMP_BACKFILL_AFTER_OPEN_INSTALLED__ = true;

            let backfillRunning = false;
            let backfillDone = false;
            let backfillRetryCount = 0;

            function getRequestVerificationTokenForStamp() {
                const el = document.querySelector('input[name="__RequestVerificationToken"]');
                return el ? String(el.value || '') : '';
            }

            function getSpreadsheetStateForStamp() {
                try {
                    if (window.getSpreadsheetStatePayload && typeof window.getSpreadsheetStatePayload === 'function') {
                        const state = window.getSpreadsheetStatePayload();
                        if (state) return state;
                    }
                } catch (e) {
                }

                try {
                    if (window.dxDetailSheet && typeof window.dxDetailSheet.getSpreadsheetState === 'function') {
                        const state = window.dxDetailSheet.getSpreadsheetState();
                        if (state) return state;
                    }
                } catch (e) {
                }

                try {
                    if (typeof ASPxClientControl !== 'undefined' &&
                        ASPxClientControl.GetControlCollection &&
                        ASPxClientControl.GetControlCollection()) {
                        const ctl = ASPxClientControl.GetControlCollection().GetByName('dxDetailSheet');
                        if (ctl && typeof ctl.getSpreadsheetState === 'function') {
                            const state = ctl.getSpreadsheetState();
                            if (state) return state;
                        }
                    }
                } catch (e) {
                }

                return null;
            }

            async function postDetailDxStampBackfill(payload) {
                const token = getRequestVerificationTokenForStamp();

                const res = await fetch('/Doc/BackfillStampsDX', {
                    method: 'POST',
                    credentials: 'same-origin',
                    headers: {
                        'Content-Type': 'application/json',
                        'Accept': 'application/json',
                        'RequestVerificationToken': token
                    },
                    body: JSON.stringify(payload || {})
                });

                const json = await res.json().catch(function () { return {}; });

                if (!res.ok) {
                    const err = new Error('BackfillStampsDX failed');
                    err.payload = json;
                    throw err;
                }

                return json;
            }

            function scheduleBackfillRetry(reason, delayMs) {
                window.setTimeout(function () {
                    requestDetailDxStampBackfill(reason);
                }, delayMs);
            }

            async function requestDetailDxStampBackfill(reason) {
                if (backfillDone || backfillRunning) return;
                if (!window.__dxStampBackfillRequired) return;

                const stampWorkPath = String(window.__dxStampWorkPath || '').trim();
                if (!stampWorkPath) return;

                const spreadsheetState = getSpreadsheetStateForStamp();
                if (!spreadsheetState) {
                    backfillRetryCount++;
                    if (backfillRetryCount <= 40)
                        scheduleBackfillRetry(reason || 'state-wait', 750);
                    return;
                }

                backfillRunning = true;

                try {
                    const result = await postDetailDxStampBackfill({
                        docId: docId,
                        spreadsheetState: spreadsheetState,
                        stampWorkPath: stampWorkPath
                    });

                    if (window.__dxLog)
                        window.__dxLog('[DX] BackfillStampsDX result', result);

                    if (result && result.ok === true) {
                        backfillDone = true;
                        window.__dxStampBackfillRequired = false;

                        // 2026.07.01 Changed: 스탬프 최초 표시 보정 Contents BackfillStampsDX 저장 성공 후 현재 열린 Spreadsheet가 저장된 파일을 다시 읽도록 한 번만 새로고침한다
                        var appliedCount = Number(result.applied || 0);
                        if (appliedCount > 0 && !window.__DETAIL_DX_STAMP_BACKFILL_RELOAD_SENT__) {
                            window.__DETAIL_DX_STAMP_BACKFILL_RELOAD_SENT__ = true;
                            window.setTimeout(function () {
                                window.location.reload();
                            }, 300);
                        }
                    } else {
                        backfillRunning = false;
                    }
                } catch (err) {
                    backfillRunning = false;

                    if (window.__dxWarn)
                        window.__dxWarn('[DX] BackfillStampsDX failed', reason || '', err);

                    backfillRetryCount++;
                    if (backfillRetryCount <= 3)
                        scheduleBackfillRetry(reason || 'failed-retry', 1500);
                }
            }

            function startBackfillAfterOpen() {
                if (!window.__dxStampBackfillRequired) return;

                scheduleBackfillRetry('after-open', 1800);
                scheduleBackfillRetry('after-open-late', 4000);
            }

            if (document.readyState === 'complete') {
                startBackfillAfterOpen();
            } else {
                window.addEventListener('load', startBackfillAfterOpen, { once: true });
            }
        })();
        }

        if (document.readyState === 'loading') {
            document.addEventListener('DOMContentLoaded', run);
        } else {
            run();
        }
    })();
    </script>
}
