                    const inst = getDxInstance();
                    if (inst) {
                        if (typeof inst.print === 'function') { try { inst.print(); return; } catch (e) { } }
                        if (typeof inst.ExecuteGesture === 'function') { try { inst.ExecuteGesture('Print'); return; } catch (e) { } }
