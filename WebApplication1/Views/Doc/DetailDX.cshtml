        //         if (candidateWidth >= saneMinWidth && candidateWidth <= saneMaxWidth) {
        //             finalWidth = Math.max(finalWidth, candidateWidth);
        //         }
        //     }

        //     if (contentBox.height > 0) {
        //         const candidateHeight = Math.ceil(contentBox.height + 8);
        //         if (candidateHeight >= saneMinHeight && candidateHeight <= saneMaxHeight) {
        //             finalHeight = Math.max(finalHeight, candidateHeight);
        //         }
        //     }

        //     // ── 크기 변경 없으면 skip (무한 루프 방지) ──
        //     const prev = state.previewExtent;
        //     if (prev && prev.width === finalWidth && prev.height === finalHeight) {
        //         return; // 변경 없음
        //     }

        //     state.previewExtent = { width: finalWidth, height: finalHeight };

        //     wrap.style.setProperty('width', finalWidth + 'px', 'important');
        //     wrap.style.setProperty('min-width', finalWidth + 'px', 'important');
        //     wrap.style.setProperty('max-width', finalWidth + 'px', 'important');
        //     wrap.style.setProperty('height', finalHeight + 'px', 'important');
        //     wrap.style.setProperty('min-height', finalHeight + 'px', 'important');
        //     wrap.style.setProperty('overflow', 'hidden', 'important');

        //     console.log('[DX] applyDxWrapSize:', 'reason=' + (reason || ''),
        //         'finalWidth=' + finalWidth, 'finalHeight=' + finalHeight);
        // }
                
        function applyDxWrapSize(reason) {
            const wrap = document.getElementById('dxDetailWrap');
            if (!wrap) return;

            const ext = computePreviewExtent(state.preview);

            const finalWidth = Math.max(600, Math.ceil(Number(ext.width || 900)));
            const finalHeight = Math.max(520, Math.ceil(Number(ext.height || 520)));

            // 크기 변경 없으면 skip
            const prev = state.previewExtent;
            if (prev && prev.width === finalWidth && prev.height === finalHeight) {
                return;
            }

            state.previewExtent = { width: finalWidth, height: finalHeight };

            wrap.style.setProperty('width', finalWidth + 'px', 'important');
            wrap.style.setProperty('min-width', finalWidth + 'px', 'important');
            wrap.style.setProperty('max-width', finalWidth + 'px', 'important');
            wrap.style.setProperty('height', finalHeight + 'px', 'important');
            wrap.style.setProperty('min-height', finalHeight + 'px', 'important');
            wrap.style.setProperty('overflow', 'hidden', 'important');

            console.log('[DX] applyDxWrapSize:', 'reason=' + (reason || ''),
                'finalWidth=' + finalWidth, 'finalHeight=' + finalHeight);
        }
        // ================== 외부 스크롤만 허용 ==================
        function installOuterScrollOnly() {
            const outer = document.getElementById('doc-scroll');
            const wrap = document.getElementById('dxDetailWrap');
            if (!outer || !wrap) return;

            const inner =
                document.getElementById('dxDetailSheet_ScrollContainer')
                || document.getElementById('dxDetailSheet_Grid')
                || $('[id$="_ScrollContainer"]', wrap)
                || $('[id$="_Grid"]', wrap);

            if (!inner) return;

            function lockInnerScroll() {
                if (inner.scrollTop !== 0) inner.scrollTop = 0;
                if (inner.scrollLeft !== 0) inner.scrollLeft = 0;
            }

            lockInnerScroll();

            if (!inner.dataset.dxOuterLocked) {
                inner.addEventListener('scroll', lockInnerScroll, { passive: true });
                inner.dataset.dxOuterLocked = '1';
            }

            if (!window.__DETAIL_DX_OUTER_WHEEL_INSTALLED__) {
                window.__DETAIL_DX_OUTER_WHEEL_INSTALLED__ = true;
                document.addEventListener('wheel', function (e) {
                    if (!wrap.contains(e.target)) return;
                    e.preventDefault();
                    lockInnerScroll();
                    if (e.deltaY) outer.scrollTop += e.deltaY;
                    if (e.deltaX) outer.scrollLeft += e.deltaX;
                }, { capture: true, passive: false });
            }
        }

        // ================== 상태 헬퍼 ==================
        function mapStatusKey(raw) {
            const s = String(raw || '').toUpperCase();
            if (!s) return '';
            if (s.startsWith('PENDING')) return 'DOC_Status_Pending';
            if (s === 'APPROVED' || s === 'APPROVE') return 'DOC_Status_Approved';
            if (s === 'REJECTED' || s === 'REJECT') return 'DOC_Status_Rejected';
            if (s.startsWith('ONHOLD') || s === 'HOLD' || s.startsWith('PENDINGHOLD')) return 'DOC_Status_OnHold';
            if (s === 'RECALLED') return 'DOC_Status_Recalled';
            if (s === 'CREATED' || s === 'CREATE' || s === 'DRAFT' || s === 'WRITTEN') return 'DOC_Status_Created';
            if (s === 'COOPERATED' || s === 'COOPERATE') return 'DOC_Btn_Cooperate';
            if (s === 'COOPERATEREJECT' || s === 'COOPERATE') return 'DOC_Btn_CooperateReject';
            return raw;
        }

        function extractPersonName(full) {
            if (!full) return '';
            const s = String(full).trim();
            if (s.indexOf('\u0040') >= 0) return '';   //  문자 포함 시 제외
            let parts = s.split(/\s+/).filter(Boolean);
            if (!parts.length) return '';
            parts = parts.map(p => p.replace(/님$/, ''));
            const hasHangul = t => /[가-힣]/.test(t);
            for (let i = parts.length - 1; i >= 0; i--) {
                if (hasHangul(parts[i])) return parts[i];
            }
            return parts[parts.length - 1];
        }

        function getApprovalDisplayName(a) {
            if (!a) return '';
            const v = a.approverDisplayText || a.ApproverDisplayText ||
                a.approverName || a.ApproverName ||
                a.actorName || a.ActorName ||
                a.userName || a.UserName ||
                a.approverValue || a.ApproverValue || '';
            return String(v || '').trim();
        }

        function formatApprovalCaption(a) {
            const fullText = getApprovalDisplayName(a);
            if (!fullText) return '';

            const parts = String(fullText).trim().split(/\s+/).filter(Boolean);
            if (!parts.length) return '';

            if (parts.length >= 3) return parts.slice(parts.length - 2).join(' ');
            if (parts.length === 2) return parts.join(' ');
            return parts[0];
        }

        // ================== A1 셀 주소 파싱 ==================
        function parseA1(a1) {
            const m = String(a1 || '').trim().toUpperCase().match(/^([A-Z]+)(\d+)$/);
            if (!m) return null;
            let col = 0;
            for (let i = 0; i < m[1].length; i++) col = (col * 26) + (m[1].charCodeAt(i) - 64);
            return { col1: col, row1: parseInt(m[2], 10) };
        }

        // ================== 스탬프 div 공통 생성 헬퍼 ==================
        function buildStampDiv(x, y, w, h, stampUrl, captionText, fallbackUrl, options) {
            options = options || {};

            const placementMode = String(options.placementMode || 'boxed');
            const padX = Math.max(0, Number(options.padX || 0));
            const padTop = Math.max(0, Number(options.padTop || 0));
            const captionHeight = Math.max(0, Number(options.captionHeight || 0));
            const bodyBottomPad = Math.max(0, Number(options.bodyBottomPad || 0));
            const scaleBoost = Math.max(0.1, Number(options.scaleBoost || 1));
            const targetWidthRatio = Math.max(0.1, Number(options.targetWidthRatio || 1));
            const targetHeightRatio = Math.max(0.1, Number(options.targetHeightRatio || 1));
            const maxWidthRatio = Math.max(0.5, Number(options.maxWidthRatio || 1));
            const maxHeightRatio = Math.max(0.5, Number(options.maxHeightRatio || 1));

            const boxW = Math.max(8, Math.round(w));
            const boxH = Math.max(8, Math.round(h));

            const div = document.createElement('div');
            div.dataset.stampOverlay = '1';
            div.style.cssText = [
                'position:absolute',
                'left:0',
                'top:0',
                'width:0',
                'height:0',
                'pointer-events:none',
                'z-index:20',
                'overflow:visible'
            ].join(';');

            const img = document.createElement('img');
            img.alt = 'stamp';
            img.crossOrigin = 'anonymous';
            img.style.cssText = [
                'position:absolute',
                'left:0',
                'top:0',
                'width:1px',
                'height:1px',
                'opacity:0',
                'transform:none',
                'object-fit:fill',
                'pointer-events:none'
            ].join(';');

            function renderCaption(drawW) {
                if (!captionText) return;

                const oldCap = div.querySelector('[data-stamp-caption="1"]');
                if (oldCap) oldCap.remove();

                const cap = document.createElement('div');
                const capW = Math.max(drawW, boxW + 56, 96);
                const capTop = Math.round(y + boxH - captionHeight);

                cap.dataset.stampCaption = '1';
                cap.textContent = captionText;
                cap.style.cssText = [
                    'position:absolute',
                    `left:${Math.round(x + boxW / 2)}px`,
                    `top:${capTop}px`,
                    'transform:translateX(-50%)',
                    `min-width:${Math.round(capW)}px`,
                    `max-width:${Math.round(capW + 24)}px`,
                    `height:${captionHeight}px`,
                    `line-height:${captionHeight}px`,
                    //`font-size:${Math.max(8, Math.min(10, captionHeight - 2))}px`,
                    'font-size:12px', // 기존 계산식 제거, 최소 12px 고정 보장
                    'text-align:center',
                    'color:#111',
                    'background:transparent',
                    'pointer-events:none',
                    'white-space:nowrap',
                    'overflow:visible',
                    'text-overflow:clip',
                    'padding:0 2px',
                    'font-family:sans-serif',
                    'font-weight:400',
                    'z-index:10'
                ].join(';');

                div.appendChild(cap);
            }

            function applyImageBox() {
                const bodyW = Math.max(8, boxW - padX * 2);
                const bodyH = Math.max(8, boxH - padTop - captionHeight - bodyBottomPad);

                const nw = Math.max(1, Number(img.naturalWidth || 1));
                const nh = Math.max(1, Number(img.naturalHeight || 1));

                let scale;
                let drawW;
                let drawH;
                let absLeft;
                let absTop;

                if (placementMode === 'fit-box-expanded') {
                    const widthScale = (bodyW * targetWidthRatio) / nw;
                    const heightScale = (bodyH * targetHeightRatio) / nh;

                    scale = Math.max(widthScale, heightScale) * scaleBoost;
                    if (!isFinite(scale) || scale <= 0) scale = 1;

                    drawW = Math.max(1, Math.round(nw * scale));
                    drawH = Math.max(1, Math.round(nh * scale));

                    const maxAllowedW = Math.max(boxW, Math.round(boxW * maxWidthRatio));
                    const maxAllowedH = Math.max(boxH, Math.round(boxH * maxHeightRatio));

                    if (drawW > maxAllowedW || drawH > maxAllowedH) {
                        const capScale = Math.min(
                            maxAllowedW / drawW,
                            maxAllowedH / drawH
                        );
                        drawW = Math.max(1, Math.round(drawW * capScale));
                        drawH = Math.max(1, Math.round(drawH * capScale));
                    }

                    absLeft = Math.round(x + (boxW - drawW) / 2);
                    absTop = Math.round(y + padTop + (bodyH - drawH) / 2);
                } else {
                    scale = Math.min(bodyW / nw, bodyH / nh);
                    if (!isFinite(scale) || scale <= 0) scale = 1;
                    scale *= scaleBoost;

                    drawW = Math.max(1, Math.round(nw * scale));
                    drawH = Math.max(1, Math.round(nh * scale));

                    absLeft = Math.round(x + padX + (bodyW - drawW) / 2);
                    absTop = Math.round(y + padTop + (bodyH - drawH) / 2);
                }

                img.style.left = absLeft + 'px';
                img.style.top = absTop + 'px';
                img.style.width = drawW + 'px';
                img.style.height = drawH + 'px';
                img.style.opacity = '1';

                renderCaption(drawW);

                console.log('[DX-DBG] stamp-size', {
                    placementMode: placementMode,
                    x: x,
                    y: y,
                    boxW: boxW,
                    boxH: boxH,
                    bodyW: bodyW,
                    bodyH: bodyH,
                    naturalW: nw,
                    naturalH: nh,
                    targetWidthRatio: targetWidthRatio,
                    targetHeightRatio: targetHeightRatio,
                    maxWidthRatio: maxWidthRatio,
                    maxHeightRatio: maxHeightRatio,
                    scaleBoost: scaleBoost,
                    drawW: drawW,
                    drawH: drawH,
                    absLeft: absLeft,
                    absTop: absTop,
                    captionHeight: captionHeight
                });
            }

            img.onload = function () {
                try {
                    if (img.dataset.trimmed !== '1') {
                        const canvas = document.createElement('canvas');
                        canvas.width = Math.max(1, img.naturalWidth || 1);
                        canvas.height = Math.max(1, img.naturalHeight || 1);

                        const ctx = canvas.getContext('2d');
                        if (ctx) {
                            ctx.drawImage(img, 0, 0);

                            const data = ctx.getImageData(0, 0, canvas.width, canvas.height).data;
                            let minX = canvas.width;
                            let minY = canvas.height;
                            let maxX = -1;
                            let maxY = -1;

                            for (let py = 0; py < canvas.height; py++) {
                                for (let px = 0; px < canvas.width; px++) {
                                    const i = (py * canvas.width + px) * 4;
                                    const alpha = data[i + 3];
                                    if (alpha < 10) continue;

                                    minX = Math.min(minX, px);
                                    minY = Math.min(minY, py);
                                    maxX = Math.max(maxX, px);
                                    maxY = Math.max(maxY, py);
                                }
                            }

                            if (maxX > minX && maxY > minY) {
                                const cw = maxX - minX + 1;
                                const ch = maxY - minY + 1;
                                const crop = document.createElement('canvas');
                                crop.width = cw;
                                crop.height = ch;

                                const cropCtx = crop.getContext('2d');
                                if (cropCtx) {
                                    cropCtx.drawImage(canvas, minX, minY, cw, ch, 0, 0, cw, ch);

                                    console.log('[DX-DBG] stamp-trim', {
                                        originalW: canvas.width,
                                        originalH: canvas.height,
                                        cropW: cw,
                                        cropH: ch,
                                        minX: minX,
                                        minY: minY,
                                        maxX: maxX,
                                        maxY: maxY
                                    });

                                    img.dataset.trimmed = '1';
                                    img.src = crop.toDataURL('image/png');
                                    return;
                                }
                            }
                        }
                    }
                } catch (e) { }

                applyImageBox();
            };

            if (fallbackUrl) {
                img.onerror = function () {
                    if (img.dataset.fallbackTried === '1') return;
                    img.dataset.fallbackTried = '1';
                    img.dataset.trimmed = '0';
                    img.src = fallbackUrl;
                };
            }

            img.src = stampUrl;
            div.appendChild(img);

            return div;
        }

        // ================== 승인 스탬프 렌더링 ==================
        function renderApprovalOverlay() {
            const wrap = document.getElementById('dxDetailWrap');
            if (!wrap) return;

            const overlay = document.getElementById('dxApprovalOverlay') || wrap;
            overlay.querySelectorAll('div[data-stamp-overlay]').forEach(el => el.remove());

                console.log('[DX-DBG] preview.merges:', JSON.stringify(state.preview?.merges));

            const approvals = Array.isArray(state.approvalsData) ? state.approvalsData : [];
            const cooperations = Array.isArray(state.cooperationsData) ? state.cooperationsData : [];
            if (!approvals.length && !cooperations.length) return;

            const chEl =
                document.getElementById('dxDetailSheet_ColumnHeader') ||
                document.querySelector('#dxDetailWrap [id$="_ColumnHeader"]');

            const rhEl =
                document.getElementById('dxDetailSheet_RowHeader') ||
                document.querySelector('#dxDetailWrap [id$="_RowHeader"]');

            if (!chEl || !rhEl) {
                setTimeout(renderApprovalOverlay, 300);
                return;
            }

            const wrapRect = wrap.getBoundingClientRect();
            const chRect = chEl.getBoundingClientRect();
            const rhRect = rhEl.getBoundingClientRect();

            if (chRect.width < 50 || rhRect.height < 50) {
                setTimeout(renderApprovalOverlay, 300);
                return;
            }

            function parseA1CellLocal(a1Cell) {
                const m = String(a1Cell || '').trim().toUpperCase().match(/^([A-Z]+)(\d+)$/);
                if (!m) return null;
                return { colLabel: m[1], row: parseInt(m[2], 10) };
            }

            function colLabelToIndex(label) {
                let col = 0;
                const s = String(label || '').trim().toUpperCase();
                for (let i = 0; i < s.length; i++) col = col * 26 + (s.charCodeAt(i) - 64);
                return col;
            }

            function colIndexToLabel(idx) {
                let n = Number(idx || 0);
                let out = '';
                while (n > 0) {
                    const r = (n - 1) % 26;
                    out = String.fromCharCode(65 + r) + out;
                    n = Math.floor((n - 1) / 26);
                }
                return out || 'A';
            }

            function parseA1RangeLocal(a1) {
                const raw = String(a1 || '').trim().toUpperCase();
                if (!raw) return null;

                const parts = raw.split(':').map(v => v.trim()).filter(Boolean);
                const start = parseA1CellLocal(parts[0]);
                const end = parseA1CellLocal(parts[1] || parts[0]);

                if (!start || !end) return null;

                const fromCol = Math.min(colLabelToIndex(start.colLabel), colLabelToIndex(end.colLabel));
                const toCol = Math.max(colLabelToIndex(start.colLabel), colLabelToIndex(end.colLabel));
                const fromRow = Math.min(start.row, end.row);
                const toRow = Math.max(start.row, end.row);

                return {
                    raw,
                    from: { col: fromCol, row: fromRow, colLabel: colIndexToLabel(fromCol) },
                    to: { col: toCol, row: toRow, colLabel: colIndexToLabel(toCol) }
                };
            }

            function buildColumnRectMap() {
                const colMap = {};
                const cells = chEl.querySelectorAll('.dxss-htd[data-header-cell-index]');

                cells.forEach(function (el) {
                    const label = String(el.textContent || '').trim().toUpperCase();
                    if (!/^[A-Z]+$/.test(label)) return;

                    const r = el.getBoundingClientRect();
                    if (r.width <= 0 || r.height <= 0) return;

                    const left = r.left - wrapRect.left;
                    const right = r.right - wrapRect.left;

                    if (!colMap[label] || left < colMap[label].left) {
                        colMap[label] = {
                            left: left,
                            right: right,
                            width: right - left
                        };
                    }
                });

                return colMap;
            }

            function buildRowRectMap() {
                const rowMap = {};
                const rowBaseTop = parseFloat(rhEl.style.top || '0') || 0;

                let tileOffsetTop = 0;
                const rowTiles = rhEl.querySelectorAll('.dxss-ht');

                rowTiles.forEach(function (tile) {
                    const tileHeight = parseFloat(tile.style.height || '0') || 0;
                    const cells = tile.querySelectorAll('.dxss-htd[data-header-cell-index]');

                    cells.forEach(function (el) {
                        const label = String(el.textContent || '').trim();
                        if (!/^\d+$/.test(label)) return;

                        const rowNo = parseInt(label, 10);
                        const cellTop = parseFloat(el.style.top || '0') || 0;
                        const cellHeight = parseFloat(el.style.height || '0') || 0;
                        if (cellHeight <= 0) return;

                        const top = rowBaseTop + tileOffsetTop + cellTop;
                        const bottom = top + cellHeight;

                        rowMap[rowNo] = {
                            top: top,
                            bottom: bottom,
                            height: cellHeight
                        };
                    });

                    tileOffsetTop += tileHeight;
                });

                return rowMap;
            }

            function normalizeMergeRange(rawMerge) {
                const m = parseA1RangeLocal(rawMerge);
                if (!m) return null;
                return {
                    fromCol: m.from.col,
                    toCol: m.to.col,
                    fromRow: m.from.row,
                    toRow: m.to.row
                };
            }

            function getPreviewMergeRanges() {
                const preview = state.preview || {};
                const rawMerges = Array.isArray(preview.merges) ? preview.merges : [];
                const list = [];

                rawMerges.forEach(function (m) {
                    if (typeof m === 'string') {
                        const parsed = normalizeMergeRange(m);
                        if (parsed) list.push(parsed);
                        return;
                    }

                    // 4-element 1-based 배열: [r1, c1, r2, c2]
                    if (Array.isArray(m) && m.length >= 4) {
                        const fromRow = parseInt(m[0], 10);
                        const fromCol = parseInt(m[1], 10);
                        const toRow   = parseInt(m[2], 10);
                        const toCol   = parseInt(m[3], 10);

                        if (
                            Number.isFinite(fromCol) && Number.isFinite(toCol) &&
                            Number.isFinite(fromRow) && Number.isFinite(toRow) &&
                            fromCol > 0 && toCol > 0 && fromRow > 0 && toRow > 0
                        ) {
                            list.push({
                                fromCol: Math.min(fromCol, toCol),
                                toCol: Math.max(fromCol, toCol),
                                fromRow: Math.min(fromRow, toRow),
                                toRow: Math.max(fromRow, toRow)
                            });
                        }
                        return;
                    }

                    const a1 = m && (m.a1 || m.A1 || m.range || m.Range);
                    if (typeof a1 === 'string') {
                        const parsed = normalizeMergeRange(a1);
                        if (parsed) list.push(parsed);
                        return;
                    }

                    // s/e 객체형은 0-based 유지
                    if (m && m.s && m.e) {
                        const fromCol = Number(m.s.c || m.s.col || 0) + 1;
                        const toCol = Number(m.e.c || m.e.col || 0) + 1;
                        const fromRow = Number(m.s.r || m.s.row || 0) + 1;
                        const toRow = Number(m.e.r || m.e.row || 0) + 1;

                        if (fromCol > 0 && toCol > 0 && fromRow > 0 && toRow > 0) {
                            list.push({
                                fromCol: Math.min(fromCol, toCol),
                                toCol: Math.max(fromCol, toCol),
                                fromRow: Math.min(fromRow, toRow),
                                toRow: Math.max(fromRow, toRow)
                            });
                        }
                    }
                });

                return list;
            }

            function expandRangeByMerges(range) {
                if (!range) return null;

                const merges = getPreviewMergeRanges();
                let fromCol = range.from.col;
                let toCol = range.to.col;
                let fromRow = range.from.row;
                let toRow = range.to.row;
                let changed = true;

                while (changed) {
                    changed = false;

                    merges.forEach(function (mg) {
                        const overlapCol = !(mg.toCol < fromCol || mg.fromCol > toCol);
                        const overlapRow = !(mg.toRow < fromRow || mg.fromRow > toRow);

                        if (overlapCol && overlapRow) {
                            const nextFromCol = Math.min(fromCol, mg.fromCol);
                            const nextToCol = Math.max(toCol, mg.toCol);
                            const nextFromRow = Math.min(fromRow, mg.fromRow);
                            const nextToRow = Math.max(toRow, mg.toRow);

                            if (
                                nextFromCol !== fromCol ||
                                nextToCol !== toCol ||
                                nextFromRow !== fromRow ||
                                nextToRow !== toRow
                            ) {
                                fromCol = nextFromCol;
                                toCol = nextToCol;
                                fromRow = nextFromRow;
                                toRow = nextToRow;
                                changed = true;
                            }
                        }
                    });
                }

                return {
                    raw: range.raw,
                    from: { col: fromCol, row: fromRow, colLabel: colIndexToLabel(fromCol) },
                    to: { col: toCol, row: toRow, colLabel: colIndexToLabel(toCol) }
                };
            }

            function getRangeBox(range, colRectMap, rowRectMap) {
                if (!range) return null;

                const expanded = expandRangeByMerges(range);

                const c1 = colRectMap[expanded.from.colLabel];
                const c2 = colRectMap[expanded.to.colLabel];
                const r1 = rowRectMap[expanded.from.row];
                const r2 = rowRectMap[expanded.to.row];

                if (!c1 || !c2 || !r1 || !r2) return null;

                const left = Math.min(c1.left, c2.left);
                const right = Math.max(c1.right, c2.right);
                const top = Math.min(r1.top, r2.top);
                const bottom = Math.max(r1.bottom, r2.bottom);

                const box = {
                    x: left,
                    y: top,
                    w: Math.max(1, right - left),
                    h: Math.max(1, bottom - top)
                };

                console.log('[DX-DBG] expanded-range-box', {
                    raw: range.raw,
                    expandedFrom: expanded.from.colLabel + expanded.from.row,
                    expandedTo: expanded.to.colLabel + expanded.to.row,
                    box: box
                });

                return box;
            }

            function normalizeBucketName(v) {
                const s = String(v || '').trim().toLowerCase();
                if (!s) return '';
                if (s.includes('coop') || s.includes('cooperation') || s.includes('협조')) return 'cooperation';
                if (s.includes('approv') || s.includes('approval') || s.includes('결재')) return 'approval';
                return '';
            }

            function inferBucketFromRow(row) {
                const candidates = [
                    row.kind, row.Kind,
                    row.type, row.Type,
                    row.group, row.Group,
                    row.section, row.Section,
                    row.category, row.Category,
                    row.mode, row.Mode,
                    row.stampType, row.StampType,
                    row.approvalType, row.ApprovalType
                ];

                for (let i = 0; i < candidates.length; i++) {
                    const bucket = normalizeBucketName(candidates[i]);
                    if (bucket) return bucket;
                }

                const roleKey = String(row.roleKey || row.RoleKey || '').trim().toUpperCase();
                if (roleKey.startsWith('C')) return 'cooperation';
                if (roleKey.startsWith('A')) return 'approval';

                if (row.isCooperation === true || row.IsCooperation === true) return 'cooperation';
                return 'approval';
            }

            function __rangePickFirst() {
                for (let i = 0; i < arguments.length; i++) {
                    const v = arguments[i];
                    if (v !== undefined && v !== null && String(v).trim() !== '') return v;
                }
                return null;
            }

            function __rangeToFinite(v) {
                const n = Number(v);
                return isFinite(n) ? n : null;
            }

            function __rangeToColNo(v, zeroBased) {
                if (v == null || String(v).trim() === '') return null;

                const s = String(v).trim().toUpperCase();
                if (/^[A-Z]+$/.test(s)) return colLabelToIndex(s);

                const n = __rangeToFinite(v);
                if (n == null) return null;

                return zeroBased ? (n + 1) : n;
            }

            function __rangeToRowNo(v, zeroBased) {
                if (v == null || String(v).trim() === '') return null;

                const n = __rangeToFinite(v);
                if (n == null) return null;

                return zeroBased ? (n + 1) : n;
            }

            function __normalizeA1Text(v) {
                const raw = String(v || '').trim().toUpperCase();
                if (!raw) return '';

                const parsed = parseA1RangeLocal(raw);
                return parsed ? parsed.raw : '';
            }

            function __buildMappedA1FromRow(row) {
                if (!row) return '';

                if (typeof row === 'string') {
                    return __normalizeA1Text(row);
                }

                if (typeof row !== 'object') return '';

                const directRange =
                    __normalizeA1Text(__rangePickFirst(
                        row.a1Range, row.A1Range,
                        row.rangeA1, row.RangeA1,
                        row.cellRange, row.CellRange,
                        row.range, row.Range,
                        row.address, row.Address,
                        row.ref, row.Ref
                    ));

                if (directRange) return directRange;

                const anchorA1 =
                    __normalizeA1Text(__rangePickFirst(
                        row.a1, row.A1,
                        row.cellA1, row.CellA1,
                        row.anchorA1, row.AnchorA1,
                        row.startA1, row.StartA1
                    ));

                const anchor = anchorA1 ? parseA1RangeLocal(anchorA1) : null;

                let fromCol =
                    __rangeToColNo(__rangePickFirst(
                        row.fromCol, row.FromCol,
                        row.startCol, row.StartCol,
                        row.firstCol, row.FirstCol,
                        row.leftCol, row.LeftCol,
                        row.col1, row.Col1
                    ), false);

                let toCol =
                    __rangeToColNo(__rangePickFirst(
                        row.toCol, row.ToCol,
                        row.endCol, row.EndCol,
                        row.lastCol, row.LastCol,
                        row.rightCol, row.RightCol,
                        row.col2, row.Col2
                    ), false);

                let fromRow =
                    __rangeToRowNo(__rangePickFirst(
                        row.fromRow, row.FromRow,
                        row.startRow, row.StartRow,
                        row.firstRow, row.FirstRow,
                        row.topRow, row.TopRow,
                        row.row1, row.Row1
                    ), false);

                let toRow =
                    __rangeToRowNo(__rangePickFirst(
                        row.toRow, row.ToRow,
                        row.endRow, row.EndRow,
                        row.lastRow, row.LastRow,
                        row.bottomRow, row.BottomRow,
                        row.row2, row.Row2
                    ), false);

                if (fromCol == null) {
                    fromCol = __rangeToColNo(__rangePickFirst(
                        row.sc, row.SC,
                        row.scol, row.SCol,
                        row.startCol0, row.StartCol0,
                        row.fromCol0, row.FromCol0
                    ), true);
                }

                if (toCol == null) {
                    toCol = __rangeToColNo(__rangePickFirst(
                        row.ec, row.EC,
                        row.ecol, row.ECol,
                        row.endCol0, row.EndCol0,
                        row.toCol0, row.ToCol0
                    ), true);
                }

                if (fromRow == null) {
                    fromRow = __rangeToRowNo(__rangePickFirst(
                        row.sr, row.SR,
                        row.srow, row.SRow,
                        row.startRow0, row.StartRow0,
                        row.fromRow0, row.FromRow0
                    ), true);
                }

                if (toRow == null) {
                    toRow = __rangeToRowNo(__rangePickFirst(
                        row.er, row.ER,
                        row.erow, row.ERow,
                        row.endRow0, row.EndRow0,
                        row.toRow0, row.ToRow0
                    ), true);
                }

                const colSpan = Math.max(1, __rangeToFinite(__rangePickFirst(
                    row.colSpan, row.ColSpan,
                    row.columnSpan, row.ColumnSpan,
                    row.spanX, row.SpanX,
                    row.widthCells, row.WidthCells
                )) || 1);

                const rowSpan = Math.max(1, __rangeToFinite(__rangePickFirst(
                    row.rowSpan, row.RowSpan,
                    row.heightSpan, row.HeightSpan,
                    row.spanY, row.SpanY,
                    row.heightCells, row.HeightCells
                )) || 1);

                if (anchor) {
                    if (fromCol == null) fromCol = anchor.from.col;
                    if (fromRow == null) fromRow = anchor.from.row;

                    if (toCol == null) {
                        if (anchor.to && anchor.to.col && anchor.to.col !== anchor.from.col) toCol = anchor.to.col;
                        else if (colSpan > 1) toCol = fromCol + colSpan - 1;
                        else toCol = fromCol;
                    }

                    if (toRow == null) {
                        if (anchor.to && anchor.to.row && anchor.to.row !== anchor.from.row) toRow = anchor.to.row;
                        else if (rowSpan > 1) toRow = fromRow + rowSpan - 1;
                        else toRow = fromRow;
                    }
                }

                if (
                    fromCol == null || toCol == null ||
                    fromRow == null || toRow == null ||
                    fromCol <= 0 || toCol <= 0 ||
                    fromRow <= 0 || toRow <= 0
                ) {
                    return anchorA1 || '';
                }

                const finalFromCol = Math.min(fromCol, toCol);
                const finalToCol = Math.max(fromCol, toCol);
                const finalFromRow = Math.min(fromRow, toRow);
                const finalToRow = Math.max(fromRow, toRow);

                const out =
                    colIndexToLabel(finalFromCol) + finalFromRow +
                    ':' +
                    colIndexToLabel(finalToCol) + finalToRow;

                return __normalizeA1Text(out);
            }
       
            function buildLocalCellMap() {
                const rows = readJsonFromScript('ApprovalCellsJson', []);
                const built = {
                    approval: { byStep: {}, byRoleKey: {} },
                    cooperation: { byStep: {}, byRoleKey: {} }
                };

                if (!Array.isArray(rows)) return built;

                rows.forEach(function (row) {
                    const resolvedA1 = __buildMappedA1FromRow(row);
                    if (!resolvedA1) return;

                    const bucket = inferStampBucketFromRow(row);
                    const step = row.step || row.Step || row.stepOrder || row.StepOrder || row.slot || row.Slot;
                    const roleKey = String(row.roleKey || row.RoleKey || '').trim();

                    const payload = {
                        row: row,
                        a1: resolvedA1
                    };

                    if (step != null && step !== '') built[bucket].byStep[String(step)] = payload;
                    if (roleKey) built[bucket].byRoleKey[roleKey] = payload;
                });

                return built;
            }


            const localMap = buildLocalCellMap();
            const legacyApprovalMap = state.approvalCellMap || { byStep: {}, byRoleKey: {} };
            const legacyCooperationMap = state.cooperationCellMap || { byStep: {}, byRoleKey: {} };

            function __unwrapMappedA1(v) {
                if (!v) return '';
                if (typeof v === 'string') return __normalizeA1Text(v);
                if (typeof v === 'object') {
                    if (v.a1) return __normalizeA1Text(v.a1);
                    return __buildMappedA1FromRow(v.row || v);
                }
                return '';
            }
       
            function resolveMappedA1(raw, step, bucketName) {
                const roleKey = String(raw.roleKey || raw.RoleKey || '').trim();
                const bucket = bucketName === 'cooperation' ? 'cooperation' : 'approval';

                if (roleKey && localMap[bucket].byRoleKey[roleKey]) {
                    return __unwrapMappedA1(localMap[bucket].byRoleKey[roleKey]);
                }

                if (localMap[bucket].byStep[String(step)]) {
                    return __unwrapMappedA1(localMap[bucket].byStep[String(step)]);
                }

                const legacyBucketMap = bucket === 'cooperation'
                    ? legacyCooperationMap
                    : legacyApprovalMap;

                if (legacyBucketMap && typeof legacyBucketMap === 'object') {
                    if (roleKey && legacyBucketMap.byRoleKey && legacyBucketMap.byRoleKey[roleKey]) {
                        return __unwrapMappedA1(legacyBucketMap.byRoleKey[roleKey]);
                    }

                    if (legacyBucketMap.byStep && legacyBucketMap.byStep[String(step)]) {
                        return __unwrapMappedA1(legacyBucketMap.byStep[String(step)]);
                    }
                }

                // approval 만 하위 호환 flat fallback 허용
                // cooperation 은 여기로 내려오면 다시 approval 좌표를 참조하게 되므로 금지
                if (bucket === 'approval') {
                    const legacyFlat = state.approvalCellMap;
                    if (legacyFlat && typeof legacyFlat === 'object') {
                        if (roleKey && legacyFlat[roleKey]) return __unwrapMappedA1(legacyFlat[roleKey]);
                        if (legacyFlat[String(step)]) return __unwrapMappedA1(legacyFlat[String(step)]);
                        if (legacyFlat[step]) return __unwrapMappedA1(legacyFlat[step]);
                    }
                }
                return __buildMappedA1FromRow(raw);
            }

            function getStampLayout(box, kind) {
                return {
                    x: box.x,
                    y: box.y,
                    w: box.w,
                    h: box.h,
                    placementMode: 'boxed',
                    padX: 0,
                    padTop: kind === 'status' ? 1 : 2,
                    captionHeight: 14,
                    bodyBottomPad: 0,
                    targetWidthRatio: 1,
                    targetHeightRatio: 1,
                    maxWidthRatio: 1,
                    maxHeightRatio: 1,
                    scaleBoost: 1
                };
            }

            function resolveStampMeta(raw) {
                const STAMP_BASE = '/images/signatures/';
                const HOLDING_STAMP = STAMP_BASE + 'holding.png';
                const REJECTED_STAMP = STAMP_BASE + 'rejected.png';
                const APPROVED_STAMP = STAMP_BASE + 'approved.png';

                const actionRaw = String(raw.action || raw.Action || '').trim().toUpperCase();
                const statusRaw = String(raw.status || raw.Status || '').trim().toUpperCase();
                const sigPathRaw = String(raw.signaturePath || raw.SignaturePath || '').trim();

                if (actionRaw === 'APPROVE' || statusRaw === 'APPROVED') {
                    if (sigPathRaw) {
                        return {
                            stampUrl: STAMP_BASE + sigPathRaw.replace(/^[\\/]+/, '').replace(/\\/g, '/'),
                            fallbackUrl: APPROVED_STAMP,
                            kind: 'signature'
                        };
                    }
                    return {
                        stampUrl: APPROVED_STAMP,
                        fallbackUrl: APPROVED_STAMP,
                        kind: 'status'
                    };
                }

                if (
                    actionRaw === 'HOLD' ||
                    statusRaw === 'HOLD' ||
                    statusRaw === 'ONHOLD' ||
                    statusRaw.startsWith('PENDINGHOLD')
                ) {
                    return {
                        stampUrl: HOLDING_STAMP,
                        fallbackUrl: HOLDING_STAMP,
                        kind: 'status'
                    };
                }

                if (actionRaw === 'REJECT' || statusRaw === 'REJECTED') {
                    return {
                        stampUrl: REJECTED_STAMP,
                        fallbackUrl: REJECTED_STAMP,
                        kind: 'status'
                    };
                }

                if (actionRaw === 'COOPERATE' || statusRaw === 'COOPERATED') {
                    if (sigPathRaw) {
                        return {
                            stampUrl: STAMP_BASE + sigPathRaw.replace(/^[\\/]+/, '').replace(/\\/g, '/'),
                            fallbackUrl: APPROVED_STAMP,
                            kind: 'signature'
                        };
                    }
                    return {
                        stampUrl: APPROVED_STAMP,
                        fallbackUrl: APPROVED_STAMP,
                        kind: 'status'
                    };
                }

                return null;
            }

            function appendStamp(raw, step, a1, debugPrefix, bucketName, colRectMap, rowRectMap) {
                const range = parseA1RangeLocal(a1);
                if (!range) return;

                const box = getRangeBox(range, colRectMap, rowRectMap);
                if (!box || box.w < 8 || box.h < 8) return;

                const meta = resolveStampMeta(raw);
                if (!meta || !meta.stampUrl) return;

                const captionText = formatApprovalCaption(raw);
                const fit = getStampLayout(box, meta.kind);

                const div = buildStampDiv(
                    fit.x,
                    fit.y,
                    fit.w,
                    fit.h,
                    meta.stampUrl,
                    captionText,
                    meta.fallbackUrl,
                    {
                        placementMode: fit.placementMode,
                        padX: fit.padX,
                        padTop: fit.padTop,
                        captionHeight: fit.captionHeight,
                        bodyBottomPad: fit.bodyBottomPad,
                        targetWidthRatio: fit.targetWidthRatio,
                        targetHeightRatio: fit.targetHeightRatio,
                        maxWidthRatio: fit.maxWidthRatio,
                        maxHeightRatio: fit.maxHeightRatio,
                        scaleBoost: fit.scaleBoost
                    }
                );

                overlay.appendChild(div);

                console.log(
                    `[DX] ${debugPrefix} stamp`,
                    'bucket=' + bucketName,
                    'step=' + step,
                    'a1=' + a1,
                    'box=(' + Math.round(box.x) + ',' + Math.round(box.y) + ',' + Math.round(box.w) + ',' + Math.round(box.h) + ')',
                    'placementMode=' + fit.placementMode,
                    'padX=' + fit.padX,
                    'padTop=' + fit.padTop,
                    'captionHeight=' + fit.captionHeight,
                    'bodyBottomPad=' + fit.bodyBottomPad,
                    'scaleBoost=' + fit.scaleBoost
                );
            }

            const colRectMap = buildColumnRectMap();
            const rowRectMap = buildRowRectMap();

            console.log(
                '[DX] measured header maps',
                'cols=' + Object.keys(colRectMap).length,
                'rows=' + Object.keys(rowRectMap).length
            );

            overlay.style.position = 'absolute';
            wrap.style.position = 'relative';

            approvals.forEach(function (a, idx) {
                let step = parseInt(a.step || a.Step || a.stepOrder || a.StepOrder || (idx + 1), 10);
                if (!step || !isFinite(step)) step = idx + 1;

                const a1 = resolveMappedA1(a, step, 'approval');
                if (!a1) return;

                appendStamp(a, step, a1, 'approval', 'approval', colRectMap, rowRectMap);
            });
    
            cooperations.forEach(function (c, idx) {
                let step = parseInt(c.step || c.Step || c.stepOrder || c.StepOrder || c.slot || c.Slot || (idx + 1), 10);
                if (!step || !isFinite(step)) step = idx + 1;

                const a1 = resolveMappedA1(c, step, 'cooperation');
                console.log('[DX] cooperation mapped a1', {
                    step: step,
                    roleKey: String(c.roleKey || c.RoleKey || ''),
                    a1: a1,
                    source: state.cooperationCellMap
                });

                if (!a1) return;

                appendStamp(c, step, a1, 'cooperation', 'cooperation', colRectMap, rowRectMap);
            });
        }
        
