                        const width = rect ? Math.abs(rect.width || 0) : 0;
                        const height = rect ? Math.abs(rect.height || 0) : 0;
                        const isSmallHandle = width > 0 && height > 0 && width <= 18 && height <= 18;

                        const hasBlueBorder =
                            isBlueSelectionColor(cs.borderTopColor)
                            || isBlueSelectionColor(cs.borderRightColor)
                            || isBlueSelectionColor(cs.borderBottomColor)
                            || isBlueSelectionColor(cs.borderLeftColor)
                            || isBlueSelectionColor(cs.outlineColor);

                        const hasBlueBackground =
                            isBlueSelectionColor(cs.backgroundColor)
                            || isBlueSelectionColor(cs.background);

