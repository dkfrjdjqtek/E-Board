            <button type="button" class="btn btn-sm btn-warning btn-hold" data-hold @(canHold ? "" : "disabled")>
                @S["DOC_Btn_Hold"]
            </button>
            <button type="button" class="btn btn-sm btn-danger btn-reject" data-reject @(canReject ? "" : "disabled")>
                @S["DOC_Btn_Reject"]
