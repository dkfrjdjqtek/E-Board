                a.actorName || a.ActorName ||
                a.userName || a.UserName ||
                a.approverValue || a.ApproverValue || '';
            return String(v || '').trim();
        }

        function formatApprovalCaption(a) {
            const fullText = getApprovalDisplayName(a);
            if (!fullText) return '';

            const parts = String(fullText).trim().split(/\s+/).filter(Boolean);
            if (!parts.length) return '';

            if (parts.length >= 3) return parts.slice(parts.length - 2).join(' ');
            if (parts.length === 2) return parts.join(' ');
            return parts[0];
        }

