            <button type="button" class="btn btn-sm btn-danger btn-cooperate-reject" data-cooperate-reject @(canCooperateReject ? "" : "disabled")>
                @S["DOC_Btn_CooperateReject"]
            </button>
        </div>
    </section>

</div>

<div id="ebImgOverlay" class="eb-img-overlay" aria-hidden="true">
