                clearInterval(timer);
                const joined = selectedIds.join(',');
                const hidden = root.querySelector('[data-role="org-ms-value"]');
                if (hidden) hidden.value = joined;
                const nameField = root.querySelector('input[name="SelectedRecipientUserIds"], textarea[name="SelectedRecipientUserIds"]');
