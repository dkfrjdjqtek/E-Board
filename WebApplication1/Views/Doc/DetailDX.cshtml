                            cs.borderTopStyle !== 'none'
                            || cs.borderRightStyle !== 'none'
                            || cs.borderBottomStyle !== 'none'
                            || cs.borderLeftStyle !== 'none'
                            || cs.outlineStyle !== 'none'
                            || hasBlueBoxShadow;

