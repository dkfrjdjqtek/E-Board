        // ================== 외부 스크롤만 허용 ==================
        function installOuterScrollOnly() {
            const outer = document.getElementById('doc-scroll');
            const wrap = document.getElementById('dxDetailWrap');
            if (!outer || !wrap) return;

            const inner =
                document.getElementById('dxDetailSheet_ScrollContainer')
                || document.getElementById('dxDetailSheet_Grid')
                || $('[id$="_ScrollContainer"]', wrap)
                || $('[id$="_Grid"]', wrap);

            if (!inner) return;

            function lockInnerScroll() {
                if (inner.scrollTop !== 0) inner.scrollTop = 0;
                if (inner.scrollLeft !== 0) inner.scrollLeft = 0;
            }

            lockInnerScroll();
            inner.addEventListener('scroll', lockInnerScroll, { passive: true });

            if (!window.__DETAIL_DX_OUTER_WHEEL_INSTALLED__) {
                window.__DETAIL_DX_OUTER_WHEEL_INSTALLED__ = true;
                document.addEventListener('wheel', function (e) {
                    if (!wrap.contains(e.target)) return;
                    e.preventDefault();
                    lockInnerScroll();
                    if (e.deltaY) outer.scrollTop += e.deltaY;
                    if (e.deltaX) outer.scrollLeft += e.deltaX;
                }, { capture: true, passive: false });
            }
        }

        // ================== 상태 헬퍼 ==================
        function mapStatusKey(raw) {
            const s = String(raw || '').toUpperCase();
            if (!s) return '';
            if (s.startsWith('PENDING')) return 'DOC_Status_Pending';
            if (s === 'APPROVED' || s === 'APPROVE') return 'DOC_Status_Approved';
            if (s === 'REJECTED' || s === 'REJECT') return 'DOC_Status_Rejected';
            if (s.startsWith('ONHOLD') || s === 'HOLD' || s.startsWith('PENDINGHOLD')) return 'DOC_Status_OnHold';
            if (s === 'RECALLED') return 'DOC_Status_Recalled';
            if (s === 'CREATED' || s === 'CREATE' || s === 'DRAFT' || s === 'WRITTEN') return 'DOC_Status_Created';
            if (s === 'COOPERATED' || s === 'COOPERATE') return 'DOC_Btn_Cooperate';
            if (s === 'COOPERATEREJECT' || s === 'COOPERATE') return 'DOC_Btn_CooperateReject';
            return raw;
        }

        function extractPersonName(full) {
            if (!full) return '';
            const s = String(full).trim();
            if (s.indexOf('\u0040') >= 0) return '';
            let parts = s.split(/\s+/).filter(Boolean);
            if (!parts.length) return '';
            parts = parts.map(p => p.replace(/님$/, ''));
            const hasHangul = t => /[가-힣]/.test(t);
            for (let i = parts.length - 1; i >= 0; i--) {
                if (hasHangul(parts[i])) return parts[i];
            }
            return parts[parts.length - 1];
        }

        function getApprovalDisplayName(a) {
            if (!a) return '';
            const v = a.approverDisplayText || a.ApproverDisplayText ||
                a.approverName || a.ApproverName ||
                a.actorName || a.ActorName ||
                a.userName || a.UserName ||
                a.approverValue || a.ApproverValue || '';
            return String(v || '').trim();
        }

        function formatApprovalCaption(a) {
            const fullText = getApprovalDisplayName(a);
            if (!fullText) return '';

            const parts = String(fullText).trim().split(/\s+/).filter(Boolean);
            if (!parts.length) return '';

            if (parts.length >= 3) return parts.slice(parts.length - 2).join(' ');
            if (parts.length === 2) return parts.join(' ');
            return parts[0];
        }

        // ================== A1 셀 주소 파싱 ==================
        function parseA1(a1) {
            const m = String(a1 || '').trim().toUpperCase().match(/^([A-Z]+)(\d+)$/);
            if (!m) return null;
            let col = 0;
            for (let i = 0; i < m[1].length; i++) col = (col * 26) + (m[1].charCodeAt(i) - 64);
            return { col1: col, row1: parseInt(m[2], 10) };
        }

        // ================== 스탬프 div 공통 생성 헬퍼 ==================
        function buildStampDiv(x, y, w, h, stampUrl, captionText, fallbackUrl, options) {
            options = options || {};

            const placementMode = String(options.placementMode || 'boxed');
            const padX = Math.max(0, Number(options.padX || 0));
            const padTop = Math.max(0, Number(options.padTop || 0));
            const captionHeight = Math.max(0, Number(options.captionHeight || 0));
            const bodyBottomPad = Math.max(0, Number(options.bodyBottomPad || 0));
            const scaleBoost = Math.max(0.1, Number(options.scaleBoost || 1));
            const targetWidthRatio = Math.max(0.1, Number(options.targetWidthRatio || 1));
            const targetHeightRatio = Math.max(0.1, Number(options.targetHeightRatio || 1));
            const maxWidthRatio = Math.max(0.5, Number(options.maxWidthRatio || 1));
            const maxHeightRatio = Math.max(0.5, Number(options.maxHeightRatio || 1));

            const boxW = Math.max(8, Math.round(w));
            const boxH = Math.max(8, Math.round(h));

            const div = document.createElement('div');
            div.dataset.stampOverlay = '1';
            div.style.cssText = [
                'position:absolute',
                'left:0',
                'top:0',
                'width:0',
                'height:0',
                'pointer-events:none',
                'z-index:20',
                'overflow:visible'
            ].join(';');

            const img = document.createElement('img');
            img.alt = 'stamp';
            img.crossOrigin = 'anonymous';
            img.style.cssText = [
                'position:absolute',
                'left:0',
                'top:0',
                'width:1px',
                'height:1px',
                'opacity:0',
                'transform:none',
                'object-fit:fill',
                'pointer-events:none'
            ].join(';');

            function renderCaption(drawW) {
                if (!captionText) return;

                const oldCap = div.querySelector('[data-stamp-caption="1"]');
                if (oldCap) oldCap.remove();

                const cap = document.createElement('div');
                const capW = Math.max(drawW, boxW + 56, 96);
                const capTop = Math.round(y + boxH - captionHeight);

                cap.dataset.stampCaption = '1';
                cap.textContent = captionText;
                cap.style.cssText = [
                    'position:absolute',
                    `left:${Math.round(x + boxW / 2)}px`,
                    `top:${capTop}px`,
                    'transform:translateX(-50%)',
                    `min-width:${Math.round(capW)}px`,
                    `max-width:${Math.round(capW + 24)}px`,
                    `height:${captionHeight}px`,
                    `line-height:${captionHeight}px`,
                    'font-size:12px',
                    'text-align:center',
                    'color:#111',
                    'background:transparent',
                    'pointer-events:none',
                    'white-space:nowrap',
                    'overflow:visible',
                    'text-overflow:clip',
                    'padding:0 2px',
                    'font-family:sans-serif',
                    'font-weight:400',
                    'z-index:10'
                ].join(';');

                div.appendChild(cap);
            }

            function getBoundsFromMask(mask, width, height) {
                let minX = width;
                let minY = height;
                let maxX = -1;
                let maxY = -1;
                let count = 0;

                for (let py = 0; py < height; py++) {
                    const rowBase = py * width;
                    for (let px = 0; px < width; px++) {
                        if (!mask[rowBase + px]) continue;
                        count++;
                        if (px < minX) minX = px;
                        if (py < minY) minY = py;
                        if (px > maxX) maxX = px;
                        if (py > maxY) maxY = py;
                    }
                }

                if (count <= 0 || maxX < minX || maxY < minY) return null;

                return {
                    minX: minX,
                    minY: minY,
                    maxX: maxX,
                    maxY: maxY,
                    count: count
                };
            }

            function filterSmallComponents(mask, width, height, totalForegroundCount) {
                const visited = new Uint8Array(mask.length);
                const keptMask = new Uint8Array(mask.length);
                const minArea = Math.max(6, Math.round(totalForegroundCount * 0.0015));

                let keptCount = 0;
                let unionMinX = width;
                let unionMinY = height;
                let unionMaxX = -1;
                let unionMaxY = -1;

                const stack = [];
                const cells = [];

                function pushNeighbor(nx, ny) {
                    if (nx < 0 || ny < 0 || nx >= width || ny >= height) return;
                    const nidx = ny * width + nx;
                    if (visited[nidx] || !mask[nidx]) return;
                    visited[nidx] = 1;
                    stack.push(nidx);
                }

                for (let idx = 0; idx < mask.length; idx++) {
                    if (!mask[idx] || visited[idx]) continue;

                    visited[idx] = 1;
                    stack.length = 0;
                    cells.length = 0;
                    stack.push(idx);

                    let area = 0;
                    let minX = width;
                    let minY = height;
                    let maxX = -1;
                    let maxY = -1;

                    while (stack.length) {
                        const cur = stack.pop();
                        cells.push(cur);
                        area++;

                        const py = Math.floor(cur / width);
                        const px = cur - py * width;

                        if (px < minX) minX = px;
                        if (py < minY) minY = py;
                        if (px > maxX) maxX = px;
                        if (py > maxY) maxY = py;

                        pushNeighbor(px - 1, py - 1);
                        pushNeighbor(px,     py - 1);
                        pushNeighbor(px + 1, py - 1);
                        pushNeighbor(px - 1, py);
                        pushNeighbor(px + 1, py);
                        pushNeighbor(px - 1, py + 1);
                        pushNeighbor(px,     py + 1);
                        pushNeighbor(px + 1, py + 1);
                    }

                    if (area < minArea) continue;

                    for (let i = 0; i < cells.length; i++) {
                        keptMask[cells[i]] = 1;
                    }

                    keptCount += area;
                    if (minX < unionMinX) unionMinX = minX;
                    if (minY < unionMinY) unionMinY = minY;
                    if (maxX > unionMaxX) unionMaxX = maxX;
                    if (maxY > unionMaxY) unionMaxY = maxY;
                }

                return {
                    keptMask: keptMask,
                    keptCount: keptCount,
                    bounds: (keptCount > 0 && unionMaxX >= unionMinX && unionMaxY >= unionMinY)
                        ? { minX: unionMinX, minY: unionMinY, maxX: unionMaxX, maxY: unionMaxY, count: keptCount }
                        : null,
                    minArea: minArea
                };
            }

            function buildForegroundBounds(imageEl) {
                const srcW = Math.max(1, imageEl.naturalWidth || 1);
                const srcH = Math.max(1, imageEl.naturalHeight || 1);

                const srcCanvas = document.createElement('canvas');
                srcCanvas.width = srcW;
                srcCanvas.height = srcH;

                const srcCtx = srcCanvas.getContext('2d', { willReadFrequently: true });
                if (!srcCtx) return null;
                srcCtx.clearRect(0, 0, srcW, srcH);
                srcCtx.drawImage(imageEl, 0, 0);

                const scanCanvas = document.createElement('canvas');
                scanCanvas.width = srcW;
                scanCanvas.height = srcH;

                const scanCtx = scanCanvas.getContext('2d', { willReadFrequently: true });
                if (!scanCtx) return null;

                scanCtx.fillStyle = '#ffffff';
                scanCtx.fillRect(0, 0, srcW, srcH);
                scanCtx.drawImage(imageEl, 0, 0);

                const srcImageData = srcCtx.getImageData(0, 0, srcW, srcH);
                const scanImageData = scanCtx.getImageData(0, 0, srcW, srcH);

                const srcData = srcImageData.data;
                const scanData = scanImageData.data;
                const gray = new Uint8Array(srcW * srcH);
                const mask = new Uint8Array(srcW * srcH);

                let borderSum = 0;
                let borderCount = 0;

                for (let py = 0; py < srcH; py++) {
                    for (let px = 0; px < srcW; px++) {
                        const i = (py * srcW + px) * 4;
                        const r = scanData[i];
                        const g = scanData[i + 1];
                        const b = scanData[i + 2];
                        const luminance = Math.round(0.299 * r + 0.587 * g + 0.114 * b);
                        gray[py * srcW + px] = luminance;

                        if (py === 0 || px === 0 || py === srcH - 1 || px === srcW - 1) {
                            borderSum += luminance;
                            borderCount++;
                        }
                    }
                }

                const bgGray = borderCount > 0 ? (borderSum / borderCount) : 255;
                const threshold = Math.max(180, Math.min(245, Math.round(bgGray - 10)));

                let foregroundCount = 0;

                for (let py = 0; py < srcH; py++) {
                    const rowBase = py * srcW;
                    for (let px = 0; px < srcW; px++) {
                        const idx = rowBase + px;
                        const i = idx * 4;

                        const luminance = gray[idx];
                        const alpha = srcData[i + 3];

                        if (luminance <= threshold) {
                            mask[idx] = 1;
                            foregroundCount++;
                            continue;
                        }

                        if (alpha > 24 && luminance <= 252) {
                            mask[idx] = 1;
                            foregroundCount++;
                        }
                    }
                }

                if (foregroundCount <= 0) {
                    return null;
                }

                const filtered = filterSmallComponents(mask, srcW, srcH, foregroundCount);
                let bounds = filtered.bounds;

                if (!bounds) {
                    bounds = getBoundsFromMask(mask, srcW, srcH);
                }

                if (!bounds) {
                    return null;
                }

                const pad = 1;
                const minX = Math.max(0, bounds.minX - pad);
                const minY = Math.max(0, bounds.minY - pad);
                const maxX = Math.min(srcW - 1, bounds.maxX + pad);
                const maxY = Math.min(srcH - 1, bounds.maxY + pad);

                const cropW = Math.max(1, maxX - minX + 1);
                const cropH = Math.max(1, maxY - minY + 1);

                const cropCanvas = document.createElement('canvas');
                cropCanvas.width = cropW;
                cropCanvas.height = cropH;

                const cropCtx = cropCanvas.getContext('2d');
                if (!cropCtx) return null;

                cropCtx.clearRect(0, 0, cropW, cropH);
                cropCtx.drawImage(srcCanvas, minX, minY, cropW, cropH, 0, 0, cropW, cropH);

                window.__dxLog('[DX-DBG] stamp-bounds', {
                    originalW: srcW,
                    originalH: srcH,
                    cropW: cropW,
                    cropH: cropH,
                    bgGray: Math.round(bgGray),
                    threshold: threshold,
                    foregroundCount: foregroundCount,
                    keptCount: filtered.keptCount,
                    minArea: filtered.minArea,
                    minX: minX,
                    minY: minY,
                    maxX: maxX,
                    maxY: maxY
                });

                return cropCanvas.toDataURL('image/png');
            }

            function applyImageBox() {
                const bodyW = Math.max(8, boxW - padX * 2);
                const bodyH = Math.max(8, boxH - padTop - bodyBottomPad);

                const nw = Math.max(1, Number(img.naturalWidth || 1));
                const nh = Math.max(1, Number(img.naturalHeight || 1));

                let scale;
                let drawW;
                let drawH;
                let absLeft;
                let absTop;

                if (placementMode === 'fit-box-expanded') {
                    const widthScale = (bodyW * targetWidthRatio) / nw;
                    const heightScale = (bodyH * targetHeightRatio) / nh;

                    scale = Math.max(widthScale, heightScale) * scaleBoost;
                    if (!isFinite(scale) || scale <= 0) scale = 1;

                    drawW = Math.max(1, Math.round(nw * scale));
                    drawH = Math.max(1, Math.round(nh * scale));

                    const maxAllowedW = Math.max(bodyW, Math.round(bodyW * maxWidthRatio));
                    const maxAllowedH = Math.max(bodyH, Math.round(bodyH * maxHeightRatio));

                    if (drawW > maxAllowedW || drawH > maxAllowedH) {
                        const capScale = Math.min(
                            maxAllowedW / drawW,
                            maxAllowedH / drawH
                        );
                        drawW = Math.max(1, Math.round(drawW * capScale));
                        drawH = Math.max(1, Math.round(drawH * capScale));
                    }

                    absLeft = Math.round(x + (boxW - drawW) / 2);
                    absTop = Math.round(y + padTop + (bodyH - drawH) / 2);
                } else {
                    scale = Math.min(bodyW / nw, bodyH / nh);
                    if (!isFinite(scale) || scale <= 0) scale = 1;
                    scale *= scaleBoost;

                    drawW = Math.max(1, Math.round(nw * scale));
                    drawH = Math.max(1, Math.round(nh * scale));

                    absLeft = Math.round(x + padX + (bodyW - drawW) / 2);
                    absTop = Math.round(y + padTop + (bodyH - drawH) / 2);
                }

                img.style.left = absLeft + 'px';
                img.style.top = absTop + 'px';
                img.style.width = drawW + 'px';
                img.style.height = drawH + 'px';
                img.style.opacity = '1';

                renderCaption(drawW);

                window.__dxLog('[DX-DBG] stamp-size', {
                    placementMode: placementMode,
                    x: x,
                    y: y,
                    boxW: boxW,
                    boxH: boxH,
                    bodyW: bodyW,
                    bodyH: bodyH,
                    naturalW: nw,
                    naturalH: nh,
                    targetWidthRatio: targetWidthRatio,
                    targetHeightRatio: targetHeightRatio,
                    maxWidthRatio: maxWidthRatio,
                    maxHeightRatio: maxHeightRatio,
                    scaleBoost: scaleBoost,
                    drawW: drawW,
                    drawH: drawH,
                    absLeft: absLeft,
                    absTop: absTop,
                    captionHeight: captionHeight
                });
            }

            img.onload = function () {
                try {
                    if (img.dataset.trimmed !== '1') {
                        const trimmedDataUrl = buildForegroundBounds(img);
                        if (trimmedDataUrl) {
                            img.dataset.trimmed = '1';
                            img.src = trimmedDataUrl;
                            return;
                        }
                    }
                } catch (e) {
                    window.__dxWarn('[DX-DBG] stamp-trim-failed', e);
                }

                applyImageBox();
            };

            if (fallbackUrl) {
                img.onerror = function () {
                    if (img.dataset.fallbackTried === '1') return;
                    img.dataset.fallbackTried = '1';
                    img.dataset.trimmed = '0';
                    img.src = fallbackUrl;
                };
            }

            img.src = stampUrl;
            div.appendChild(img);

            return div;
        }

        // ================== 승인 스탬프 렌더링 ==================
        function renderApprovalOverlay() {
            const wrap = document.getElementById('dxDetailWrap');
            if (!wrap) return;
            if (state.overlayRendering) {
                window.__dxLog('[DX] renderApprovalOverlay skipped: overlayRendering');
                return;
            }

            state.overlayRendering = true;

            try {
                const overlay = document.getElementById('dxApprovalOverlay') || wrap;
                overlay.querySelectorAll('div[data-stamp-overlay]').forEach(el => el.remove());

                if (!window.__DX_DETAIL_PREVIEW_MERGES_LOGGED__) {
                    window.__DX_DETAIL_PREVIEW_MERGES_LOGGED__ = true;
                    window.__dxLog('[DX-DBG] preview.merges:', JSON.stringify(state.preview?.merges));
                }

                const approvals = Array.isArray(state.approvalsData) ? state.approvalsData : [];
                const cooperations = Array.isArray(state.cooperationsData) ? state.cooperationsData : [];
                if (!approvals.length && !cooperations.length) return;

                const chEl =
                    document.getElementById('dxDetailSheet_ColumnHeader') ||
                    document.querySelector('#dxDetailWrap [id$="_ColumnHeader"]');

                const rhEl =
                    document.getElementById('dxDetailSheet_RowHeader') ||
                    document.querySelector('#dxDetailWrap [id$="_RowHeader"]');

                if (!chEl || !rhEl) {
                    state.overlayRetryCount = Number(state.overlayRetryCount || 0);
                    if (state.overlayRetryCount < 6) {
                        clearTimeout(state.overlayRetryTimer);
                        state.overlayRetryTimer = setTimeout(function () {
                            state.overlayRetryCount++;
                            window.__dxLog('[DX] renderApprovalOverlay retry: missing headers', state.overlayRetryCount);
                            renderApprovalOverlay();
                        }, 300);
                    } else {
                        window.__dxWarn('[DX] renderApprovalOverlay stopped: missing headers');
                    }
                    return;
                }

                const wrapRect = wrap.getBoundingClientRect();
                const chRect = chEl.getBoundingClientRect();
                const rhRect = rhEl.getBoundingClientRect();

                if (chRect.width < 50 || rhRect.height < 50) {
                    state.overlayRetryCount = Number(state.overlayRetryCount || 0);
                    if (state.overlayRetryCount < 6) {
                        clearTimeout(state.overlayRetryTimer);
                        state.overlayRetryTimer = setTimeout(function () {
                            state.overlayRetryCount++;
                            window.__dxLog('[DX] renderApprovalOverlay retry: header size too small', state.overlayRetryCount, chRect.width, rhRect.height);
                            renderApprovalOverlay();
                        }, 300);
                    } else {
                        window.__dxWarn('[DX] renderApprovalOverlay stopped: header size too small');
                    }
                    return;
                }

                state.overlayRetryCount = 0;

                function parseA1CellLocal(a1Cell) {
                    const m = String(a1Cell || '').trim().toUpperCase().match(/^([A-Z]+)(\d+)$/);
                    if (!m) return null;
                    return { colLabel: m[1], row: parseInt(m[2], 10) };
                }

                function colLabelToIndex(label) {
                    let col = 0;
                    const s = String(label || '').trim().toUpperCase();
                    for (let i = 0; i < s.length; i++) col = col * 26 + (s.charCodeAt(i) - 64);
                    return col;
                }

                function colIndexToLabel(idx) {
                    let n = Number(idx || 0);
                    let out = '';
                    while (n > 0) {
                        const r = (n - 1) % 26;
                        out = String.fromCharCode(65 + r) + out;
                        n = Math.floor((n - 1) / 26);
                    }
                    return out || 'A';
                }

                function parseA1RangeLocal(a1) {
                    const raw = String(a1 || '').trim().toUpperCase();
                    if (!raw) return null;

                    const parts = raw.split(':').map(v => v.trim()).filter(Boolean);
                    const start = parseA1CellLocal(parts[0]);
                    const end = parseA1CellLocal(parts[1] || parts[0]);

                    if (!start || !end) return null;

                    const fromCol = Math.min(colLabelToIndex(start.colLabel), colLabelToIndex(end.colLabel));
                    const toCol = Math.max(colLabelToIndex(start.colLabel), colLabelToIndex(end.colLabel));
                    const fromRow = Math.min(start.row, end.row);
                    const toRow = Math.max(start.row, end.row);

                    return {
                        raw,
                        from: { col: fromCol, row: fromRow, colLabel: colIndexToLabel(fromCol) },
                        to: { col: toCol, row: toRow, colLabel: colIndexToLabel(toCol) }
                    };
                }

                function buildColumnRectMap() {
                    const actualItems = [];
                    const legacyItems = [];

                    function pushItem(list, label, left, width, source) {
                        const cleanLabel = String(label || '').trim().toUpperCase();
                        if (!/^[A-Z]+$/.test(cleanLabel)) return;

                        const colNo = colLabelToIndex(cleanLabel);
                        const safeLeft = Number(left);
                        const safeWidth = Number(width);

                        if (!isFinite(colNo) || colNo <= 0) return;
                        if (!isFinite(safeLeft)) return;
                        if (!isFinite(safeWidth) || safeWidth <= 0) return;

                        list.push({
                            label: cleanLabel,
                            colNo: colNo,
                            left: safeLeft,
                            width: safeWidth,
                            right: safeLeft + safeWidth,
                            source: source || ''
                        });
                    }

                    const actualCells = chEl.querySelectorAll('.dxss-htd[data-header-cell-index]');

                    actualCells.forEach(function (el) {
                        const label = String(el.textContent || '').trim().toUpperCase();
                        if (!/^[A-Z]+$/.test(label)) return;

                        const r = el.getBoundingClientRect();
                        if (r.width <= 0 || r.height <= 0) return;

                        pushItem(
                            actualItems,
                            label,
                            r.left - wrapRect.left,
                            r.width,
                            'actual-dom'
                        );
                    });

                    const colBaseLeft = parseFloat(chEl.style.left || '0') || 0;
                    let tileOffsetLeft = 0;
                    const colTiles = chEl.querySelectorAll('.dxss-ht');

                    colTiles.forEach(function (tile) {
                        const tileWidth = parseFloat(tile.style.width || '0') || 0;
                        const cells = tile.querySelectorAll('.dxss-htd[data-header-cell-index]');

                        cells.forEach(function (el) {
                            const label = String(el.textContent || '').trim().toUpperCase();
                            if (!/^[A-Z]+$/.test(label)) return;

                            const cellLeft = parseFloat(el.style.left || '0') || 0;
                            let cellWidth = parseFloat(el.style.width || '0') || 0;

                            if (cellWidth <= 0) {
                                const r = el.getBoundingClientRect();
                                cellWidth = r.width || 0;
                            }

                            if (cellWidth <= 0) return;

                            pushItem(
                                legacyItems,
                                label,
                                colBaseLeft + tileOffsetLeft + cellLeft,
                                cellWidth,
                                'legacy-style'
                            );
                        });

                        tileOffsetLeft += tileWidth;
                    });

                    function normalizeItems(items, source) {
                        const map = {};

                        if (!Array.isArray(items) || !items.length) {
                            return {
                                map: map,
                                count: 0,
                                source: source,
                                outOfRange: true,
                                minLeft: 0,
                                maxRight: 0
                            };
                        }

                        items.sort(function (a, b) {
                            if (a.colNo !== b.colNo) return a.colNo - b.colNo;
                            return a.left - b.left;
                        });

                        const minLeft = items.reduce(function (min, item) {
                            return Math.min(min, item.left);
                        }, items[0].left);

                        const maxRight = items.reduce(function (max, item) {
                            return Math.max(max, item.right);
                        }, items[0].right);

                        const renderLimitW = Math.max(
                            Number(window.__dxLayoutWidthPx || 0),
                            Number(window.__dxRenderWidthPx || 0),
                            900
                        ) + 300;

                        let outOfRange = false;

                        items.forEach(function (item) {
                            const left = item.left - minLeft;
                            const right = item.right - minLeft;
                            const width = Math.max(1, item.width);

                            if (!isFinite(left) || !isFinite(right) || left < -50 || right > renderLimitW) {
                                outOfRange = true;
                            }

                            if (!map[item.label] || left < map[item.label].left) {
                                map[item.label] = {
                                    left: left,
                                    right: right,
                                    width: width
                                };
                            }
                        });

                        return {
                            map: map,
                            count: Object.keys(map).length,
                            source: source,
                            outOfRange: outOfRange,
                            minLeft: minLeft,
                            maxRight: maxRight,
                            renderLimitW: renderLimitW
                        };
                    }

                    const actual = normalizeItems(actualItems, 'actual-dom-normalized');
                    const legacy = normalizeItems(legacyItems, 'legacy-style-normalized');

                    let selected = actual;

                    if (
                        actual.count <= 0 ||
                        actual.outOfRange ||
                        (
                            legacy.count > 0 &&
                            !legacy.outOfRange &&
                            legacy.count >= actual.count
                        )
                    ) {
                        selected = legacy;
                    }

                    // 2026.06.19 Changed: DevExpress 열 헤더 가상 오프셋이 스탬프 x 좌표에 반영되지 않도록 첫 열 기준 상대 좌표로 보정
                    window.__dxLog('[DX] column map mode', {
                        mode: selected.source,
                        colsActual: actual.count,
                        colsLegacy: legacy.count,
                        actualOutOfRange: actual.outOfRange,
                        legacyOutOfRange: legacy.outOfRange,
                        actualMinLeft: Math.round(actual.minLeft || 0),
                        actualMaxRight: Math.round(actual.maxRight || 0),
                        legacyMinLeft: Math.round(legacy.minLeft || 0),
                        legacyMaxRight: Math.round(legacy.maxRight || 0),
                        renderLimitW: Math.round(selected.renderLimitW || 0)
                    });

                    return selected.map || {};
                }

                function buildRowRectMap() {
                    const wrap = document.getElementById('dxDetailWrap');
                    if (!wrap) return {};

                    const rhEl =
                        document.getElementById('dxDetailSheet_RowHeader')
                        || document.querySelector('#dxDetailWrap [id$="_RowHeader"]');

                    if (!rhEl) return {};

                    const legacyMap = {};
                    const actualMap = {};

                    const rowBaseTop = parseFloat(rhEl.style.top || '0') || 0;
                    let tileOffsetTop = 0;
                    const rowTiles = rhEl.querySelectorAll('.dxss-ht');

                    rowTiles.forEach(function (tile) {
                        const tileHeight = parseFloat(tile.style.height || '0') || 0;
                        const cells = tile.querySelectorAll('.dxss-htd[data-header-cell-index]');

                        cells.forEach(function (el) {
                            const label = String(el.textContent || '').trim();
                            if (!/^\d+$/.test(label)) return;

                            const rowNo = parseInt(label, 10);
                            const cellTop = parseFloat(el.style.top || '0') || 0;
                            const cellHeight = parseFloat(el.style.height || '0') || 0;
                            if (cellHeight <= 0) return;

                            const top = rowBaseTop + tileOffsetTop + cellTop;

                            legacyMap[rowNo] = {
                                top: top,
                                bottom: top + cellHeight,
                                height: cellHeight
                            };
                        });

                        tileOffsetTop += tileHeight;
                    });

                    const wrapRect = wrap.getBoundingClientRect();
                    const actualCells = rhEl.querySelectorAll('.dxss-htd[data-header-cell-index]');

                    actualCells.forEach(function (el) {
                        const label = String(el.textContent || '').trim();
                        if (!/^\d+$/.test(label)) return;

                        const rowNo = parseInt(label, 10);
                        const rect = el.getBoundingClientRect();

                        if (rect.width <= 0 || rect.height <= 0) return;

                        const top = rect.top - wrapRect.top;
                        const bottom = rect.bottom - wrapRect.top;

                        actualMap[rowNo] = {
                            top: top,
                            bottom: bottom,
                            height: Math.max(0, bottom - top)
                        };
                    });

                    const diffs = Object.keys(legacyMap)
                        .map(function (k) {
                            const rowNo = parseInt(k, 10);
                            if (!actualMap[rowNo]) return null;
                            return legacyMap[rowNo].top - actualMap[rowNo].top;
                        })
                        .filter(function (v) {
                            return typeof v === 'number' && isFinite(v);
                        })
                        .sort(function (a, b) { return a - b; });

                    let useActual = false;
                    let medianDiff = 0;
                    let maxSpread = 0;

                    if (diffs.length >= 3) {
                        const mid = Math.floor(diffs.length / 2);
                        medianDiff = diffs.length % 2
                            ? diffs[mid]
                            : (diffs[mid - 1] + diffs[mid]) / 2;

                        maxSpread = diffs.reduce(function (max, v) {
                            return Math.max(max, Math.abs(v - medianDiff));
                        }, 0);

                        useActual = Math.abs(medianDiff) >= 8 && maxSpread <= 3;
                    }

                    window.__dxLog('[DX] row map mode', {
                        mode: useActual ? 'actual-dom-corrected' : 'legacy-style',
                        rowsLegacy: Object.keys(legacyMap).length,
                        rowsActual: Object.keys(actualMap).length,
                        medianDiff: Math.round(medianDiff),
                        maxSpread: Math.round(maxSpread)
                    });

                    return useActual ? actualMap : legacyMap;
                }

                function normalizeMergeRange(rawMerge) {
                    const m = parseA1RangeLocal(rawMerge);
                    if (!m) return null;
                    return {
                        fromCol: m.from.col,
                        toCol: m.to.col,
                        fromRow: m.from.row,
                        toRow: m.to.row
                    };
                }

                function getPreviewMergeRanges() {
                    const preview = state.preview || {};
                    const rawMerges = Array.isArray(preview.merges) ? preview.merges : [];
                    const list = [];

                    rawMerges.forEach(function (m) {
                        if (typeof m === 'string') {
                            const parsed = normalizeMergeRange(m);
                            if (parsed) list.push(parsed);
                            return;
                        }

                        if (Array.isArray(m) && m.length >= 4) {
                            const fromRow = parseInt(m[0], 10);
                            const fromCol = parseInt(m[1], 10);
                            const toRow = parseInt(m[2], 10);
                            const toCol = parseInt(m[3], 10);

                            if (
                                Number.isFinite(fromCol) && Number.isFinite(toCol) &&
                                Number.isFinite(fromRow) && Number.isFinite(toRow) &&
                                fromCol > 0 && toCol > 0 && fromRow > 0 && toRow > 0
                            ) {
                                list.push({
                                    fromCol: Math.min(fromCol, toCol),
                                    toCol: Math.max(fromCol, toCol),
                                    fromRow: Math.min(fromRow, toRow),
                                    toRow: Math.max(fromRow, toRow)
                                });
                            }
                            return;
                        }

                        const a1 = m && (m.a1 || m.A1 || m.range || m.Range);
                        if (typeof a1 === 'string') {
                            const parsed = normalizeMergeRange(a1);
                            if (parsed) list.push(parsed);
                            return;
                        }

                        if (m && m.s && m.e) {
                            const fromCol = Number(m.s.c || m.s.col || 0) + 1;
                            const toCol = Number(m.e.c || m.e.col || 0) + 1;
                            const fromRow = Number(m.s.r || m.s.row || 0) + 1;
                            const toRow = Number(m.e.r || m.e.row || 0) + 1;

                            if (fromCol > 0 && toCol > 0 && fromRow > 0 && toRow > 0) {
                                list.push({
                                    fromCol: Math.min(fromCol, toCol),
                                    toCol: Math.max(fromCol, toCol),
                                    fromRow: Math.min(fromRow, toRow),
                                    toRow: Math.max(fromRow, toRow)
                                });
                            }
                        }
                    });

                    return list;
                }

                function expandRangeByMerges(range) {
                    if (!range) return null;

                    const merges = getPreviewMergeRanges();
                    let fromCol = range.from.col;
                    let toCol = range.to.col;
                    let fromRow = range.from.row;
                    let toRow = range.to.row;
                    let changed = true;

                    while (changed) {
                        changed = false;

                        merges.forEach(function (mg) {
                            const overlapCol = !(mg.toCol < fromCol || mg.fromCol > toCol);
                            const overlapRow = !(mg.toRow < fromRow || mg.fromRow > toRow);

                            if (overlapCol && overlapRow) {
                                const nextFromCol = Math.min(fromCol, mg.fromCol);
                                const nextToCol = Math.max(toCol, mg.toCol);
                                const nextFromRow = Math.min(fromRow, mg.fromRow);
                                const nextToRow = Math.max(toRow, mg.toRow);

                                if (
                                    nextFromCol !== fromCol ||
                                    nextToCol !== toCol ||
                                    nextFromRow !== fromRow ||
                                    nextToRow !== toRow
                                ) {
                                    fromCol = nextFromCol;
                                    toCol = nextToCol;
                                    fromRow = nextFromRow;
                                    toRow = nextToRow;
                                    changed = true;
                                }
                            }
                        });
                    }

                    return {
                        raw: range.raw,
                        from: { col: fromCol, row: fromRow, colLabel: colIndexToLabel(fromCol) },
                        to: { col: toCol, row: toRow, colLabel: colIndexToLabel(toCol) }
                    };
                }

                function getRangeBox(range, colRectMap, rowRectMap) {
                    if (!range) return null;

                    const expanded = expandRangeByMerges(range);

                    const c1 = colRectMap[expanded.from.colLabel];
                    const c2 = colRectMap[expanded.to.colLabel];
                    const r1 = rowRectMap[expanded.from.row];
                    const r2 = rowRectMap[expanded.to.row];

                    if (!c1 || !c2 || !r1 || !r2) return null;

                    const left = Math.min(c1.left, c2.left);
                    const right = Math.max(c1.right, c2.right);
                    const top = Math.min(r1.top, r2.top);
                    const bottom = Math.max(r1.bottom, r2.bottom);

                    const box = {
                        x: left,
                        y: top,
                        w: Math.max(1, right - left),
                        h: Math.max(1, bottom - top)
                    };

                    window.__dxLog('[DX-DBG] expanded-range-box', {
                        raw: range.raw,
                        expandedFrom: expanded.from.colLabel + expanded.from.row,
                        expandedTo: expanded.to.colLabel + expanded.to.row,
                        box: box
                    });

                    return box;
                }

                function normalizeBucketName(v) {
                    const s = String(v || '').trim().toLowerCase();
                    if (!s) return '';
                    if (s.includes('coop') || s.includes('cooperation') || s.includes('협조')) return 'cooperation';
                    if (s.includes('approv') || s.includes('approval') || s.includes('결재')) return 'approval';
                    return '';
                }

                function inferBucketFromRow(row) {
                    const candidates = [
                        row.kind, row.Kind,
                        row.type, row.Type,
                        row.group, row.Group,
                        row.section, row.Section,
                        row.category, row.Category,
                        row.mode, row.Mode,
                        row.stampType, row.StampType,
                        row.approvalType, row.ApprovalType
                    ];

                    for (let i = 0; i < candidates.length; i++) {
                        const bucket = normalizeBucketName(candidates[i]);
                        if (bucket) return bucket;
                    }

                    const roleKey = String(row.roleKey || row.RoleKey || '').trim().toUpperCase();
                    if (roleKey.startsWith('C')) return 'cooperation';
                    if (roleKey.startsWith('A')) return 'approval';

                    if (row.isCooperation === true || row.IsCooperation === true) return 'cooperation';
                    return 'approval';
                }

                function __rangePickFirst() {
                    for (let i = 0; i < arguments.length; i++) {
                        const v = arguments[i];
                        if (v !== undefined && v !== null && String(v).trim() !== '') return v;
                    }
                    return null;
                }

                function __rangeToFinite(v) {
                    const n = Number(v);
                    return isFinite(n) ? n : null;
                }

                function __rangeToColNo(v, zeroBased) {
                    if (v == null || String(v).trim() === '') return null;

                    const s = String(v).trim().toUpperCase();
                    if (/^[A-Z]+$/.test(s)) return colLabelToIndex(s);

                    const n = __rangeToFinite(v);
                    if (n == null) return null;

                    return zeroBased ? (n + 1) : n;
                }

                function __rangeToRowNo(v, zeroBased) {
                    if (v == null || String(v).trim() === '') return null;

                    const n = __rangeToFinite(v);
                    if (n == null) return null;

                    return zeroBased ? (n + 1) : n;
                }

                function __normalizeA1Text(v) {
                    const raw = String(v || '').trim().toUpperCase();
                    if (!raw) return '';

                    const parsed = parseA1RangeLocal(raw);
                    return parsed ? parsed.raw : '';
                }

                function __buildMappedA1FromRow(row) {
                    if (!row) return '';

                    if (typeof row === 'string') {
                        return __normalizeA1Text(row);
                    }

                    if (typeof row !== 'object') return '';

                    const directRange =
                        __normalizeA1Text(__rangePickFirst(
                            row.a1Range, row.A1Range,
                            row.rangeA1, row.RangeA1,
                            row.cellRange, row.CellRange,
                            row.range, row.Range,
                            row.address, row.Address,
                            row.ref, row.Ref
                        ));

                    if (directRange) return directRange;

                    const anchorA1 =
                        __normalizeA1Text(__rangePickFirst(
                            row.a1, row.A1,
                            row.cellA1, row.CellA1,
                            row.anchorA1, row.AnchorA1,
                            row.startA1, row.StartA1
                        ));

                    const anchor = anchorA1 ? parseA1RangeLocal(anchorA1) : null;

                    let fromCol =
                        __rangeToColNo(__rangePickFirst(
                            row.fromCol, row.FromCol,
                            row.startCol, row.StartCol,
                            row.firstCol, row.FirstCol,
                            row.leftCol, row.LeftCol,
                            row.col1, row.Col1
                        ), false);

                    let toCol =
                        __rangeToColNo(__rangePickFirst(
                            row.toCol, row.ToCol,
                            row.endCol, row.EndCol,
                            row.lastCol, row.LastCol,
                            row.rightCol, row.RightCol,
                            row.col2, row.Col2
                        ), false);

                    let fromRow =
                        __rangeToRowNo(__rangePickFirst(
                            row.fromRow, row.FromRow,
                            row.startRow, row.StartRow,
                            row.firstRow, row.FirstRow,
                            row.topRow, row.TopRow,
                            row.row1, row.Row1
                        ), false);

                    let toRow =
                        __rangeToRowNo(__rangePickFirst(
                            row.toRow, row.ToRow,
                            row.endRow, row.EndRow,
                            row.lastRow, row.LastRow,
                            row.bottomRow, row.BottomRow,
                            row.row2, row.Row2
                        ), false);

                    if (fromCol == null) {
                        fromCol = __rangeToColNo(__rangePickFirst(
                            row.sc, row.SC,
                            row.scol, row.SCol,
                            row.startCol0, row.StartCol0,
                            row.fromCol0, row.FromCol0
                        ), true);
                    }

                    if (toCol == null) {
                        toCol = __rangeToColNo(__rangePickFirst(
                            row.ec, row.EC,
                            row.ecol, row.ECol,
                            row.endCol0, row.EndCol0,
                            row.toCol0, row.ToCol0
                        ), true);
                    }

                    if (fromRow == null) {
                        fromRow = __rangeToRowNo(__rangePickFirst(
                            row.sr, row.SR,
                            row.srow, row.SRow,
                            row.startRow0, row.StartRow0,
                            row.fromRow0, row.FromRow0
                        ), true);
                    }

                    if (toRow == null) {
                        toRow = __rangeToRowNo(__rangePickFirst(
                            row.er, row.ER,
                            row.erow, row.ERow,
                            row.endRow0, row.EndRow0,
                            row.toRow0, row.ToRow0
                        ), true);
                    }

                    const colSpan = Math.max(1, __rangeToFinite(__rangePickFirst(
                        row.colSpan, row.ColSpan,
                        row.columnSpan, row.ColumnSpan,
                        row.spanX, row.SpanX,
                        row.widthCells, row.WidthCells
                    )) || 1);

                    const rowSpan = Math.max(1, __rangeToFinite(__rangePickFirst(
                        row.rowSpan, row.RowSpan,
                        row.heightSpan, row.HeightSpan,
                        row.spanY, row.SpanY,
                        row.heightCells, row.HeightCells
                    )) || 1);

                    if (anchor) {
                        if (fromCol == null) fromCol = anchor.from.col;
                        if (fromRow == null) fromRow = anchor.from.row;

                        if (toCol == null) {
                            if (anchor.to && anchor.to.col && anchor.to.col !== anchor.from.col) toCol = anchor.to.col;
                            else if (colSpan > 1) toCol = fromCol + colSpan - 1;
                            else toCol = fromCol;
                        }

                        if (toRow == null) {
                            if (anchor.to && anchor.to.row && anchor.to.row !== anchor.from.row) toRow = anchor.to.row;
                            else if (rowSpan > 1) toRow = fromRow + rowSpan - 1;
                            else toRow = fromRow;
                        }
                    }

                    if (
                        fromCol == null || toCol == null ||
                        fromRow == null || toRow == null ||
                        fromCol <= 0 || toCol <= 0 ||
                        fromRow <= 0 || toRow <= 0
                    ) {
                        return anchorA1 || '';
                    }

                    const finalFromCol = Math.min(fromCol, toCol);
                    const finalToCol = Math.max(fromCol, toCol);
                    const finalFromRow = Math.min(fromRow, toRow);
                    const finalToRow = Math.max(fromRow, toRow);

                    const out =
                        colIndexToLabel(finalFromCol) + finalFromRow +
                        ':' +
                        colIndexToLabel(finalToCol) + finalToRow;

                    return __normalizeA1Text(out);
                }

                function buildLocalCellMap() {
                    const rows = readJsonFromScript('ApprovalCellsJson', []);
                    const built = {
                        approval: { byStep: {}, byRoleKey: {} },
                        cooperation: { byStep: {}, byRoleKey: {} }
                    };

                    if (!Array.isArray(rows)) return built;

                    rows.forEach(function (row) {
                        const resolvedA1 = __buildMappedA1FromRow(row);
                        if (!resolvedA1) return;

                        const bucket = inferStampBucketFromRow(row);
                        const step = row.step || row.Step || row.stepOrder || row.StepOrder || row.slot || row.Slot;
                        const roleKey = String(row.roleKey || row.RoleKey || '').trim();

                        const payload = {
                            row: row,
                            a1: resolvedA1
                        };

                        if (step != null && step !== '') built[bucket].byStep[String(step)] = payload;
                        if (roleKey) built[bucket].byRoleKey[roleKey] = payload;
                    });

                    return built;
                }

                const localMap = buildLocalCellMap();
                const legacyApprovalMap = state.approvalCellMap || { byStep: {}, byRoleKey: {} };
                const legacyCooperationMap = state.cooperationCellMap || { byStep: {}, byRoleKey: {} };

                function __unwrapMappedA1(v) {
                    if (!v) return '';
                    if (typeof v === 'string') return __normalizeA1Text(v);
                    if (typeof v === 'object') {
                        if (v.a1) return __normalizeA1Text(v.a1);
                        return __buildMappedA1FromRow(v.row || v);
                    }
                    return '';
                }

                function resolveMappedA1(raw, step, bucketName) {
                    const roleKey = String(raw.roleKey || raw.RoleKey || '').trim();
                    const bucket = bucketName === 'cooperation' ? 'cooperation' : 'approval';

                    if (roleKey && localMap[bucket].byRoleKey[roleKey]) {
                        return __unwrapMappedA1(localMap[bucket].byRoleKey[roleKey]);
                    }

                    if (localMap[bucket].byStep[String(step)]) {
                        return __unwrapMappedA1(localMap[bucket].byStep[String(step)]);
                    }

                    const legacyBucketMap = bucket === 'cooperation'
                        ? legacyCooperationMap
                        : legacyApprovalMap;

                    if (legacyBucketMap && typeof legacyBucketMap === 'object') {
                        if (roleKey && legacyBucketMap.byRoleKey && legacyBucketMap.byRoleKey[roleKey]) {
                            return __unwrapMappedA1(legacyBucketMap.byRoleKey[roleKey]);
                        }

                        if (legacyBucketMap.byStep && legacyBucketMap.byStep[String(step)]) {
                            return __unwrapMappedA1(legacyBucketMap.byStep[String(step)]);
                        }
                    }

                    if (bucket === 'approval') {
                        const legacyFlat = state.approvalCellMap;
                        if (legacyFlat && typeof legacyFlat === 'object') {
                            if (roleKey && legacyFlat[roleKey]) return __unwrapMappedA1(legacyFlat[roleKey]);
                            if (legacyFlat[String(step)]) return __unwrapMappedA1(legacyFlat[String(step)]);
                            if (legacyFlat[step]) return __unwrapMappedA1(legacyFlat[step]);
                        }
                    }
                    return __buildMappedA1FromRow(raw);
                }

                function getStampLayout(box, kind) {
                    return {
                        x: box.x,
                        y: box.y,
                        w: box.w,
                        h: box.h,
                        placementMode: 'boxed',
                        padX: 0,
                        padTop: kind === 'status' ? 1 : 2,
                        captionHeight: 14,
                        bodyBottomPad: 0,
                        targetWidthRatio: 1,
                        targetHeightRatio: 1,
                        maxWidthRatio: 1,
                        maxHeightRatio: 1,
                        scaleBoost: 1
                    };
                }

                function resolveStampMeta(raw) {
                    const STAMP_BASE = '/images/signatures/';
                    const HOLDING_STAMP = STAMP_BASE + 'Holding.png';
                    const REJECTED_STAMP = STAMP_BASE + 'Rejected.png';
                    const APPROVED_STAMP = STAMP_BASE + 'Approved.png';

                    const actionRaw = String(raw.action || raw.Action || '').trim().toUpperCase();
                    const statusRaw = String(raw.status || raw.Status || '').trim().toUpperCase();
                    const sigPathRaw = String(raw.signaturePath || raw.SignaturePath || '').trim();

                    if (actionRaw === 'APPROVE' || statusRaw === 'APPROVED') {
                        if (sigPathRaw) {
                            return {
                                stampUrl: STAMP_BASE + sigPathRaw.replace(/^[\\/]+/, '').replace(/\\/g, '/'),
                                fallbackUrl: APPROVED_STAMP,
                                kind: 'signature'
                            };
                        }
                        return {
                            stampUrl: APPROVED_STAMP,
                            fallbackUrl: APPROVED_STAMP,
                            kind: 'status'
                        };
                    }

                    if (
                        actionRaw === 'HOLD' ||
                        statusRaw === 'HOLD' ||
                        statusRaw === 'ONHOLD' ||
                        statusRaw.startsWith('PENDINGHOLD')
                    ) {
                        return {
                            stampUrl: HOLDING_STAMP,
                            fallbackUrl: HOLDING_STAMP,
                            kind: 'status'
                        };
                    }

                    if (actionRaw === 'REJECT' || statusRaw === 'REJECTED') {
                        return {
                            stampUrl: REJECTED_STAMP,
                            fallbackUrl: REJECTED_STAMP,
                            kind: 'status'
                        };
                    }

                    if (actionRaw === 'COOPERATE' || statusRaw === 'COOPERATED') {
                        if (sigPathRaw) {
                            return {
                                stampUrl: STAMP_BASE + sigPathRaw.replace(/^[\\/]+/, '').replace(/\\/g, '/'),
                                fallbackUrl: APPROVED_STAMP,
                                kind: 'signature'
                            };
                        }
                        return {
                            stampUrl: APPROVED_STAMP,
                            fallbackUrl: APPROVED_STAMP,
                            kind: 'status'
                        };
                    }

                    return null;
                }

                function appendStamp(raw, step, a1, debugPrefix, bucketName, colRectMap, rowRectMap) {
                    const range = parseA1RangeLocal(a1);
                    if (!range) return;

                    const box = getRangeBox(range, colRectMap, rowRectMap);
                    if (!box || box.w < 8 || box.h < 8) return;

                    const meta = resolveStampMeta(raw);
                    if (!meta || !meta.stampUrl) return;

                    const captionText = formatApprovalCaption(raw);
                    const fit = getStampLayout(box, meta.kind);

                    const div = buildStampDiv(
                        fit.x,
                        fit.y,
                        fit.w,
                        fit.h,
                        meta.stampUrl,
                        captionText,
                        meta.fallbackUrl,
                        {
                            placementMode: fit.placementMode,
                            padX: fit.padX,
                            padTop: fit.padTop,
                            captionHeight: fit.captionHeight,
                            bodyBottomPad: fit.bodyBottomPad,
                            targetWidthRatio: fit.targetWidthRatio,
                            targetHeightRatio: fit.targetHeightRatio,
                            maxWidthRatio: fit.maxWidthRatio,
                            maxHeightRatio: fit.maxHeightRatio,
                            scaleBoost: fit.scaleBoost
                        }
                    );

                    overlay.appendChild(div);

                    window.__dxLog(
                        `[DX] ${debugPrefix} stamp`,
                        'bucket=' + bucketName,
                        'step=' + step,
                        'a1=' + a1,
                        'box=(' + Math.round(box.x) + ',' + Math.round(box.y) + ',' + Math.round(box.w) + ',' + Math.round(box.h) + ')',
                        'placementMode=' + fit.placementMode,
                        'padX=' + fit.padX,
                        'padTop=' + fit.padTop,
                        'captionHeight=' + fit.captionHeight,
                        'bodyBottomPad=' + fit.bodyBottomPad,
                        'scaleBoost=' + fit.scaleBoost
                    );
                }

                const colRectMap = buildColumnRectMap();
                const rowRectMap = buildRowRectMap();

                window.__dxLog(
                    '[DX] measured header maps',
                    'cols=' + Object.keys(colRectMap).length,
                    'rows=' + Object.keys(rowRectMap).length
                );

                overlay.style.position = 'absolute';
                wrap.style.position = 'relative';

                approvals.forEach(function (a, idx) {
                    let step = parseInt(a.step || a.Step || a.stepOrder || a.StepOrder || (idx + 1), 10);
                    if (!step || !isFinite(step)) step = idx + 1;

                    const a1 = resolveMappedA1(a, step, 'approval');
                    if (!a1) return;

                    appendStamp(a, step, a1, 'approval', 'approval', colRectMap, rowRectMap);
                });

                cooperations.forEach(function (c, idx) {
                    let step = parseInt(c.step || c.Step || c.stepOrder || c.StepOrder || c.slot || c.Slot || (idx + 1), 10);
                    if (!step || !isFinite(step)) step = idx + 1;

                    const a1 = resolveMappedA1(c, step, 'cooperation');
                    window.__dxLog('[DX] cooperation mapped a1', {
                        step: step,
                        roleKey: String(c.roleKey || c.RoleKey || ''),
                        a1: a1,
                        source: state.cooperationCellMap
                    });

                    if (!a1) return;

                    appendStamp(c, step, a1, 'cooperation', 'cooperation', colRectMap, rowRectMap);
                });
            } finally {
                state.overlayRendering = false;
            }
        }

        // ================== 파일 헬퍼 ==================
        function normalizeCommentFiles(c) {
            if (!c) return [];
            const a = c.attachments || c.Attachments || c.files || c.Files ||
                c.fileItems || c.FileItems || c.items || c.Items || null;
            return Array.isArray(a) ? a : [];
        }

        function normalizeFileItem(f) {
            if (!f) return null;
            const fileKey = (f.fileKey || f.FileKey || f.key || f.Key || '').toString().trim();
            if (!fileKey) return null;
            const originalName = (f.originalName || f.OriginalName || f.name || f.Name || fileKey).toString();
            const byteSize = Number(f.byteSize || f.ByteSize || f.size || f.Size || 0) || 0;
            return { fileKey, originalName, byteSize, url: '/Doc/Download/' + encodeURIComponent(fileKey) };
        }

        function renderFilesHtml(c) {
            const files = normalizeCommentFiles(c).map(normalizeFileItem).filter(Boolean);
            if (!files.length) return '';
            const lis = files.map(f => {
                const sizeText = f.byteSize ? ` (${Number(f.byteSize).toLocaleString()} B)` : '';
                return `<li><a href="${escapeHtml(f.url)}" target="_blank" rel="noopener">${escapeHtml(f.originalName)}</a><span class="text-muted">${escapeHtml(sizeText)}</span></li>`;
            }).join('');
            return `<div class="doc-comment-files"><ul class="mb-0 ps-3">${lis}</ul></div>`;
        }

        function escapeHtml(s) {
            return String(s || '').replace(/[&<>"']/g,
                m => ({ '&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;', "'": '&#39;' }[m]));
        }

        function nl2br(s) {
            return String(s || '').replace(/\n/g, '<br>');
        }

        function cancelOverlayRefresh() {
            if (state.overlayRefreshTimer) {
                clearTimeout(state.overlayRefreshTimer);
                state.overlayRefreshTimer = 0;
            }
            if (state.overlayRefreshRaf) {
                cancelAnimationFrame(state.overlayRefreshRaf);
                state.overlayRefreshRaf = 0;
            }
        }

        function renderApprovalOverlayStable(reason, pass) {
            const currentPass = Number(pass || 0);

            state.overlayRefreshRaf = requestAnimationFrame(function () {
                requestAnimationFrame(function () {
                    try { renderApprovalOverlay(); } catch (e) { window.__dxWarn('[DX] renderApprovalOverlayStable failed', e); }

                    if (currentPass < 1) {
                        state.overlayRefreshTimer = window.setTimeout(function () {
                            renderApprovalOverlayStable(reason, currentPass + 1);
                        }, 200);
                    } else {
                        const scroll = document.getElementById('doc-scroll');
                        if (scroll) scroll.classList.add('dx-page-ready');
                    }
                });
            });
        }

        function scheduleOverlayRefresh(reason) {
            cancelOverlayRefresh();
            renderApprovalOverlayStable(reason || 'overlay-refresh', 0);
        }

        function bindOverlayResizeObserver() {
            if (state.overlayResizeObserver || typeof ResizeObserver === 'undefined') return;

            const wrap = document.getElementById('dxDetailWrap');
            if (!wrap) return;

            let debounceTimer = 0;

            state.overlayResizeObserver = new ResizeObserver(function () {
                if (!state.overlayReady) return;

                clearTimeout(debounceTimer);
                debounceTimer = setTimeout(function () {
                    window.__dxLog('[DX] overlay resize observer refresh');
                    try { renderApprovalOverlay(); } catch (e) { window.__dxWarn('[DX] overlay resize observer failed', e); }
                }, 500);
            });

            try { state.overlayResizeObserver.observe(wrap); } catch (e) { }
        }

        // ================== 수신자 ==================
        function collectSelectedRecipientUserIds_Detail() {
            function uniq(list) {
                const seen = new Set(); const out = [];
                for (const raw of (list || [])) {
                    const s = String(raw || '').trim(); if (!s) continue;
                    const k = s.toLowerCase(); if (seen.has(k)) continue;
                    seen.add(k); out.push(s);
                }
                return out;
            }
            function parseRaw(raw) {
                raw = String(raw || '').trim(); if (!raw) return [];
                if (raw.startsWith('[')) {
                    try {
                        const arr = JSON.parse(raw);
                        if (Array.isArray(arr)) return uniq(arr.map(x => String(x || '').trim()).filter(Boolean));
                    } catch { }
                }
                return uniq(raw.split(/[,\s;]+/g).map(s => (s || '').trim()).filter(Boolean));
            }
            const root = document.getElementById('doc-recipient-select-detail');
            if (root) {
                const one = root.querySelector('input[name="SelectedRecipientUserIds"]')?.value ||
                    root.querySelector('textarea[name="SelectedRecipientUserIds"]')?.value || '';
                const parsedOne = parseRaw(one);
                if (parsedOne.length) return parsedOne;
                const ds = root.getAttribute('data-selected') || (root.dataset ? root.dataset.selected : '') || '';
                const parsedDs = parseRaw(ds);
                if (parsedDs.length) return parsedDs;
            }
            return [];
        }

        function initRecipientsFromSelected() {
            if (!Array.isArray(selectedIds) || selectedIds.length === 0) return;
            let tries = 0;
            const timer = setInterval(function () {
                tries++;
                const root = document.getElementById('doc-recipient-select-detail');
                if (!root) { if (tries >= 60) clearInterval(timer); return; }
                const anyCb = root.querySelector('.org-ms-checkbox[data-node-type="User"]');
                if (!anyCb) { if (tries >= 60) clearInterval(timer); return; }
                clearInterval(timer);
                const joined = selectedIds.join(',');
                const hidden = root.querySelector('[data-role="org-ms-value"]');
                if (hidden) hidden.value = joined;
                const nameField = root.querySelector('input[name="SelectedRecipientUserIds"], textarea[name="SelectedRecipientUserIds"]');
                if (nameField) nameField.value = joined;
                selectedIds.forEach(function (id) {
                    const cb = root.querySelector('.org-ms-checkbox[data-node-type="User"][data-node-id="' + id + '"]');
                    if (!cb) return;
                    cb.checked = true;
                    cb.dispatchEvent(new Event('change', { bubbles: true }));
                });
                root.dispatchEvent(new Event('change', { bubbles: true }));
            }, 50);
        }

        function initRecipientsChangeButton() {
            const btn = document.getElementById('btnRecipientsChange');
            if (!btn) return;
            btn.addEventListener('click', async function () {
                const ids = collectSelectedRecipientUserIds_Detail() || [];
                if (!docId) return;
                const EBC = window.EBCSRF || window.EBCsrf;
                if (!EBC || typeof EBC.json !== 'function') return;
                try {
                    const res = await EBC.json('/Doc/UpdateShares', { docId, selectedRecipientUserIds: ids }, 'POST');
                    if (!res || res.ok === false) throw { payload: res };
                    location.reload();
                } catch {
                    showAlert(T('DOC_Err_SaveFailed'), 'alert-danger');
                }
            });
        }

        // ================== 이미지 오버레이 ==================
        function initDocFileImageOverlay() {
            const overlay = document.getElementById('ebImgOverlay');
            const overlayImg = document.getElementById('ebImgOverlayImg');
            if (!overlay || !overlayImg) return;
            function closeOverlay() {
                overlay.classList.remove('is-open');
                overlay.setAttribute('aria-hidden', 'true');
                overlayImg.src = '';
            }
            function openOverlay(src) {
                if (!src) return;
                overlayImg.src = src;
                overlay.classList.add('is-open');
                overlay.setAttribute('aria-hidden', 'false');
            }
            document.addEventListener('click', function (ev) {
                const t = ev && ev.target;
                if (!t) return;
                if (t.classList && t.classList.contains('doc-attach-thumb')) {
                    ev.preventDefault();
                    openOverlay(t.getAttribute('data-fullsrc') || t.getAttribute('src') || '');
                    return;
                }
                if (t === overlay || t === overlayImg) { ev.preventDefault(); closeOverlay(); }
            }, true);
            document.addEventListener('keydown', function (ev) {
                if (ev.key === 'Escape' && overlay.classList.contains('is-open')) { ev.preventDefault(); closeOverlay(); }
            });
        }

        // ================== 조회 로그 ==================
        function renderViewLogs() {
            const host = document.getElementById('viewlog-list');
            if (!host) return;
            let logs = readJsonFromScript('ViewLogsJson', []);
            if (!Array.isArray(logs)) logs = [];
            if (!logs.length) { host.innerHTML = `<div class="text-muted">${T('DOC_Msg_NoViewLogs')}</div>`; return; }
            logs.sort((a, b) => (a.viewedAt || '').localeCompare(b.viewedAt || ''));
            const seen = new Set(); const rows = [];
            logs.forEach(v => {
                const key = v.userId || v.userName || '';
                if (!key || seen.has(key)) return;
                seen.add(key); rows.push(v);
            });
            host.innerHTML = '';
            rows.forEach(v => {
                const row = document.createElement('div');
                row.textContent = `${v.viewedAtText || v.viewedAt || ''} - ${v.userName || v.userId || ''}`;
                host.append(row);
            });
        }

        // ================== 승인 테이블 ==================
        function getActionedWhenText(row) {
            return String(
                row?.actedAtText || row?.ActedAtText ||
                row?.approvalTimeText || row?.ApprovalTimeText ||
                row?.approvedAtText || row?.ApprovedAtText ||
                row?.actionTimeText || row?.ActionTimeText ||
                row?.actedAt || row?.ActedAt ||
                row?.approvalTime || row?.ApprovalTime ||
                row?.approvedAt || row?.ApprovedAt ||
                row?.actionTime || row?.ActionTime ||
                ''
            ).trim();
        }

        function formatRes(key) {
            const fmt = T(key);
            const args = Array.prototype.slice.call(arguments, 1);
            return String(fmt || '').replace(/\{(\d+)\}/g, function (_, idx) {
                const i = parseInt(idx, 10);
                return (i >= 0 && i < args.length) ? String(args[i] ?? '') : _;
            });
        }

        function getStepNo(row) {
            const raw = row?.step ?? row?.stepOrder ?? row?.Step ?? row?.StepOrder ?? row?.slot ?? row?.Slot ?? '';
            const n = Number(raw);
            return Number.isFinite(n) && n > 0 ? n : 0;
        }

        function getRoleKeyText(row) {
            return String(row?.roleKey || row?.RoleKey || '').trim().toUpperCase();
        }

        function getRoleKeySortNo(row) {
            const rk = getRoleKeyText(row);
            const m = rk.match(/(\d+)/);
            if (m) return parseInt(m[1], 10);
            return Number.MAX_SAFE_INTEGER;
        }

        function renderApprovalsTable() {
            const tbody = document.getElementById('tbody-approvals');
            if (!tbody) return;

            let rows = readJsonFromScript('ApprovalTableRowsJson', []);
            if (!Array.isArray(rows)) rows = [];

            const approvals = Array.isArray(state.approvalsData) ? state.approvalsData.slice() : [];
            const cooperations = Array.isArray(state.cooperationsData) ? state.cooperationsData.slice() : [];

            approvals.sort((a, b) => getStepNo(a) - getStepNo(b));
            cooperations.sort((a, b) => {
                const aa = getRoleKeySortNo(a);
                const bb = getRoleKeySortNo(b);
                if (aa !== bb) return aa - bb;
                return getRoleKeyText(a).localeCompare(getRoleKeyText(b));
            });

            const root = document.getElementById('doc-scroll');
            const isDocRecalled = String(root?.getAttribute('data-status') || '').toUpperCase() === 'RECALLED';
            const creatorName = String(root?.getAttribute('data-creator-name') || '').trim();
            const createdAt = String(root?.getAttribute('data-created-at') || '').trim();
            const recalledAt = String(root?.getAttribute('data-recalled-at') || '').trim();

            function buildFallbackRows() {
                const list = [];
                list.push({
                    rowType: 'drafter',
                    displayName: creatorName,
                    roleText: T('DOC_Role_Submit'),
                    status: isDocRecalled ? 'Recalled' : 'Created',
                    actedAtText: isDocRecalled ? recalledAt : createdAt
                });

                approvals.forEach(function (a) {
                    const stepNo = getStepNo(a);
                    list.push({
                        rowType: 'approval',
                        roleKey: a?.roleKey || a?.RoleKey || '',
                        displayName: getApprovalDisplayName(a),
                        roleText: stepNo > 0 ? formatRes('DOC_Role_ApprovalFmt', stepNo) : '',
                        status: String(a?.status || a?.Status || a?.action || a?.Action || 'Pending'),
                        actedAtText: getActionedWhenText(a)
                    });
                });

                cooperations.forEach(function (c) {
                    list.push({
                        rowType: 'cooperation',
                        roleKey: c?.roleKey || c?.RoleKey || '',
                        displayName: getApprovalDisplayName(c),
                        roleText: T('DOC_Role_Cooperation'),
                        status: String(c?.status || c?.Status || c?.action || c?.Action || 'Pending'),
                        actedAtText: getActionedWhenText(c)
                    });
                });

                return list;
            }

            if (!rows.length) rows = buildFallbackRows();

            tbody.innerHTML = '';

            rows.forEach(function (row) {
                const rowType = String(row?.rowType || row?.RowType || '').toLowerCase();
                const rowRoleKey = getRoleKeyText(row);
                const rowSortOrder = Number(row?.sortOrder || row?.SortOrder || 0);

                let rawDisplayName = String(row?.displayName || row?.DisplayName || '').trim();
                const rawRoleText = String(row?.roleText || row?.RoleText || '').trim();
                let rawStatus = String(row?.status || row?.Status || '').trim();
                let rawWhen = String(row?.actedAtText || row?.ActedAtText || '').trim();

                if (!rawDisplayName) {
                    if (rowType === 'drafter') {
                        rawDisplayName = creatorName;
                    } else if (rowType === 'approval') {
                        const matchedApproval = approvals.find(function (a) {
                            const aRoleKey = getRoleKeyText(a);
                            const aStep = getStepNo(a);
                            if (rowRoleKey && aRoleKey) return rowRoleKey === aRoleKey;
                            if (rowSortOrder > 0 && aStep > 0) return rowSortOrder === aStep;
                            return false;
                        });
                        rawDisplayName = getApprovalDisplayName(matchedApproval);
                    } else if (rowType === 'cooperation') {
                        const matchedCooperation = cooperations.find(function (c) {
                            const cRoleKey = getRoleKeyText(c);
                            if (rowRoleKey && cRoleKey) return rowRoleKey === cRoleKey;
                            return false;
                        });
                        rawDisplayName = getApprovalDisplayName(matchedCooperation);
                    }
                }

                if (isDocRecalled && rowType !== 'drafter') {
                    rawStatus = 'Pending';
                    rawWhen = '';
                }

                const statusText = T(mapStatusKey(rawStatus)) || rawStatus;

                const tr = document.createElement('tr');
                tr.innerHTML = `
                    <td>${escapeHtml(rawDisplayName || '')}</td>
                    <td>${escapeHtml(rawRoleText || '')}</td>
                    <td>${escapeHtml(statusText || '')}</td>
                    <td>${escapeHtml(rawWhen || '')}</td>
                `;
                tbody.appendChild(tr);
            });
        }

        // ================== 댓글 ==================
        function initComments() {
            const rawFetch = (window.fetch || function () { }).bind(window);
            const EBC = (window.EBCSRF || window.EBCsrf) || {
                async fetch(url, options) { return await rawFetch(url, options || {}); },
                async json(url, payload, method = 'POST') {
                    const res = await rawFetch(url, {
                        method,
                        headers: { 'Content-Type': 'application/json', 'Accept': 'application/json' },
                        body: method === 'GET' ? undefined : JSON.stringify(payload || {})
                    });
                    const j = await res.json().catch(() => ({}));
                    if (!res.ok) { const err = new Error('request failed'); err.payload = j; throw err; }
                    return j;
                }
            };
            const $list = document.getElementById('cmt-list');
            const $alert = document.getElementById('cmt-alert');
            const $count = document.getElementById('cmt-count');
            const $body = document.getElementById('cmt-body');
            const $submit = document.getElementById('cmt-submit');
            const COMMENT_DEPTH_INDENT = 40;
            let activeReply = null;

            if (!docId) {
                $alert.innerHTML = `<div class="alert alert-danger py-1 mb-1">${T('DOC_Err_DocumentNotFound')}</div>`;
                return;
            }
            function showErr(msgs) {
                $alert.innerHTML = `<div class="alert alert-danger py-1 mb-1">${(msgs || []).map(escapeHtml).join('<br>')}</div>`;
            }
            async function loadComments() {
                try {
                    const res = await EBC.fetch('/Doc/Comments?docId=' + encodeURIComponent(docId), { method: 'GET', headers: { 'Accept': 'application/json' } });
                    const data = await res.json().catch(() => ({}));
                    renderComments(Array.isArray(data.items) ? data.items : []);
                } catch (e) { console.error('loadComments error', e); showErr([T('DOC_Err_LoadFailed')]); }
            }
            function renderComments(items) {
                $list.innerHTML = ''; activeReply = null;
                if (!items.length) { $count.textContent = ''; $list.innerHTML = `<div class="text-muted">${T('DOC_Msg_NoComments')}</div>`; return; }
                $count.textContent = T('DOC_Cmt_Count').replace('{n}', items.length);
                items.forEach(c => {
                    const wrap = document.createElement('div');
                    wrap.className = 'doc-comment-item';
                    const depthRaw = (typeof c.depth === 'number') ? c.depth : parseInt(c.depth || '0', 10) || 0;
                    wrap.style.marginLeft = (Math.max(0, Math.min(depthRaw, 4)) * COMMENT_DEPTH_INDENT) + 'px';
                    const cid = c.id || c.commentId || c.CommentId;
                    if (cid != null) wrap.dataset.commentId = String(cid);
                    let actionsHtml = '';
                    if (cid != null) {
                        const btns = [];
                        btns.push(`<button type="button" class="btn btn-link btn-sm p-0" data-reply-id="${String(cid)}">${escapeHtml(T('DOC_Btn_Reply'))}</button>`);
                        if (!!c.canEdit) btns.push(`<button type="button" class="btn btn-link btn-sm p-0 ms-2" data-edit-id="${String(cid)}">${escapeHtml(T('_CM_Edit'))}</button>`);
                        if (!!c.canDelete) btns.push(`<button type="button" class="btn btn-link btn-sm p-0 ms-2 text-danger" data-delete-id="${String(cid)}">${escapeHtml(T('_CM_Delete'))}</button>`);
                        actionsHtml = `<span class="ms-auto">${btns.join(' ')}</span>`;
                    }
                    wrap.innerHTML = `
                        <div class="doc-comment-meta d-flex align-items-center">
                            <span><strong>${escapeHtml(c.createdBy || '')}</strong></span>
                            <span class="ms-2">${escapeHtml(c.createdAt || '')}</span>
                            ${actionsHtml}
                        </div>
                        <div class="doc-comment-body">${nl2br(escapeHtml(c.body || ''))}</div>
                        ${renderFilesHtml(c)}`;
                    $list.append(wrap);
                });
            }
            $submit?.addEventListener('click', async () => {
                const body = ($body.value || '').trim();
                if (!body) { showErr([T('DOC_Val_Required')]); return; }
                try {
                    await EBC.json('/Doc/Comments', { docId, parentCommentId: null, body, files: [] }, 'POST');
                    $body.value = '';
                    await loadComments();
                } catch (e) { const p = e && e.payload; showErr(p?.messages || [T('DOC_Err_SaveFailed')]); }
            });
            $list.addEventListener('click', async (e) => {
                const replyBtn = e.target.closest('button[data-reply-id]');
                const editBtn = e.target.closest('button[data-edit-id]');
                const deleteBtn = e.target.closest('button[data-delete-id]');
                if (replyBtn) { toggleReplyForm(replyBtn.getAttribute('data-reply-id'), replyBtn.closest('.doc-comment-item')); return; }
                if (editBtn) { toggleEditForm(editBtn.getAttribute('data-edit-id'), editBtn.closest('.doc-comment-item')); return; }
                if (deleteBtn) {
                    const cid = deleteBtn.getAttribute('data-delete-id');
                    if (!cid || !confirm(T('DOC_Confirm_DeleteComment') || '삭제하시겠습니까?')) return;
                    try {
                        const res = await EBC.fetch(`/Doc/Comments/${encodeURIComponent(cid)}?docId=${encodeURIComponent(docId)}`, { method: 'DELETE', headers: { 'Accept': 'application/json' } });
                        const j = await res.json().catch(() => ({}));
                        if (!res.ok || j.ok === false) throw { payload: j };
                        await loadComments();
                    } catch (err) { const p = err && err.payload; showErr(p?.messages || [T('DOC_Err_DeleteFailed')]); }
                    return;
                }
                const submitBtn = e.target.closest('button[data-reply-submit]');
                if (submitBtn) {
                    const form = submitBtn.closest('.doc-comment-reply');
                    if (!form || !activeReply?.parentId) return;
                    const textarea = form.querySelector('textarea');
                    const body = (textarea?.value || '').trim();
                    if (!body) { showErr([T('DOC_Val_Required')]); return; }
                    try {
                        await EBC.json('/Doc/Comments', { docId, parentCommentId: activeReply.parentId, body, files: [] }, 'POST');
                        if (textarea) textarea.value = '';
                        removeReplyForm();
                        await loadComments();
                    } catch (err) { const p = err && err.payload; showErr(p?.messages || [T('DOC_Err_SaveFailed')]); }
                    return;
                }
                const cancelBtn = e.target.closest('button[data-reply-cancel]');
                if (cancelBtn) removeReplyForm();
            });
            function toggleReplyForm(parentId, itemEl) {
                if (!parentId || !itemEl) return;
                if (activeReply && activeReply.parentId === parentId) { removeReplyForm(); return; }
                removeReplyForm();
                const form = document.createElement('div');
                form.className = 'doc-comment-reply mt-2';
                const parentIndent = parseInt(window.getComputedStyle(itemEl).marginLeft || '0', 10) || 0;
                form.style.marginLeft = (parentIndent + COMMENT_DEPTH_INDENT / 2) + 'px';
                form.innerHTML = `
                    <textarea class="form-control form-control-sm mb-1" rows="2" placeholder="${escapeHtml(T('DOC_Placeholder_Reply'))}"></textarea>
                    <div class="d-flex gap-2 justify-content-end">
                        <button type="button" class="btn btn-sm btn-primary" data-reply-submit>${escapeHtml(T('DOC_Btn_ReplyPost'))}</button>
                        <button type="button" class="btn btn-sm btn-outline-secondary" data-reply-cancel>${escapeHtml(T('DOC_Btn_Cancel'))}</button>
                    </div>`;
                itemEl.append(form);
                activeReply = { parentId, form };
            }
            function removeReplyForm() {
                if (activeReply?.form?.parentNode) activeReply.form.parentNode.removeChild(activeReply.form);
                activeReply = null;
            }
            function toggleEditForm(commentId, itemEl) {
                if (!commentId || !itemEl) return;
                const existing = itemEl.querySelector('.doc-comment-edit');
                if (existing) { existing.remove(); return; }
                const originalText = itemEl.querySelector('.doc-comment-body')?.textContent || '';
                const form = document.createElement('div');
                form.className = 'doc-comment-edit mt-1';
                form.innerHTML = `
                    <textarea class="form-control form-control-sm mb-1" rows="2">${escapeHtml(originalText)}</textarea>
                    <div class="d-flex gap-2 justify-content-end">
                        <button type="button" class="btn btn-sm btn-primary" data-edit-submit="${commentId}">${escapeHtml(T('_CM_Edit'))}</button>
                        <button type="button" class="btn btn-sm btn-outline-secondary" data-edit-cancel>${escapeHtml(T('DOC_Btn_Cancel'))}</button>
                    </div>`;
                itemEl.append(form);
                form.addEventListener('click', async (e) => {
                    const submit = e.target.closest('button[data-edit-submit]');
                    const cancel = e.target.closest('button[data-edit-cancel]');
                    if (cancel) { form.remove(); return; }
                    if (submit) {
                        const tid = submit.getAttribute('data-edit-submit');
                        const textarea = form.querySelector('textarea');
                        const body = (textarea?.value || '').trim();
                        if (!body) { showErr([T('DOC_Val_Required')]); return; }
                        try {
                            await EBC.json(`/Doc/Comments/${encodeURIComponent(tid)}`, { docId, body }, 'PUT');
                            await loadComments();
                        } catch (err) { const p = err && err.payload; showErr(p?.messages || [T('DOC_Err_SaveFailed')]); }
                    }
                }, { once: true });
            }
            loadComments();
        }

        // ================== 승인 버튼 ==================
        function initApproveButtons() {
            const EBC = window.EBCSRF || window.EBCsrf || {};
            if (!docId) return;
            async function call(action) {
                try {
                    const res = await EBC.json('/Doc/ApproveOrHoldDX', { docId, action }, 'POST');
                    if (!res || res.ok === false) throw { payload: res };
                    showAlert(T('DOC_Msg_Approve_Success'), 'alert-success');
                    location.reload();
                } catch (e) {
                    const p = e && e.payload;
                    showAlert((p?.messages || [T('DOC_Err_SaveFailed')]).join('<br>'), 'alert-danger');
                }
            }
            document.querySelectorAll('[data-approve]').forEach(btn => btn.addEventListener('click', () => { if (!btn.disabled) call('Approve'); }));
            document.querySelectorAll('[data-hold]').forEach(btn => btn.addEventListener('click', () => { if (!btn.disabled) call('Hold'); }));
            document.querySelectorAll('[data-reject]').forEach(btn => btn.addEventListener('click', () => { if (!btn.disabled) call('Reject'); }));
            document.querySelectorAll('[data-cooperate]').forEach(btn => btn.addEventListener('click', () => { if (!btn.disabled) call('Cooperate'); }));
            document.querySelectorAll('[data-cooperate-reject]').forEach(btn => btn.addEventListener('click', () => { if (!btn.disabled) call('CooperateReject'); }));
        }

        // ================== 회수 버튼 ==================
        function initRecallButton() {
            const EBC = window.EBCSRF || window.EBCsrf || {};
            const btnRecall = document.getElementById('btnRecall');
            if (!btnRecall || !docId) return;
            btnRecall.addEventListener('click', async () => {
                if (btnRecall.disabled) return;
                try {
                    const res = await EBC.json('/Doc/ApproveOrHoldDX', { docId, action: 'Recall' }, 'POST');
                    if (!res || res.ok === false) throw { payload: res };
                    showAlert(T('DOC_Msg_Recall_Success') || T('DOC_Msg_Approve_Success'), 'alert-success');
                    location.href = '/Doc/Board';
                } catch (e) {
                    const p = e && e.payload;
                    showAlert((p?.messages || [T('DOC_Err_RequestFailed')]).join('<br>'), 'alert-danger');
                }
            });
        }

        // ================== 인쇄 & PDF 내보내기 ==================
        function initPrintExport() {
            const btnPrint = document.getElementById('btnPrint');
            if (btnPrint) {
                btnPrint.addEventListener('click', function () {
                    const inst = getDxInstance();
                    if (inst) {
                        if (typeof inst.print === 'function') { try { inst.print(); return; } catch (e) { } }
                        if (typeof inst.ExecuteGesture === 'function') { try { inst.ExecuteGesture('Print'); return; } catch (e) { } }
                    }
                    window.print();
                });
            }
            const btnExport = document.getElementById('btnExport');
            if (btnExport) {
                btnExport.addEventListener('click', async function () {
                    btnExport.disabled = true;
                    btnExport.classList.add('btn-loading');
                    const origHtml = btnExport.innerHTML;
                    btnExport.innerHTML = '<span class="spinner-border spinner-border-sm" role="status" aria-hidden="true"></span>';
                    function restoreBtn() { btnExport.disabled = false; btnExport.classList.remove('btn-loading'); btnExport.innerHTML = origHtml; }
                    function loadScript(url) {
                        return new Promise(function (resolve, reject) {
                            if (url.includes('html2canvas') && typeof window.html2canvas === 'function') { resolve(); return; }
                            if (url.includes('jspdf') && window.jspdf?.jsPDF) { resolve(); return; }
                            var s = document.createElement('script');
                            s.src = url; s.crossOrigin = 'anonymous';
                            s.onload = resolve;
                            s.onerror = () => reject(new Error('스크립트 로드 실패: ' + url));
                            document.head.appendChild(s);
                        });
                    }
                    try {
                        if (typeof window.html2canvas !== 'function')
                            await loadScript('https://cdnjs.cloudflare.com/ajax/libs/html2canvas/1.4.1/html2canvas.min.js');
                        if (!window.jspdf?.jsPDF)
                            await loadScript('https://cdnjs.cloudflare.com/ajax/libs/jspdf/2.5.1/jspdf.umd.min.js');
                        if (typeof window.html2canvas !== 'function') throw new Error('html2canvas 로드 실패');
                        if (!window.jspdf?.jsPDF) throw new Error('jsPDF 로드 실패');

                        const JsPDF = window.jspdf.jsPDF;
                        const target = document.getElementById('dxDetailWrap');
                        if (!target) throw new Error('캡처 대상 요소를 찾을 수 없습니다.');

                        const canvas = await window.html2canvas(target, {
                            scale: 2, useCORS: true, allowTaint: false,
                            backgroundColor: '#ffffff', logging: false,
                            width: target.offsetWidth, height: target.offsetHeight,
                            scrollX: 0, scrollY: 0
                        });

                        const imgData = canvas.toDataURL('image/jpeg', 0.92);
                        const A4_W = 210;
                        const pdfH = (canvas.height / canvas.width) * A4_W;
                        const pdf = new JsPDF({ orientation: 'portrait', unit: 'mm', format: [A4_W, Math.max(pdfH, 297)] });
                        pdf.addImage(imgData, 'JPEG', 0, 0, A4_W, pdfH);
                        const root = document.getElementById('doc-scroll');
                        const titleAttr = (root?.getAttribute('data-doc-title') || '').trim();
                        pdf.save((titleAttr || docId || 'document') + '.pdf');
                    } catch (err) {
                        console.error('[PDF Export] 오류:', err);
                        showAlert('PDF 변환 중 오류가 발생했습니다: ' + (err.message || String(err)), 'alert-danger');
                    } finally { restoreBtn(); }
                });
            }
        }

        function hookDxReady() {
            installOuterScrollOnly();

            function applySize() {
                applyDxWrapSize();

                const scroll = document.getElementById('doc-scroll');
                if (scroll) scroll.classList.add('dx-page-ready');
            }

            const wrap = document.getElementById('dxDetailWrap');
            if (!wrap) return;

            let applied = false;
            function tryApply() {
                if (applied) return;
                const wbc = document.getElementById('dxDetailSheet_WBC')
                         || document.querySelector('#dxDetailWrap [id$="_WBC"]');
                if (wbc && wbc.offsetWidth > 0 && wbc.offsetHeight > 0) {
                    applied = true;
                    observer.disconnect();
                    applySize();
                }
            }

            // 2026.06.19 Changed: DetailDX 엑셀 렌더링 완료 판단을 ComposeDX와 동일한 WBC 감지 방식으로 단순화
            const observer = new MutationObserver(function () {
                tryApply();
            });

            observer.observe(wrap, { childList: true, subtree: true, attributes: true });
            tryApply();
        }

        function run() {
            clearAlert();

            state.preview = readJsonFromScript('PreviewJson', {}) || {};
            state.descriptor = readJsonFromScript('DescriptorJson', {}) || {};

            state.approvalsData = Array.isArray(readJsonFromScript('ApprovalsJson', []))
                ? readJsonFromScript('ApprovalsJson', [])
                : [];

            state.cooperationsData = Array.isArray(readJsonFromScript('CooperationsJson', []))
                ? readJsonFromScript('CooperationsJson', [])
                : [];

            const mapRows = readJsonFromScript('ApprovalCellsJson', []);
            const builtMap = buildLegacyApprovalCellMap(Array.isArray(mapRows) ? mapRows : []);

            state.approvalCellMap = builtMap.approval || { byStep: {}, byRoleKey: {} };
            state.cooperationCellMap = builtMap.cooperation || { byStep: {}, byRoleKey: {} };

            window.__dxLog('approvalCellMap', state.approvalCellMap, mapRows);
            window.__dxLog('cooperationCellMap', state.cooperationCellMap, mapRows);

            applyDxWrapSize();

            renderViewLogs();
            renderApprovalsTable();
            initRecipientsFromSelected();
            initRecipientsChangeButton();
            initDocFileImageOverlay();
            initComments();
            initApproveButtons();
            initRecallButton();
            initPrintExport();
            hookDxReady();
        }

        if (document.readyState === 'loading') {
            document.addEventListener('DOMContentLoaded', run);
        } else {
            run();
        }
    })();
    </script>
}
