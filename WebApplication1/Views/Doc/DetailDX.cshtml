            const layoutWidth = Number(window.__dxLayoutWidthPx || 0);
            const layoutHeight = Number(window.__dxLayoutHeightPx || 0);
            const padW = Number(window.__dxRenderPadWidthPx || 0);
            const padH = Number(window.__dxRenderPadHeightPx || 0);

            const width = layoutWidth > 0
