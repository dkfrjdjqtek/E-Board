</div>

@section Scripts {
    <script src="~/js/eb.csrf.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/html2canvas/1.4.1/html2canvas.min.js"
            crossorigin="anonymous" referrerpolicy="no-referrer"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jspdf/2.5.1/jspdf.umd.min.js"
            crossorigin="anonymous" referrerpolicy="no-referrer"></script>
    <script>
    (function () {
        'use strict';

        window.__ORG_MS_INITIAL_SELECTED = @Html.Raw(ViewBag.SelectedRecipientUserIdsJson ?? "[]");
        var selectedIds = @Html.Raw(ViewBag.SelectedRecipientUserIdsJson ?? "[]");

        const $ = (q, r = document) => r.querySelector(q);
        const docId = "@(docId ?? "")";
        const compCd = "@(compCd ?? "")";

        let detailDxStampTempCleanupSent = false;

        function getRequestVerificationToken() {
            const el = document.querySelector('input[name="__RequestVerificationToken"]');
            return el ? String(el.value || '') : '';
        }

        // 2026.06.23 Changed: DetailDX 임시파일 정리 요청 트리거를 보강 Contents 링크 이동 및 폼 제출 시에도 DocDXStamp 작업 파일 삭제 요청을 보낸다
        function cleanupDetailDxStampTemp(reason) {
            if (detailDxStampTempCleanupSent) return;

            const stampWorkPath = String(window.__dxStampWorkPath || '').trim();
            if (!docId || !stampWorkPath) return;

            detailDxStampTempCleanupSent = true;

            const token = getRequestVerificationToken();
            const payload = {
                docId: docId,
                stampWorkPath: stampWorkPath,
                dxDocumentId: String(window.__dxDocumentId || ''),
                reason: String(reason || '')
            };

            try {
                fetch('/Doc/CleanupDetailDxStampTemp', {
                    method: 'POST',
                    keepalive: true,
                    credentials: 'same-origin',
                    headers: {
                        'Content-Type': 'application/json',
                        'Accept': 'application/json',
                        'RequestVerificationToken': token
                    },
                    body: JSON.stringify(payload)
                }).catch(function () { });
            } catch (e) {
            }
        }

