        // ================== 인쇄 & PDF 내보내기 ==================
        function initPrintExport() {
            const btnPrint = document.getElementById('btnPrint');
            if (btnPrint) {
                btnPrint.addEventListener('click', function () {
                    const inst = getDxInstance();
                    if (inst) {
                        if (typeof inst.print === 'function') { try { inst.print(); return; } catch (e) { } }
                        if (typeof inst.ExecuteGesture === 'function') { try { inst.ExecuteGesture('Print'); return; } catch (e) { } }
                    }
                    window.print();
                });
            }
            const btnExport = document.getElementById('btnExport');
            if (btnExport) {
                btnExport.addEventListener('click', async function () {
                    btnExport.disabled = true;
                    btnExport.classList.add('btn-loading');
                    const origHtml = btnExport.innerHTML;
                    btnExport.innerHTML = '<span class="spinner-border spinner-border-sm" role="status" aria-hidden="true"></span>';
                    function restoreBtn() { btnExport.disabled = false; btnExport.classList.remove('btn-loading'); btnExport.innerHTML = origHtml; }
                    function loadScript(url) {
                        return new Promise(function (resolve, reject) {
                            if (url.includes('html2canvas') && typeof window.html2canvas === 'function') { resolve(); return; }
                            if (url.includes('jspdf') && window.jspdf?.jsPDF) { resolve(); return; }
                            var s = document.createElement('script');
                            s.src = url; s.crossOrigin = 'anonymous';
                            s.onload = resolve;
                            s.onerror = () => reject(new Error('스크립트 로드 실패: ' + url));
                            document.head.appendChild(s);
                        });
                    }
                    try {
                        if (typeof window.html2canvas !== 'function')
                            await loadScript('https://cdnjs.cloudflare.com/ajax/libs/html2canvas/1.4.1/html2canvas.min.js');
                        if (!window.jspdf?.jsPDF)
                            await loadScript('https://cdnjs.cloudflare.com/ajax/libs/jspdf/2.5.1/jspdf.umd.min.js');
                        if (typeof window.html2canvas !== 'function') throw new Error('html2canvas 로드 실패');
                        if (!window.jspdf?.jsPDF) throw new Error('jsPDF 로드 실패');

                        const JsPDF = window.jspdf.jsPDF;
                        const target = document.getElementById('dxDetailWrap');
                        if (!target) throw new Error('캡처 대상 요소를 찾을 수 없습니다.');

                        const canvas = await window.html2canvas(target, {
                            scale: 2, useCORS: true, allowTaint: false,
                            backgroundColor: '#ffffff', logging: false,
                            width: target.offsetWidth, height: target.offsetHeight,
                            scrollX: 0, scrollY: 0
                        });

                        const imgData = canvas.toDataURL('image/jpeg', 0.92);
                        const A4_W = 210;
                        const pdfH = (canvas.height / canvas.width) * A4_W;
                        const pdf = new JsPDF({ orientation: 'portrait', unit: 'mm', format: [A4_W, Math.max(pdfH, 297)] });
                        pdf.addImage(imgData, 'JPEG', 0, 0, A4_W, pdfH);
                        const root = document.getElementById('doc-scroll');
                        const titleAttr = (root?.getAttribute('data-doc-title') || '').trim();
                        pdf.save((titleAttr || docId || 'document') + '.pdf');
                    } catch (err) {
                        console.error('[PDF Export] 오류:', err);
                        showAlert('PDF 변환 중 오류가 발생했습니다: ' + (err.message || String(err)), 'alert-danger');
                    } finally { restoreBtn(); }
                });
            }
        }

        function hookDxReady() {
             const wrap = document.getElementById('dxDetailWrap');
             const scroll = document.getElementById('doc-scroll');
             if (!wrap) return;

             let done = false;
             let settleTimer = 0;
             let forceTimer1 = 0;
             let forceTimer2 = 0;
             let observer = null;

             function getWbc() {
                 return document.getElementById('dxDetailSheet_WBC')
                     || document.querySelector('#dxDetailWrap [id$="_WBC"]');
             }

             function getInnerScroll() {
                 return document.getElementById('dxDetailSheet_ScrollContainer')
                     || document.getElementById('dxDetailSheet_Grid')
                     || document.querySelector('#dxDetailWrap [id$="_ScrollContainer"]')
                     || document.querySelector('#dxDetailWrap [id$="_Grid"]');
             }
             
             function hasRenderedContent() {
                const wrap = document.getElementById('dxDetailWrap');
                if (!wrap) return false;

                const contentBox = getRenderedContentBox();
                if (contentBox.width > 120 && contentBox.height > 120) return true;

                const ctb = wrap.querySelector('[id*="_ctb."]');
                if (ctb) {
                    const r = ctb.getBoundingClientRect();
                    if (r.width > 40 && r.height > 12) return true;
                }

                const ftc = wrap.querySelector('.dxss-ftc');
                if (ftc) {
                    const r = ftc.getBoundingClientRect();
                    if (r.width > 40 && r.height > 12) return true;
                }

                return false;
            }

             function requestLayoutKick(reason) {
                 try {
                     applyDxWrapSize(reason);
                 } catch (e) { }

                 try {
                     const inst = getDxInstance();
                     if (inst && typeof inst.GetMainElement === 'function') {
                         const el = inst.GetMainElement();
                         if (el && typeof el.getBoundingClientRect === 'function') {
                             el.getBoundingClientRect();
                         }
                     }
                 } catch (e) { }

                 try {
                     window.dispatchEvent(new Event('resize'));
                 } catch (e) { }

                 const inner = getInnerScroll();
                 if (inner) {
                     try {
                         if (inner.scrollLeft !== 0) inner.scrollLeft = 0;
                         if (inner.scrollTop !== 0) inner.scrollTop = 0;
                     } catch (e) { }
                 }
             }
        
             function forceDxRender() {
                var wrap = document.getElementById('dxDetailWrap');
                if (!wrap) return;

                // 방법 1: window resize 이벤트
                try { window.dispatchEvent(new Event('resize')); } catch (e) { }

                // 방법 2: DX 인스턴스에 직접 AdjustControl 호출
                try {
                    var inst = getDxInstance();
                    if (inst && typeof inst.AdjustControl === 'function') {
                        inst.AdjustControl();
                    }
                } catch (e) { }

                // 방법 3: wrap 크기를 1px 변경했다 복원 → DX 내부 레이아웃 강제 재계산
                var h = wrap.style.getPropertyValue('height');
                if (h) {
                    var hVal = parseInt(h, 10) || 520;
                    wrap.style.setProperty('height', (hVal + 1) + 'px', 'important');
                    requestAnimationFrame(function () {
                        wrap.style.setProperty('height', hVal + 'px', 'important');
                    });
                }
            }

            function waitForVisibleContent(callback) {
                var attempts = 0;
                var maxAttempts = 30; // 최대 3초 (30 × 100ms)

                function check() {
                    attempts++;

                    // 실제로 셀 내용이 그려졌는지 확인
                    var wrap = document.getElementById('dxDetailWrap');
                    if (wrap) {
                        var cells = wrap.querySelectorAll('[id*="_ctb."], .dxss-ftc, .dxss-htd');
                        var hasVisible = false;
                        for (var i = 0; i < cells.length; i++) {
                            var r = cells[i].getBoundingClientRect();
                            if (r.width > 20 && r.height > 10) {
                                hasVisible = true;
                                break;
                            }
                        }

                        if (hasVisible) {
                            requestAnimationFrame(function () {
                                requestAnimationFrame(callback);
                            });
                            return;
                        }
                    }

                    if (attempts < maxAttempts) {
                        // 아직 안 보이면 DX에 다시 신호 보내고 재시도
                        if (attempts % 5 === 0) {
                            forceDxRender();
                        }
                        setTimeout(check, 100);
                    } else {
                        // 타임아웃 — 그래도 콜백은 실행
                        console.warn('[DX] content not visible after timeout, proceeding anyway');
                        forceDxRender();
                        requestAnimationFrame(function () {
                            requestAnimationFrame(callback);
                        });
                    }
                }

                check();
            }
                    
             function finalize(reason) {
                if (done) return;
                if (!hasRenderedContent()) return;

                done = true;
                state.overlayReady = false;

                clearTimeout(settleTimer);
                clearTimeout(forceTimer1);
                clearTimeout(forceTimer2);

                if (observer) {
                    observer.disconnect();
                    observer = null;
                }

                // 1단계: wrap 크기 설정 + 스크롤 잠금
                applyDxWrapSize(reason);
                installOuterScrollOnly();

                // 2단계: DX에 강제 resize 신호 → 렌더링 트리거
                forceDxRender();

                // 3단계: 콘텐츠가 보일 때까지 대기 후 오버레이 렌더
                waitForVisibleContent(function () {
                    renderApprovalOverlay();

                    setTimeout(function () {
                        renderApprovalOverlay();
                        var scroll = document.getElementById('doc-scroll');
                        if (scroll) scroll.classList.add('dx-page-ready');
                        console.log('[DX] page shown by', reason);

                        state.overlayReady = true;
                        bindOverlayResizeObserver();
                    }, 300);
                });
            }
            
            function settle(reason) {
                 clearTimeout(settleTimer);
                 settleTimer = window.setTimeout(function () {
                     requestLayoutKick(reason || 'dx-ready');
                     if (hasRenderedContent()) {
                         finalize(reason || 'dx-ready');
                     }
                 }, 120);
             }

             observer = new MutationObserver(function () {
                 if (done) return;
                 if (hasRenderedContent()) {
                     finalize('dx-dom-ready');
                 }
             });

             observer.observe(wrap, {
                 childList: true,
                 subtree: true,
                 attributes: false
             });

             window.__dxDetailOnEndSyncImpl = function (reason) {
                 if (done) return;
                 console.log('[DX] EndSynchronization fired:', reason);
                 settle(reason || 'dx-sync');
             };

             if (window.__dxDetailOnEndSyncPending) {
                 const pendingReason = window.__dxDetailOnEndSyncPending;
                 window.__dxDetailOnEndSyncPending = null;
                 settle(pendingReason || 'pending-sync');
             } else {
                 settle('hook-start');
             }

             forceTimer1 = window.setTimeout(function () {
                 if (done) return;
                 requestLayoutKick('dx-force-1');
                 if (hasRenderedContent()) {
                     finalize('dx-force-1');
                 }
             }, 1500);

             forceTimer2 = window.setTimeout(function () {
                 if (done) return;
                 requestLayoutKick('dx-force-2');
                 if (hasRenderedContent()) {
                     finalize('dx-force-2');
                 }
             }, 4500);

             if (!window.__DETAIL_DX_RESIZE_BOUND__) {
                 window.__DETAIL_DX_RESIZE_BOUND__ = true;
                 window.addEventListener('resize', function () {
                     requestAnimationFrame(function () {
                         applyDxWrapSize('window-resize');
                         renderApprovalOverlay();
                     });
                 }, { passive: true });
             }
        }
       
        // ================== 진입점 ==================
        function run() {
            clearAlert();

            state.preview = readJsonFromScript('PreviewJson', {}) || {};
            state.descriptor = readJsonFromScript('DescriptorJson', {}) || {};

            state.approvalsData = Array.isArray(readJsonFromScript('ApprovalsJson', []))
                ? readJsonFromScript('ApprovalsJson', [])
                : [];

            state.cooperationsData = Array.isArray(readJsonFromScript('CooperationsJson', []))
                ? readJsonFromScript('CooperationsJson', [])
                : [];

            const mapRows = readJsonFromScript('ApprovalCellsJson', []);
            const builtMap = buildLegacyApprovalCellMap(Array.isArray(mapRows) ? mapRows : []);

            state.approvalCellMap = builtMap.approval || { byStep: {}, byRoleKey: {} };
            state.cooperationCellMap = builtMap.cooperation || { byStep: {}, byRoleKey: {} };

            console.log('approvalCellMap', state.approvalCellMap, mapRows);
            console.log('cooperationCellMap', state.cooperationCellMap, mapRows);

            applyDxWrapSize('run-init');
            renderViewLogs();
            renderApprovalsTable();
            initRecipientsFromSelected();
            initRecipientsChangeButton();
            initDocFileImageOverlay();
            initComments();
            initApproveButtons();
            initRecallButton();
            initPrintExport();
            hookDxReady();
        }

        if (document.readyState === 'loading') {
            document.addEventListener('DOMContentLoaded', run);
        } else {
            run();
        }    
    })();
    </script>
}