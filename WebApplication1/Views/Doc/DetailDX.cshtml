        // 2026.07.02 Changed: DetailDX Spreadsheet 선택 표시 숨김 보강 Contents 클래스명 없는 파란 선택 테두리와 선택 핸들 점까지 숨긴다
        function installDetailDxSelectionChromeHider() {
            if (window.__DETAIL_DX_SELECTION_CHROME_HIDER_INSTALLED__) return;
            window.__DETAIL_DX_SELECTION_CHROME_HIDER_INSTALLED__ = true;

            const wrap = document.getElementById('dxDetailWrap');
            if (!wrap) return;

            let rafId = 0;

            function parseRgb(value) {
                const s = String(value || '').trim();
                const m = s.match(/rgba?\s*\(\s*(\d+)\s*,\s*(\d+)\s*,\s*(\d+)/i);
                if (!m) return null;
                return {
                    r: parseInt(m[1], 10),
                    g: parseInt(m[2], 10),
                    b: parseInt(m[3], 10)
                };
            }

            function isBlueSelectionColor(value) {
                const c = parseRgb(value);
                if (!c) return false;

                return c.b >= 120
                    && c.g >= 70
                    && c.r <= 140
                    && c.b > c.r + 30
                    && c.b >= c.g;
            }

            function hideElementChrome(el) {
                if (!el || !el.style) return;

                el.style.setProperty('visibility', 'hidden', 'important');
                el.style.setProperty('opacity', '0', 'important');
                el.style.setProperty('pointer-events', 'none', 'important');
                el.style.setProperty('outline', '0', 'important');
                el.style.setProperty('box-shadow', 'none', 'important');
                el.style.setProperty('border-color', 'transparent', 'important');
                el.style.setProperty('background', 'transparent', 'important');
                el.style.setProperty('background-color', 'transparent', 'important');
            }

            function hideSelectionChrome() {
                rafId = 0;

                const nameSelectors = [
                    '[id*="Selection"]',
                    '[id*="selection"]',
                    '[id*="Selected"]',
                    '[id*="selected"]',
                    '[id*="ActiveCell"]',
                    '[id*="activeCell"]',
                    '[id*="FocusedCell"]',
                    '[id*="focusedCell"]',
                    '[class*="selection"]',
                    '[class*="Selection"]',
                    '[class*="selected"]',
                    '[class*="Selected"]',
                    '[class*="activeCell"]',
                    '[class*="ActiveCell"]',
                    '[class*="focusedCell"]',
                    '[class*="FocusedCell"]',
                    '[class*="focusCell"]',
                    '[class*="FocusCell"]',
                    '[class*="rangeSelector"]',
                    '[class*="RangeSelector"]',
                    '[class*="fillHandle"]',
                    '[class*="FillHandle"]',
                    '[class*="resizeHandle"]',
                    '[class*="ResizeHandle"]',
                    '[class*="sizeHandle"]',
                    '[class*="SizeHandle"]'
                ].join(',');

                try {
                    wrap.querySelectorAll(nameSelectors).forEach(hideElementChrome);
                } catch (e) {
                }

                // 2026.07.02 Changed: 색상 기반 선택 표시 숨김 Contents DevExpress 버전에 따라 클래스명이 없는 파란 테두리와 작은 파란 핸들을 제거한다
