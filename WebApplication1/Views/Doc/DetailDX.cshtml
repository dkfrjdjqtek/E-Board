        function excelColWidthToPx(w) {
            const n = Number(w);
            if (!isFinite(n) || n < 0) return 0;
            const MDW = 7;
            return Math.floor((n * MDW + 5) / MDW) * MDW + 2;
        }

        function ptToPx(pt) {
            return ((Number(pt) || 0) * 96 / 72);
        }

        function normalizeStampBucketSeed(v) {
            const s = String(v || '').trim().toLowerCase();
            if (!s) return '';
            if (s.includes('coop') || s.includes('cooperation') || s.includes('협조')) return 'cooperation';
            if (s.includes('approv') || s.includes('approval') || s.includes('결재')) return 'approval';
            return '';
        }

        function inferStampBucketSeed(row) {
            if (!row) return 'approval';

            const candidates = [
                row.kind, row.Kind,
                row.type, row.Type,
                row.group, row.Group,
                row.section, row.Section,
                row.category, row.Category,
                row.mode, row.Mode,
                row.stampType, row.StampType,
                row.approvalType, row.ApprovalType
            ];

            for (let i = 0; i < candidates.length; i++) {
                const bucket = normalizeStampBucketSeed(candidates[i]);
                if (bucket) return bucket;
            }

            const roleKey = String(row.roleKey || row.RoleKey || '').trim().toUpperCase();
            if (roleKey.startsWith('C')) return 'cooperation';
            if (roleKey.startsWith('A')) return 'approval';

            if (row.isCooperation === true || row.IsCooperation === true) return 'cooperation';
            return 'approval';
        }

        function normalizeStampBucketName(v) {
            const s = String(v || '').trim().toLowerCase();
            if (!s) return '';
            if (s.includes('coop') || s.includes('cooperation') || s.includes('협조')) return 'cooperation';
            if (s.includes('approv') || s.includes('approval') || s.includes('결재')) return 'approval';
            return '';
        }

        function inferStampBucketFromRow(row) {
            if (!row) return 'approval';

            const candidates = [
                row.kind, row.Kind,
                row.type, row.Type,
                row.group, row.Group,
                row.section, row.Section,
                row.category, row.Category,
                row.mode, row.Mode,
                row.stampType, row.StampType,
                row.approvalType, row.ApprovalType,
                row.bucket, row.Bucket,
                row.lane, row.Lane
            ];

            for (let i = 0; i < candidates.length; i++) {
                const bucket = normalizeStampBucketName(candidates[i]);
                if (bucket) return bucket;
            }

            const roleKey = String(row.roleKey || row.RoleKey || '').trim().toUpperCase();
            if (roleKey.startsWith('C')) return 'cooperation';
            if (roleKey.startsWith('A')) return 'approval';

            if (row.isCooperation === true || row.IsCooperation === true) return 'cooperation';
            return 'approval';
        }

        function buildLegacyApprovalCellMap(rows) {
            const built = {
                approval: { byStep: {}, byRoleKey: {} },
                cooperation: { byStep: {}, byRoleKey: {} }
            };

            if (!Array.isArray(rows)) return built;

            rows.forEach(function (row) {
                if (!row) return;

                const a1 = String(row.a1 || row.A1 || row.cellA1 || row.CellA1 || '').trim();
                if (!a1) return;

                const bucket = inferStampBucketFromRow(row);
                const step = row.step || row.Step || row.stepOrder || row.StepOrder || row.slot || row.Slot;
                const roleKey = String(row.roleKey || row.RoleKey || '').trim();
                const payload = { row: row, a1: a1 };

                if (step != null && step !== '') {
                    built[bucket].byStep[String(step)] = payload;
                    if (bucket === 'approval') built[String(step)] = a1;
                }

                if (roleKey) {
                    built[bucket].byRoleKey[roleKey] = payload;
                    if (bucket === 'approval') built[roleKey] = a1;
                }
            });

            return built;
        }

