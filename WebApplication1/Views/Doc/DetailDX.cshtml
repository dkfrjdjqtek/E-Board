@using System.IO
@using System.Text.Json
@using System.Text.Encodings.Web
@using WebApplication1.Models
@model WebApplication1.Models.DocTLViewModel
@inject Microsoft.AspNetCore.Hosting.IWebHostEnvironment Env
@inject Microsoft.Extensions.Localization.IStringLocalizer<SharedResource> S
@inject Microsoft.Extensions.Logging.ILoggerFactory LoggerFactory

@functions {
    public class __DocFileVm
    {
        public string? FileKey { get; set; }
        public string? OriginalName { get; set; }
        public string? ContentType { get; set; }
        public long ByteSize { get; set; }
        public string? UploadedAtText { get; set; }
    }

    private static bool __IsImageAttachment(string? contentType, string? originalName)
    {
        if (!string.IsNullOrWhiteSpace(contentType) &&
            contentType.StartsWith("image/", StringComparison.OrdinalIgnoreCase))
            return true;

        if (string.IsNullOrWhiteSpace(originalName))
            return false;

        var ext = System.IO.Path.GetExtension(originalName) ?? string.Empty;
        if (string.IsNullOrWhiteSpace(ext))
            return false;

        ext = ext.Trim().ToLowerInvariant();
        return ext == ".png" || ext == ".jpg" || ext == ".jpeg" || ext == ".gif" || ext == ".webp" || ext == ".bmp";
    }
}

@{
    
    ViewData["DisableDxAll"] = true;

    var workDir = Env.ContentRootPath;
    var isAjax = string.Equals(Context.Request.Headers["X-Requested-With"], "XMLHttpRequest", StringComparison.OrdinalIgnoreCase);
    Layout = isAjax ? null : "~/Views/Shared/_Layout.cshtml";

    var routeId = (string?)ViewContext?.RouteData?.Values?["id"]?.ToString();
    var qid = (Context?.Request?.Query["id"].ToString() ?? string.Empty);

    var docId =
        (string?)ViewBag.DocId
        ?? (string?)ViewBag.DocumentId
        ?? (!string.IsNullOrWhiteSpace(routeId) ? routeId : null)
        ?? (!string.IsNullOrWhiteSpace(qid) ? qid : string.Empty);

    var __detailDxViewLogger = LoggerFactory.CreateLogger("WebApplication1.Views.Doc.DetailDX");
    var __detailDxViewSw = System.Diagnostics.Stopwatch.StartNew();
    double __detailDxViewLastMs = 0d;

    void __MarkDetailDxViewPerf(string name)
    {
        try
        {
            var elapsedMs = __detailDxViewSw.Elapsed.TotalMilliseconds;
            var deltaMs = elapsedMs - __detailDxViewLastMs;
            __detailDxViewLastMs = elapsedMs;

            __detailDxViewLogger.LogInformation(
                "DETAILDX-VIEW-PERF {Name} elapsedMs={ElapsedMs} deltaMs={DeltaMs} docId={DocId}",
                name ?? "mark",
                elapsedMs,
                deltaMs,
                docId ?? string.Empty);
        }
        catch
        {
        }
    }

    __MarkDetailDxViewPerf("view-start");

    var templateCode = (string?)ViewBag.TemplateCode ?? string.Empty;
    var templateTitle = (string?)ViewBag.TemplateTitle ?? string.Empty;
    var status = (string?)ViewBag.Status ?? "Draft";
    var compCd = (string?)ViewBag.CompCd ?? string.Empty;
    var creatorName = (string?)ViewBag.CreatorName ?? string.Empty;
    var descJson = (string?)ViewBag.DescriptorJson ?? "{}";
    var previewJson = (string?)ViewBag.PreviewJson ?? "{}";
    var approvalsJson = (string?)ViewBag.ApprovalsJson ?? "[]";
    var viewLogsJson = (string?)ViewBag.ViewLogsJson ?? "[]";
    var approvalTableRowsJson = (string?)ViewBag.ApprovalTableRowsJson ?? "[]";
    var approvalCellsJson = (string?)ViewBag.ApprovalCellsJson ?? "[]";
    var cooperationsJson = (string?)ViewBag.CooperationsJson ?? "[]";
    var createdAtText = (string?)ViewBag.CreatedAtText ?? string.Empty;
    var recalledAtText = (string?)ViewBag.RecalledAtText ?? string.Empty;
    var excelPath = (string?)ViewBag.ExcelPath ?? string.Empty;
    var dxCallbackUrl = (string?)ViewBag.DxCallbackUrl ?? "/Doc/dx-callback";
    var dxDocumentId = (string?)ViewBag.DxDocumentId ?? ("detail_" + Guid.NewGuid().ToString("N"));

    var renderUsedLastCellA1 = (string?)ViewBag.RenderUsedLastCellA1 ?? "A1";
    var renderLastCellA1 = (string?)ViewBag.RenderLastCellA1 ?? "B2";
    var renderMaxRow = (int?)ViewBag.RenderMaxRow ?? 0;
    var renderMaxCol = (int?)ViewBag.RenderMaxCol ?? 0;
    var renderWidthPx = Convert.ToDouble(ViewBag.RenderWidthPx ?? 0);
    var renderHeightPx = Convert.ToDouble(ViewBag.RenderHeightPx ?? 0);
    var renderDiagJson = (string?)ViewBag.RenderDiagJson ?? "{}";

    // 2026.06.12 Changed: DetailDX도 ComposeDX와 동일하게 실제 xlsx 파일을 byte accessor로 연다.
    // App_Data 상대경로를 DevExpress Open(path)에 직접 넘기지 않는다.
    var dxOpenByBytes = !string.IsNullOrWhiteSpace(excelPath)
        && System.IO.Path.IsPathRooted(excelPath)
        && System.IO.File.Exists(excelPath);

    Func<byte[]> dxOpenContentAccessor = () =>
    {
        var readSw = System.Diagnostics.Stopwatch.StartNew();
        var bytes = System.IO.File.ReadAllBytes(excelPath);
        try
        {
            __detailDxViewLogger.LogInformation(
                "DETAILDX-VIEW-PERF bytes-read elapsedMs={ElapsedMs} bytes={Bytes} docId={DocId} documentId={DocumentId} excelPath={ExcelPath}",
                readSw.Elapsed.TotalMilliseconds,
                bytes.Length,
                docId ?? string.Empty,
                dxDocumentId ?? string.Empty,
                excelPath ?? string.Empty);
        }
        catch
        {
        }
        return bytes;
    };

    // 2026.06.12 Changed: DetailDX 화면 크기는 템플릿 버전에 저장된 DB VisualMetric을 그대로 사용한다.
    // ComposeDX와 동일하게 DX 내부 클리핑 여백만 고정 padding으로 더하고 최초 로딩 후 resize 이벤트에 의존하지 않는다.
    var dxRenderPadWidthPx = renderWidthPx > 0 ? 72d : 0d;
    var dxRenderPadHeightPx = renderHeightPx > 0 ? 72d : 0d;
    var dxLayoutWidthPx = renderWidthPx > 0 ? renderWidthPx + dxRenderPadWidthPx : 900d;
    var dxLayoutHeightPx = renderHeightPx > 0 ? renderHeightPx + dxRenderPadHeightPx : 900d;
    var dxInitialWidthPx = (int)Math.Ceiling(dxLayoutWidthPx);
    var dxInitialHeightPx = (int)Math.Ceiling(dxLayoutHeightPx);

    var openRel = (string?)ViewBag.OpenRel ?? excelPath;
    try
    {
        if (!string.IsNullOrWhiteSpace(excelPath) && System.IO.Path.IsPathRooted(excelPath))
            openRel = System.IO.Path.GetRelativePath(workDir, excelPath);
    }
    catch
    {
        openRel = excelPath;
    }

    var creatorDisplayName = creatorName;
    if (!string.IsNullOrWhiteSpace(creatorDisplayName))
    {
        var parts = creatorDisplayName.Split(' ', StringSplitOptions.RemoveEmptyEntries);
        if (parts.Length > 0) creatorDisplayName = parts[^1];
    }

    var docTitle = !string.IsNullOrWhiteSpace(templateTitle) ? templateTitle : ((string?)ViewBag.DocTitle ?? string.Empty);            
    var formattedTitle = (!string.IsNullOrWhiteSpace(creatorDisplayName) && !string.IsNullOrWhiteSpace(docTitle)) ? S["DOC_Title_Fmt", creatorDisplayName, docTitle].Value : S["DOC_Title_Detail"].Value;
    ViewData["Title"] = formattedTitle;

    var canRecall = (bool?)ViewBag.CanBackToNew ?? false;
    var canPrint = (bool?)ViewBag.CanPrint ?? true;
    var canExport = (bool?)ViewBag.CanExportPdf ?? true;
    var canApprove = (bool?)ViewBag.CanApprove ?? false;
    var canHold = (bool?)ViewBag.CanHold ?? false;
    var canReject = (bool?)ViewBag.CanReject ?? false;
    var canCooperate = (bool?)ViewBag.CanCooperate ?? false;
    var canCooperateReject = (bool?)ViewBag.CanCooperateReject ?? false;

    List<__DocFileVm> documentFiles;
    try
    {
        documentFiles = JsonSerializer.Deserialize<List<__DocFileVm>>(ViewBag.DocumentFilesJson?.ToString() ?? "[]") ?? new List<__DocFileVm>();
    }
    catch
    {
        documentFiles = new List<__DocFileVm>();
    }

    __MarkDetailDxViewPerf("view-model-ready");
}

