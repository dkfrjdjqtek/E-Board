    <script>
    (function () {
        'use strict';

        window.__ORG_MS_INITIAL_SELECTED = @Html.Raw(ViewBag.SelectedRecipientUserIdsJson ?? "[]");
        var selectedIds = @Html.Raw(ViewBag.SelectedRecipientUserIdsJson ?? "[]");

        const $ = (q, r = document) => r.querySelector(q);
        const docId = "@(docId ?? "")";
        const compCd = "@(compCd ?? "")";
        const state = {
            preview: {},
            descriptor: {},
            approvalsData: [],
            cooperationsData: [],
            approvalCellMap: { byStep: {}, byRoleKey: {} },
            cooperationCellMap: { byStep: {}, byRoleKey: {} },
            previewExtent: { width: 900, height: 520 },
            renderExtent: { width: 0, height: 0, maxRow: 0, maxCol: 0, usedLastCellA1: 'A1', renderLastCellA1: 'B2' },
            _effectiveMaxC: 0,
            _colSum: 0,
            overlayRefreshTimer: 0,
            overlayRefreshRaf: 0,
            overlayResizeObserver: null,
            overlayReady: false
        };


        // ================== 공통 유틸 ==================
        function decodeHtmlEntities(str) {
                    if (str == null) return '';
                    let s = String(str);
                    s = s.replace(/&#x([0-9a-fA-F]+);/g, (_, h) => String.fromCodePoint(parseInt(h, 16)));
                    s = s.replace(/&#(\d+);/g, (_, d) => String.fromCodePoint(parseInt(d, 10)));
                    s = s.replace(/&lt;/g, '<').replace(/&gt;/g, '>').replace(/&amp;/g, '&')
                        .replace(/&quot;/g, '"').replace(/&apos;/g, "'");
                    return s;
                }

                const T = (m) => {
            if (m == null) return '';
            if (Array.isArray(m)) return m.map(T).join('\n');
            const s = String(m);
            const mapped = (window.__RESX && Object.prototype.hasOwnProperty.call(window.__RESX, s))
                ? window.__RESX[s] : s;
            return decodeHtmlEntities(mapped);
        };

        function readJsonFromScript(id, fallback) {
            try {
                const el = document.getElementById(id);
                if (!el) return fallback;
                const raw = el.textContent || '';
                if (!raw.trim()) return fallback;
                const decoded = decodeHtmlEntities(raw);
                let v = JSON.parse(decoded);
                if (typeof v === 'string') { try { v = JSON.parse(v); } catch { } }
                return (v != null) ? v : fallback;
            } catch { return fallback; }
        }

        function clearAlert() {
            const box = document.getElementById('detail-alert');
            if (box) box.innerHTML = '';
        }

        function showAlert(msg, cls) {
            const box = document.getElementById('detail-alert');
            if (!box) return;
            box.innerHTML = `<div class="alert ${cls} py-1 my-1">${msg}</div>`;
        }

        function excelColWidthToPx(w) {
            const n = Number(w);
            if (!isFinite(n) || n < 0) return 0;
            const MDW = 7;
            return Math.floor((n * MDW + 5) / MDW) * MDW + 2;
        }

        function ptToPx(pt) {
            return ((Number(pt) || 0) * 96 / 72);
        }

        function normalizeStampBucketSeed(v) {
            const s = String(v || '').trim().toLowerCase();
            if (!s) return '';
            if (s.includes('coop') || s.includes('cooperation') || s.includes('협조')) return 'cooperation';
            if (s.includes('approv') || s.includes('approval') || s.includes('결재')) return 'approval';
            return '';
        }

        function inferStampBucketSeed(row) {
            if (!row) return 'approval';

            const candidates = [
                row.kind, row.Kind,
                row.type, row.Type,
                row.group, row.Group,
                row.section, row.Section,
                row.category, row.Category,
                row.mode, row.Mode,
                row.stampType, row.StampType,
                row.approvalType, row.ApprovalType
            ];

            for (let i = 0; i < candidates.length; i++) {
                const bucket = normalizeStampBucketSeed(candidates[i]);
                if (bucket) return bucket;
            }

            const roleKey = String(row.roleKey || row.RoleKey || '').trim().toUpperCase();
            if (roleKey.startsWith('C')) return 'cooperation';
            if (roleKey.startsWith('A')) return 'approval';

            if (row.isCooperation === true || row.IsCooperation === true) return 'cooperation';
            return 'approval';
        }

        function normalizeStampBucketName(v) {
            const s = String(v || '').trim().toLowerCase();
            if (!s) return '';
            if (s.includes('coop') || s.includes('cooperation') || s.includes('협조')) return 'cooperation';
            if (s.includes('approv') || s.includes('approval') || s.includes('결재')) return 'approval';
            return '';
        }
        
        function inferStampBucketFromRow(row) {
            if (!row) return 'approval';

            const candidates = [
                row.kind, row.Kind,
                row.type, row.Type,
                row.group, row.Group,
                row.section, row.Section,
                row.category, row.Category,
                row.mode, row.Mode,
                row.stampType, row.StampType,
                row.approvalType, row.ApprovalType,
                row.bucket, row.Bucket,
                row.lane, row.Lane
            ];

            for (let i = 0; i < candidates.length; i++) {
                const bucket = normalizeStampBucketName(candidates[i]);
                if (bucket) return bucket;
            }

            const roleKey = String(row.roleKey || row.RoleKey || '').trim().toUpperCase();
            if (roleKey.startsWith('C')) return 'cooperation';
            if (roleKey.startsWith('A')) return 'approval';

            if (row.isCooperation === true || row.IsCooperation === true) return 'cooperation';
            return 'approval';
        }
        
        function buildLegacyApprovalCellMap(rows) {
            const built = {
                approval: { byStep: {}, byRoleKey: {} },
                cooperation: { byStep: {}, byRoleKey: {} }
            };

            if (!Array.isArray(rows)) return built;

            rows.forEach(function (row) {
                if (!row) return;

                const a1 = String(row.a1 || row.A1 || row.cellA1 || row.CellA1 || '').trim();
                if (!a1) return;

                const bucket = inferStampBucketFromRow(row);
                const step = row.step || row.Step || row.stepOrder || row.StepOrder || row.slot || row.Slot;
                const roleKey = String(row.roleKey || row.RoleKey || '').trim();
                const payload = { row: row, a1: a1 };

                if (step != null && step !== '') {
                    built[bucket].byStep[String(step)] = payload;

                    // 구형 flat fallback 은 approval 만 유지
                    if (bucket === 'approval') built[String(step)] = a1;
                }

                if (roleKey) {
                    built[bucket].byRoleKey[roleKey] = payload;

                    // 구형 flat fallback 은 approval 만 유지
                    if (bucket === 'approval') built[roleKey] = a1;
                }
            });

            return built;
        }

        // ================== DX 인스턴스 취득 ==================    
        function getDxInstance() {
            try { if (window.dxDetailSheet && typeof window.dxDetailSheet === 'object') return window.dxDetailSheet; } catch (e) { }
            try {
                if (typeof ASPxClientSpreadsheet !== 'undefined' && typeof ASPxClientSpreadsheet.Cast === 'function') {
                    const inst = ASPxClientSpreadsheet.Cast(window.dxDetailSheet);
                    if (inst) return inst;
                }
            } catch (e) { }
            try {
                if (typeof ASPxClientControl !== 'undefined' && typeof ASPxClientControl.GetControlCollection === 'function') {
                    const col = ASPxClientControl.GetControlCollection();
                    if (col) {
                        const inst = col.GetByName('dxDetailSheet');
                        if (inst) return inst;
                    }
                }
            } catch (e) { }
            return null;
        }
    
        // ================== 프리뷰 extent 계산 ==================            
        function computePreviewExtent(preview) {
            const serverMaxRow = Number(window.__dxRenderMaxRow || 0);
            const serverMaxCol = Number(window.__dxRenderMaxCol || 0);
            const serverWidthPx = Number(window.__dxRenderWidthPx || 0);
            const serverHeightPx = Number(window.__dxRenderHeightPx || 0);

            if (serverMaxRow > 0 && serverMaxCol > 0 && serverWidthPx > 0 && serverHeightPx > 0) {
                const leftReservePx = 32;
                const topReservePx = 22;
                const rightReservePx = 72;
                const bottomReservePx = 16;

                const wrapWidth = Math.max(600, Math.ceil(serverWidthPx + leftReservePx + rightReservePx));
                const wrapHeight = Math.max(520, Math.ceil(serverHeightPx + topReservePx + bottomReservePx));

                state.renderExtent = {
                    width: serverWidthPx,
                    height: serverHeightPx,
                    wrapWidth: wrapWidth,
                    wrapHeight: wrapHeight,
                    maxRow: serverMaxRow,
                    maxCol: serverMaxCol,
                    usedLastCellA1: String(window.__dxRenderUsedLastCellA1 || 'A1'),
                    renderLastCellA1: String(window.__dxRenderLastCellA1 || 'B2')
                };

                console.log('[DX] render extent from server:', state.renderExtent);
                console.log('[DX] render diag from server:', window.__dxRenderDiag);

                return {
                    width: wrapWidth,
                    height: wrapHeight
                };
            }

            return { width: 900, height: 520 };
        }
        function getRenderedPageBox() {
            const wrap = document.getElementById('dxDetailWrap');
            if (!wrap) return { width: 0, height: 0 };

            const page =
                wrap.querySelector('.dxss-print-area')
                || wrap.querySelector('.dxss-page');

            if (!page) return { width: 0, height: 0 };

            const rect = page.getBoundingClientRect();
            return {
                width: Math.ceil(rect.width || 0),
                height: Math.ceil(rect.height || 0)
            };
        }

        function getRenderedContentBox() {
            const wrap = document.getElementById('dxDetailWrap');
            if (!wrap) return { width: 0, height: 0 };

            const wbc =
                document.getElementById('dxDetailSheet_WBC')
                || document.querySelector('#dxDetailWrap [id$="_WBC"]');

            const grid =
                document.getElementById('dxDetailSheet_Grid')
                || document.querySelector('#dxDetailWrap [id$="_Grid"]');

            const pageBox = getRenderedPageBox();

            let width = pageBox.width;
            let height = pageBox.height;

            if (wbc) {
                // scrollWidth/offsetWidth가 부모 컨테이너 크기(1000000 등)를 반환하는 경우 방지
                // clientWidth만 사용하고, 서버 기준값의 2배를 초과하면 무시
                const serverW = Number(state.renderExtent?.width || 0);
                const maxSaneW = Math.max(2000, serverW * 2);
                const wbcW = Math.ceil(wbc.clientWidth || 0);
                if (wbcW > 0 && wbcW < maxSaneW) {
                    width = Math.max(width, wbcW);
                }
                const wbcH = Math.ceil(wbc.clientHeight || 0);
                if (wbcH > 0) {
                    height = Math.max(height, wbcH);
                }
            }

            if (grid) {
                const serverW = Number(state.renderExtent?.width || 0);
                const maxSaneW = Math.max(2000, serverW * 2);
                const gridW = Math.ceil(grid.clientWidth || 0);
                if (gridW > 0 && gridW < maxSaneW) {
                    width = Math.max(width, gridW);
                }
                const gridH = Math.ceil(grid.clientHeight || 0);
                if (gridH > 0) {
                    height = Math.max(height, gridH);
                }
            }

            return { width, height };
        }

        // function applyDxWrapSize(reason) {
        //     const wrap = document.getElementById('dxDetailWrap');
        //     if (!wrap) return;

        //     const ext = computePreviewExtent(state.preview);
        //     const contentBox = getRenderedContentBox();

        //     let finalWidth = Math.max(600, Math.ceil(Number(ext.width || 900)));
        //     let finalHeight = Math.max(520, Math.ceil(Number(ext.height || 520)));

