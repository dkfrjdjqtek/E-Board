<div id="doc-scroll" data-template-code="@templateCode">
    <div class="page-header">
        <h3>@S["DOC_Title_Compose"]</h3>
        <span class="text-muted">@templateTitle</span>
    </div>

    <div id="doc-alert" class="mb-2" aria-live="polite"></div>

    <form id="doc-form" method="post" novalidate style="max-width:100%">
        @Html.AntiForgeryToken()

        <input type="hidden" name="TemplateCode" value="@templateCode" />
        <input type="hidden" name="templateCode" value="@templateCode" />
        <input type="hidden" id="dx-open-rel" value="@openRel" />
        <input type="hidden" id="dx-excel-path" value="@excelPath" />
        <input type="hidden" id="dx-doc-id" value="@dxDocumentId" />

        <script type="application/json" id="DescriptorJson">@Html.Raw(descJson.Replace("</", "<\\/"))</script>
        <script type="application/json" id="PreviewJson">@Html.Raw(previewJson.Replace("</", "<\\/"))</script>

        <script>
            window.__RESX = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(new
                {
                                DOC_Err_PreviewFailed = S["DOC_Err_PreviewFailed"].Value,
                                DOC_Err_SaveFailed = S["DOC_Err_SaveFailed"].Value,
                                DOC_Msg_Saved = S["DOC_Msg_Saved"].Value,
                                DOC_Val_TemplateRequired = S["DOC_Val_TemplateRequired"].Value,
                                DOC_Btn_Cancel = S["DOC_Btn_Cancel"].Value,
                                DOC_Submit_Button = S["DOC_Submit_Button"].Value,
                                DOC_Err_UploadFailed = S["DOC_Err_UploadFailed"].Value,
                                ORG_MS_Placeholder_Search = S["ORG_MS_Placeholder_Search"].Value,
                                ORG_MS_Placeholder_Empty = S["ORG_MS_Placeholder_Empty"].Value,
                                ORG_MS_Label_SelectedCount = S["ORG_MS_Label_SelectedCount"].Value,
                                ORG_MS_Label_All = S["ORG_MS_Label_All"].Value,
                                ORG_MS_Label_Clear = S["ORG_MS_Label_Clear"].Value,
                                DOC_Attach_Count_None = S["DOC_Attach_Count_None"].Value,
                                DOC_Attach_Count_N = S["DOC_Attach_Count_N"].Value,
                                DOC_Label_Attachments = S["DOC_Label_Attachments"].Value,
                                DOC_Label_Recipients = S["DOC_Label_Recipients"].Value,
                                _CM_Select = S["_CM_Select"].Value,
                                _CM_Delete = S["_CM_Delete"].Value,
                                _CM_Open = S["_CM_Open"].Value,
                                _CM_Save = S["_CM_Save"].Value,
                                _CM_Error = S["_CM_Error"].Value,
                                DTL_Type_Text = S["DTL_Type_Text"].Value,
                                DTL_Type_Date = S["DTL_Type_Date"].Value,
                                DTL_Type_Num = S["DTL_Type_Num"].Value
                }));
            window.__tplFromServer = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(templateCode ?? string.Empty));
            window.__dxOpenRel = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(openRel ?? string.Empty));
            window.__dxCallbackUrl = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(dxCallbackUrl ?? "/Doc/dx-callback"));
            window.__dxExcelAbsPath = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(excelPath ?? string.Empty));
            window.__dxDocumentId = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(dxDocumentId ?? string.Empty));
            window.__dxTargetHeightPx = @dxTargetHeightPx;
            window.__dxTargetWidthPx = @dxTargetWidthPx;
            window.__dxTargetHeightSafePx = @dxTargetHeightSafePx;
            window.__dxTargetWidthSafePx = @dxTargetWidthSafePx;
            window.__dxLastRow = @dxLastRow;
            window.__dxLastCol = @dxLastCol;
            window.__dxLastA1 = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(dxLastA1));
            window.__dxTargetA1 = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(dxTargetA1));
            window.__dxTargetRow1 = @dxTargetRow1;
            window.__dxTargetCol1 = @dxTargetCol1;
            window.__dxVisualMode = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(dxVisualMode));
        </script>

        <div id="dxComposeWrap"
             style="height:@(dxTargetHeightSafePx)px; min-height:@(dxTargetHeightSafePx)px; width:@(dxTargetWidthSafePx)px; min-width:@(dxTargetWidthSafePx)px; max-width:@(dxTargetWidthSafePx)px;">
            @{
                Html.DevExpress().Spreadsheet("dxComposeSheet")
                .Height("100%")
                .Width("100%")
                .WorkDirectory(workDir)
                .DocumentRequestHandlerUrl(dxCallbackUrl)
                .Open(openRel)
                .ReadOnly(false)
                .ConfirmOnLosingChanges(c => c.Enabled(false))
                .WriteTo(ViewContext.Writer, HtmlEncoder.Default);
            }
        </div>

        <div class="doc-upload-area">
            <label class="form-label">@S["DOC_Label_Attachments"]</label>

            <div class="d-flex align-items-center gap-2 flex-wrap">
                <button type="button" class="btn btn-secondary" id="doc-attach-pick">
                    @S["_CM_Select"]
                </button>

                <input id="doc-attachments"
                       type="file"
                       multiple
                       style="display:none" />

                <span class="text-muted" id="doc-attach-count"></span>
            </div>

            <div id="doc-attach-list" class="mt-2"></div>
        </div>

        <div class="doc-share-area">
            <label class="form-label">@S["DOC_Label_Recipients"]</label>
            @{
                var orgNodes = ViewBag.OrgTreeNodes as IEnumerable<OrgTreeNode>
                ?? Array.Empty<OrgTreeNode>();
            }
            @await Html.PartialAsync(
            "_OrgMultiSelectCombo",
                        orgNodes,
                        new Microsoft.AspNetCore.Mvc.ViewFeatures.ViewDataDictionary(ViewData)
                        {
                            ["ControlId"] = "doc-recipient-select",
                            ["FieldName"] = "SelectedRecipientUserIds"
                        })
        </div>

        <div class="form-actions">
            <button type="button" id="btn-save" class="btn btn-primary action-btn" data-doc-submit>
                @S["DOC_Submit_Button"]
            </button>
            <button type="button" id="btn-cancel" class="btn btn-outline-secondary action-btn">
                @S["DOC_Btn_Cancel"]
            </button>
        </div>

        <input type="text"
               id="dxCommitSink"
               tabindex="-1"
               autocomplete="off"
               style="position:fixed;left:-10000px;top:-10000px;width:1px;height:1px;opacity:0;pointer-events:none;" />

        <input type="date" id="dxDatePickerBridge" />
    </form>
</div>

@section Scripts {
    <script src="~/js/eb.csrf.js"></script>
    <script>
        (function () {
            'use strict';

            const $ = (q, r = document) => r.querySelector(q);
            const $alert = () => document.getElementById('doc-alert');

            const SERVER_UI_CULTURE = '@System.Globalization.CultureInfo.CurrentUICulture.Name';

            const state = {
                dxEditing: false,
                dxDirtySinceLastSync: false,
                dxSyncDepth: 0,
                saveCommitPromise: null,
                intentionalLeave: false,
                editableMap: new Map(),
                editableByA1: new Map(),
                descriptor: {},
                preview: {},
                filesFailed: [],
                fileCache: [],
                activeSelection: null,
                activeA1: '',
                dateA1Set: new Set(),
                datePickerOpen: false,
                lastDatePopupA1: '',
                lastWrapAppliedA1: '',
                previewExtent: null,
                dateDefaultsApplied: false,
                dateBridgeBound: false,
                lastDateAnchorEl: null,
                serverExtent: {
                    width: Number(window.__dxTargetWidthPx || 0),
                    height: Number(window.__dxTargetHeightPx || 0),
                    safeWidth: Number(window.__dxTargetWidthSafePx || 0),
                    safeHeight: Number(window.__dxTargetHeightSafePx || 0),
                    lastRow: Number(window.__dxLastRow || 0),
                    lastCol: Number(window.__dxLastCol || 0),
                    lastA1: String(window.__dxLastA1 || 'A1'),
                    targetA1: String(window.__dxTargetA1 || 'A1'),
                    targetRow1: Number(window.__dxTargetRow1 || 1),
                    targetCol1: Number(window.__dxTargetCol1 || 1),
                    mode: String(window.__dxVisualMode || '')
                }
            };

            // ──────────────────────────────────────────
            // 유틸
            // ──────────────────────────────────────────

            function getTodayYmd() {
                const d = new Date();
                const y = d.getFullYear();
                const m = String(d.getMonth() + 1).padStart(2, '0');
                const dd = String(d.getDate()).padStart(2, '0');
                return `${y}-${m}-${dd}`;
            }

            function clearAlert() {
                const box = $alert();
                if (box) box.innerHTML = '';
            }

            function decodeHtmlEntities(str) {
                if (str == null) return '';
                let s = String(str);
                s = s.replace(/&#x([0-9a-fA-F]+);/g, (_, h) => String.fromCodePoint(parseInt(h, 16)));
                s = s.replace(/&#(\d+);/g, (_, d) => String.fromCodePoint(parseInt(d, 10)));
                s = s.replace(/&lt;/g, '<').replace(/&gt;/g, '>').replace(/&amp;/g, '&')
                    .replace(/&quot;/g, '"').replace(/&apos;/g, "'");
                return s;
            }

            const T = (m) => {
                if (m == null) return '';
                if (Array.isArray(m)) return m.map(T).join('\n');
                const s = String(m);
                const mapped = (window.__RESX && Object.prototype.hasOwnProperty.call(window.__RESX, s))
                    ? window.__RESX[s] : s;
                return decodeHtmlEntities(mapped);
            };

            const ok = m => {
                $alert()?.replaceChildren(
                    Object.assign(document.createElement('div'),
                        { className: 'alert alert-success', textContent: T(m) })
                );
            };

            const err = m => {
                $alert()?.replaceChildren(
                    Object.assign(document.createElement('div'),
                        { className: 'alert alert-danger', textContent: T(m || 'DOC_Err_SaveFailed') })
                );
            };

            function readJson(id) {
                try {
                    const el = document.getElementById(id);
                    if (!el) return {};
                    const raw = el.textContent || '';
                    const v = JSON.parse(raw);
                    return typeof v === 'string' ? JSON.parse(v) : v;
                } catch {
                    return {};
                }
            }

            function getTemplateCode() {
                const d1 = document.getElementById('doc-scroll')?.dataset?.templateCode?.trim();
                if (d1) return d1;
                const form = document.getElementById('doc-form');
                const v1 = form?.querySelector('input[name=TemplateCode]')?.value?.trim();
                if (v1) return v1;
                const v1b = form?.querySelector('input[name=templateCode]')?.value?.trim();
                if (v1b) return v1b;
                try {
                    const qs = new URLSearchParams(location.search);
                    const v2 = (qs.get('templateCode') || '').trim();
                    if (v2) return v2;
                } catch { }
                return (window.__tplFromServer || '').trim();
            }

            function markIntentionalLeave() {
                state.intentionalLeave = true;
                try { window.onbeforeunload = null; } catch { }
            }

            window.addEventListener('beforeunload', function () {
                if (state.intentionalLeave) return;
            }, true);

            async function getCsrf() {
                try {
                    const r = await fetch('/Doc/Csrf', { credentials: 'same-origin' });
                    if (!r.ok) return { headerName: 'RequestVerificationToken', token: '' };
                    return await r.json();
                } catch {
                    return { headerName: 'RequestVerificationToken', token: '' };
                }
            }

            async function deleteDxTemp() {
                const dxDocumentId = (window.__dxDocumentId || '').trim();
                if (!dxDocumentId) return;
                try {
                    const csrf = await getCsrf();
                    await fetch('/Doc/DeleteDxTemp', {
                        method: 'POST',
                        headers: {
                            'Content-Type': 'application/json',
                            [csrf.headerName]: csrf.token
                        },
                        credentials: 'same-origin',
                        keepalive: true,
                        body: JSON.stringify({ dxDocumentId })
                    });
                } catch {
                }
            }


            // ──────────────────────────────────────────
            // A1 좌표 변환
            // ──────────────────────────────────────────

            function normalizeSingleA1(a1) {
                const m = String(a1 || '').trim().toUpperCase().match(/^([A-Z]+)(\d+)$/);
                if (!m) return '';
                return m[1] + String(parseInt(m[2], 10));
            }

            function tryParseRange(a1) {
                const m = String(a1 || '').trim().toUpperCase().match(/^([A-Z]+)(\d+):([A-Z]+)(\d+)$/);
                if (!m) return null;
                return { c1: m[1], r1: parseInt(m[2], 10), c2: m[3], r2: parseInt(m[4], 10) };
            }

            function colLettersToNumber(col) {
                const s = String(col || '').trim().toUpperCase();
                if (!s || !/^[A-Z]+$/.test(s)) return 0;
                let n = 0;
                for (let i = 0; i < s.length; i++) n = (n * 26) + (s.charCodeAt(i) - 64);
                return n;
            }

            function columnNumberToLetters(num) {
                let n = parseInt(num, 10);
                if (!Number.isFinite(n) || n < 1) return '';
                let s = '';
                while (n > 0) {
                    const m = (n - 1) % 26;
                    s = String.fromCharCode(65 + m) + s;
                    n = Math.floor((n - 1) / 26);
                }
                return s;
            }

            function a1FromRowCol(row1, col1) {
                if (!Number.isFinite(row1) || !Number.isFinite(col1) || row1 < 1 || col1 < 1) return '';
                return columnNumberToLetters(col1) + row1;
            }

            function rowColFromA1(a1) {
                const m = normalizeSingleA1(a1).match(/^([A-Z]+)(\d+)$/);
                if (!m) return null;
                return { row1: parseInt(m[2], 10), col1: colLettersToNumber(m[1]) };
            }

            function expandRangeToSingles(a1) {
                const one = normalizeSingleA1(a1);
                if (one) return [one];
                const rg = tryParseRange(a1);
                if (!rg) return [];
                const left = Math.min(colLettersToNumber(rg.c1), colLettersToNumber(rg.c2));
                const right = Math.max(colLettersToNumber(rg.c1), colLettersToNumber(rg.c2));
                const top = Math.min(rg.r1, rg.r2);
                const bottom = Math.max(rg.r1, rg.r2);
                const out = [];
                for (let c = left; c <= right; c++)
                    for (let r = top; r <= bottom; r++)
                        out.push(columnNumberToLetters(c) + r);
                return out;
            }

            // ──────────────────────────────────────────
            // 크기 레이아웃 유틸
            // ──────────────────────────────────────────

            function excelColWidthToPx(w) {
                const n = Number(w);
                if (!isFinite(n) || n < 0) return 0;
                return Math.floor(n * 7 + 5);
            }

            function ptToPx(pt) {
                return ((Number(pt) || 0) * 96 / 72);
            }

            function hasVisibleStyle(st) {
                if (!st) return false;
                if (st.fill?.bg) return true;
                if (st.font && (st.font.bold || st.font.italic || st.font.underline || st.font.size || st.font.name)) return true;
                const b = st.border || {};
                return !!(
                    (b.l && b.l !== 'None') || (b.r && b.r !== 'None') ||
                    (b.t && b.t !== 'None') || (b.b && b.b !== 'None')
                );
            }

            function computePreviewExtent(preview) {
                const serverWidth = Number(state.serverExtent?.width || 0);
                const serverHeight = Number(state.serverExtent?.height || 0);
                const serverSafeWidth = Number(state.serverExtent?.safeWidth || 0);
                const serverSafeHeight = Number(state.serverExtent?.safeHeight || 0);
                const serverLastCol = Number(state.serverExtent?.lastCol || 0);

                if (serverWidth > 0 && serverHeight > 0) {
                    state._effectiveMaxC = Math.max(1, serverLastCol + 1);
                    state._colSum = Math.max(0, serverWidth - 12);

                    console.log('[DX] serverExtent mode=', state.serverExtent?.mode, 'lastA1=', state.serverExtent?.lastA1, 'width=', serverSafeWidth || serverWidth, 'height=', serverSafeHeight || serverHeight);

                    return {
                        width: serverSafeWidth > 0 ? serverSafeWidth : serverWidth,
                        height: serverSafeHeight > 0 ? serverSafeHeight : serverHeight
                    };
                }

                const p = preview || {};
                const styles = p.styles || {};
                const cells = Array.isArray(p.cells) ? p.cells : [];
                const merges = Array.isArray(p.merges) ? p.merges : [];
                const rowH = Array.isArray(p.rowH) ? p.rowH : [];
                const colW = Array.isArray(p.colW) ? p.colW : [];
                const colPx = Array.isArray(p.colPx) ? p.colPx : [];
                const rowPx = Array.isArray(p.rowPx) ? p.rowPx : [];

                let minR = Infinity, maxR = -Infinity, minC = Infinity, maxC = -Infinity;
                let contentMergeMaxC = 0;
                function mark(r, c) {
                    minR = Math.min(minR, r); maxR = Math.max(maxR, r);
                    minC = Math.min(minC, c); maxC = Math.max(maxC, c);
                }
                for (let r = 1; r <= cells.length; r++) {
                    const row = Array.isArray(cells[r - 1]) ? cells[r - 1] : [];
                    for (let c = 1; c <= row.length; c++) {
                        const v = row[c - 1];
                        if (v !== null && v !== undefined && v !== '' && String(v).trim() !== '') {
                            mark(r, c);
                            if (c > contentMergeMaxC) contentMergeMaxC = c;
                        }
                    }
                }
                for (const m of merges) {
                    if (!Array.isArray(m) || m.length < 4) continue;
                    const r1 = parseInt(m[0], 10) || 0, c1 = parseInt(m[1], 10) || 0;
                    const r2 = parseInt(m[2], 10) || 0, c2 = parseInt(m[3], 10) || 0;
                    if (r1 > 0 && c1 > 0) mark(r1, c1);
                    if (r2 > 0 && c2 > 0) mark(r2, c2);
                    if (c2 > contentMergeMaxC) contentMergeMaxC = c2;
                }
                if (contentMergeMaxC > 0) {
                    for (let r = 1; r <= cells.length; r++) {
                        for (let c = 1; c <= contentMergeMaxC; c++) {
                            const st = styles[`${r},${c}`];
                            if (!st) continue;
                            const b = st.border || {};
                            if ((b.l && b.l !== 'None') || (b.r && b.r !== 'None') ||
                                (b.t && b.t !== 'None') || (b.b && b.b !== 'None')) {
                                mark(r, c);
                            }
                        }
                    }
                }

                const contentMaxR = isFinite(maxR) ? maxR : (p.rows || 1);
                if (!isFinite(minR) || !isFinite(minC)) {
                    minR = 1; maxR = Math.max(1, p.rows || 1);
                    minC = 1; maxC = Math.max(1, p.cols || 1);
                } else {
                    maxR = Math.max(maxR, p.rows || maxR);
                }

                const maxColsFromCells = Math.max(...cells.map(r => Array.isArray(r) ? r.length : 0), 1);
                maxC = Math.min(Math.max(maxC, 1), maxColsFromCells);
                const effectiveMaxC = contentMergeMaxC || maxC || 1;
                minC = Math.max(minC, 1);
                state._effectiveMaxC = effectiveMaxC;

                let colSum = 0;
                for (let c = 1; c <= effectiveMaxC; c++) {
                    if (colPx[c - 1] > 0) {
                        colSum += colPx[c - 1];
                    } else {
                        colSum += Math.round(Number(colW[c - 1] ?? 8.43) * 7 + 5);
                    }
                }
                state._colSum = colSum;

                let height = 0;
                for (let r = minR; r <= maxR; r++) {
                    const px = rowPx[r - 1] > 0 ? rowPx[r - 1] : ((Number(rowH[r - 1]) || 0) * 96 / 72);
                    height += (r <= contentMaxR) ? px : px * 0.5;
                }

                console.log(`[DX] fallback contentMergeMaxC=${contentMergeMaxC}, effectiveMaxC=${effectiveMaxC}, colSum=${colSum}`);

                return {
                    width: Math.max(600, Math.ceil(colSum + 30 + 16)),
                    height: Math.max(520, Math.ceil(height + Math.max(80, Math.min(200, Math.ceil(height * 0.05)))))
                };
            }

            // ──────────────────────────────────────────
            // 편집 가능 셀 맵 구축
            // ──────────────────────────────────────────

            function buildEditableMap(descriptor) {
                const map = new Map();
                const byA1 = new Map();
                const dateSet = new Set();

                for (const f of (Array.isArray(descriptor?.inputs) ? descriptor.inputs : [])) {
                    const key = String(f?.key || '').trim();
                    const type = String(f?.type || 'Text').trim() || 'Text';
                    const a1 = String(f?.a1 || '').trim().toUpperCase();
                    if (!key || !a1) continue;

                    map.set(key, { key, type, a1 });

                    for (const one of expandRangeToSingles(a1)) {
                        if (!byA1.has(one)) byA1.set(one, { key, type, a1: one, sourceA1: a1 });
                        if (type.toLowerCase() === 'date') dateSet.add(one);
                    }
                }

                state.editableMap = map;
                state.editableByA1 = byA1;
                state.dateA1Set = dateSet;
            }

            // ──────────────────────────────────────────
            // DevExtreme 인스턴스
            // ──────────────────────────────────────────

            function getDxInstance() {
                const topWin = window.top || window;
                try {
                    if (topWin.dxComposeSheet) return topWin.dxComposeSheet;
                    if (topWin.dxSpreadsheet) return topWin.dxSpreadsheet;
                    if (topWin.dxSheet) return topWin.dxSheet;
                    if (topWin.DevExpress?.Spreadsheet?.getInstance) {
                        return topWin.DevExpress.Spreadsheet.getInstance('dxComposeSheet')
                            || topWin.DevExpress.Spreadsheet.getInstance('dxSpreadsheet')
                            || topWin.DevExpress.Spreadsheet.getInstance('dxSheet');
                    }
                } catch { }
                try {
                    if (window.dxComposeSheet) return window.dxComposeSheet;
                    if (window.dxSpreadsheet) return window.dxSpreadsheet;
                    if (window.dxSheet) return window.dxSheet;
                } catch { }
                return null;
            }

            function getDxSelection(inst) {
                if (!inst) return null;
                try {
                    if (typeof inst.getSelection === 'function') return inst.getSelection();
                    if (typeof inst.GetSelection === 'function') return inst.GetSelection();
                } catch { }
                return null;
            }

            function selectionToActiveA1(sel) {
                if (!sel) return '';
                const col0 = Number(sel.activeCellColumnIndex);
                const row0 = Number(sel.activeCellRowIndex);
                if (!Number.isFinite(col0) || !Number.isFinite(row0)) return '';
                return a1FromRowCol(row0 + 1, col0 + 1);
            }

            function refreshActiveSelection(inst) {
                const sel = getDxSelection(inst);
                state.activeSelection = sel;
                state.activeA1 = selectionToActiveA1(sel);
                return sel;
            }

            function trySetCellValueByIndex(inst, col0, row0, value) {
                if (!inst) return false;
                try {
                    if (typeof inst.SetCellValue === 'function') {
                        inst.SetCellValue(col0, row0, value);
                        state.dxDirtySinceLastSync = true;
                        return true;
                    }
                } catch { }
                return false;
            }

            function trySetCellValueByA1(inst, a1, value) {
                const rc = rowColFromA1(a1);
                if (!rc) return false;
                return trySetCellValueByIndex(inst, rc.col1 - 1, rc.row1 - 1, value);
            }

            function tryReadCellValue(inst, a1) {
                if (!inst || !a1) return { ok: false, value: '' };

                for (const fn of ['getCellValue', 'GetCellValue', 'getValue', 'GetValue', 'getCellText', 'GetCellText']) {
                    try {
                        if (typeof inst[fn] === 'function') {
                            const v = inst[fn](a1);
                            if (v !== undefined) return { ok: true, value: v };
                        }
                    } catch { }
                }

                const rc = rowColFromA1(a1);
                if (rc && typeof inst.getCellValue === 'function') {
                    try {
                        const v = inst.getCellValue(rc.col1 - 1, rc.row1 - 1);
                        if (v !== undefined) return { ok: true, value: v };
                    } catch { }
                }

                return { ok: false, value: '' };
            }

            function tryInvokeDxEditorCommit(inst) {
                if (!inst) return;
                for (const fn of ['applyCellEdit', 'ApplyCellEdit',
                                  'closeCellEditor', 'CloseCellEditor',
                                  'endEdit', 'EndEdit',
                                  'stopEditing', 'StopEditing']) {
                    try { if (typeof inst[fn] === 'function') { inst[fn](); return; } } catch { }
                }
            }

            // ──────────────────────────────────────────
            // DX 이벤트 바인딩
            // ──────────────────────────────────────────

            function bindDxStateEvents(inst) {
                if (!inst || inst.__composeDxStateBound) return;
                inst.__composeDxStateBound = true;

                function tryAdd(event, handler) {
                    try {
                        if (inst[event] && typeof inst[event].AddHandler === 'function')
                            inst[event].AddHandler(handler);
                    } catch { }
                }

                tryAdd('beginSynchronization', () => state.dxSyncDepth++);
                tryAdd('endSynchronization', () => {
                    state.dxSyncDepth = Math.max(0, state.dxSyncDepth - 1);
                    if (state.dxSyncDepth === 0) state.dxDirtySinceLastSync = false;
                });
                tryAdd('documentChanged', () => state.dxDirtySinceLastSync = true);
                tryAdd('selectionChanged', () => refreshActiveSelection(inst));

                tryAdd('CellBeginEdit', function (s, e) {
                    refreshActiveSelection(inst);
                    const a1 = state.activeA1 || '';
                    const meta = a1 ? state.editableByA1.get(a1) : null;

                    if (meta && String(meta.type || '').toLowerCase() === 'date') {
                        try { if (e && typeof e === 'object') e.cancel = true; } catch { }
                        state.dxEditing = false;
                        setTimeout(() =>
                            openDatePickerForA1(a1, state.lastDateAnchorEl || document.getElementById('dxComposeWrap'))
                        , 0);
                        return;
                    }

                    state.dxEditing = true;
                });

                tryAdd('CellEndEdit', () => {
                    state.dxEditing = false;
                    state.dxDirtySinceLastSync = true;
                    refreshActiveSelection(inst);
                });

                tryAdd('CellCancelEdit', () => {
                    state.dxEditing = false;
                    refreshActiveSelection(inst);
                });

                tryAdd('protectionWarning', function (s, e) {
                    try { if (e && typeof e === 'object') e.cancel = true; } catch { }
                });
            }

            function installKeyBlocker(target) {
                if (!target || target.__keyBlockerBound) return;
                target.__keyBlockerBound = true;

                target.addEventListener('keydown', function (e) {

                    if ((e.ctrlKey || e.metaKey) && e.key === 'a') return;

                    const isDelete = e.key === 'Delete' || e.key === 'Backspace';
                    const isCut = (e.ctrlKey || e.metaKey) && e.key === 'x';
                    const isUndo = (e.ctrlKey || e.metaKey) && (e.key === 'z' || e.key === 'y');

                    if (!isDelete && !isCut && !isUndo) return;

                    if (state.dxEditing) return;

                    const ae = document.activeElement
                            || (typeof target.activeElement !== 'undefined' ? target.activeElement : null);
                    if (ae) {
                        const tag = (ae.tagName || '').toLowerCase();
                        if (tag === 'input' || tag === 'textarea') return;
                        if (ae.getAttribute('contenteditable') === 'true') return;
                        try {
                            const itFrame = document.getElementById('dxComposeSheet_IT');
                            if (itFrame) {
                                const iDoc = itFrame.contentDocument || itFrame.contentWindow?.document;
                                if (iDoc) {
                                    const iAe = iDoc.activeElement;
                                    if (iAe) {
                                        const iTag = (iAe.tagName || '').toLowerCase();
                                        if (iTag === 'input' || iTag === 'textarea') return;
                                        if (iAe.getAttribute('contenteditable') === 'true') return;
                                        if (iAe.closest && iAe.closest('.dxss-cell-editor, .dxss-input-bar, [class*="dxss-edit"]')) return;
                                    }
                                }
                            }
                        } catch { }
                    }

                    const inst = getDxInstance();
                    if (inst) refreshActiveSelection(inst);

                    const activeA1 = state.activeA1 || '';

                    if (isDelete || isCut) {
                        const inst2 = getDxInstance();
                        if (!inst2) return;

                        let sel = null;
                        try {
                            if (typeof inst2.getSelection === 'function') sel = inst2.getSelection();
                            else if (typeof inst2.GetSelection === 'function') sel = inst2.GetSelection();
                        } catch { }
                        if (!sel) sel = state.activeSelection;

                        const r1 = Number(sel?.topRowIndex ?? sel?.activeCellRowIndex ?? -1);
                        const r2 = Number(sel?.bottomRowIndex ?? sel?.activeCellRowIndex ?? -1);
                        const c1 = Number(sel?.leftColumnIndex ?? sel?.activeCellColumnIndex ?? -1);
                        const c2 = Number(sel?.rightColumnIndex ?? sel?.activeCellColumnIndex ?? -1);

                        const isRangeSelection = (r2 - r1) > 0 || (c2 - c1) > 0;

                        if (isRangeSelection) {
                            e.preventDefault();
                            e.stopPropagation();
                            if (typeof e.stopImmediatePropagation === 'function') e.stopImmediatePropagation();

                            dxBatchUpdate(inst2, () => {
                                let cleared = false;
                                for (const [a1, meta] of state.editableByA1.entries()) {
                                    if (String(meta.type || '').toLowerCase() === 'date') continue;
                                    const rc = rowColFromA1(a1);
                                    if (!rc) continue;
                                    const r0 = rc.row1 - 1;
                                    const c0 = rc.col1 - 1;
                                    const inRange = (r2 - r1 > 200)
                                        ? true
                                        : (r0 >= r1 && r0 <= r2 && c0 >= c1 && c0 <= c2);
                                    if (inRange) {
                                        trySetCellValueByIndex(inst2, c0, r0, '');
                                        cleared = true;
                                    }
                                }
                                if (cleared) {
                                    tryInvokeDxEditorCommit(inst2);
                                    state.dxDirtySinceLastSync = true;
                                }
                            });
                            return;
                        }

                        if (activeA1 && state.dateA1Set.has(activeA1)) {
                            e.preventDefault();
                            e.stopPropagation();
                            if (typeof e.stopImmediatePropagation === 'function') e.stopImmediatePropagation();
                            return;
                        }

                        if (activeA1 && state.editableByA1.has(activeA1)) return;
                        if (!activeA1 && state.editableByA1.size > 0) return;

                        e.preventDefault();
                        e.stopPropagation();
                        if (typeof e.stopImmediatePropagation === 'function') e.stopImmediatePropagation();
                        return;
                    }

                    if (isUndo) {
                        if (activeA1 && state.editableByA1.has(activeA1) && !state.dateA1Set.has(activeA1)) return;
                        if (!activeA1) return;
                        e.preventDefault();
                        e.stopPropagation();
                        if (typeof e.stopImmediatePropagation === 'function') e.stopImmediatePropagation();
                    }

                }, true);
            }

            function dxBatchUpdate(inst, fn) {
                const wrap = document.getElementById('dxComposeWrap');
                const frame = document.getElementById('dxComposeSheet_IT');

                if (wrap) {
                    wrap.style.transform = 'translateZ(0)';
                    wrap.style.isolation = 'isolate';
                    wrap.style.contain = 'strict';
                }
                if (frame) {
                    frame.style.transform = 'translateZ(0)';
                }

                try {
                    fn();
                } finally {
                    requestAnimationFrame(() => {
                        if (wrap) {
                            wrap.style.transform = '';
                            wrap.style.isolation = '';
                            wrap.style.contain = '';
                        }
                        if (frame) {
                            frame.style.transform = '';
                        }
                    });
                }
            }

            function selectionContainsAnyEditable() {
                const inst = getDxInstance();
                if (!inst) return false;

                let sel = null;
                try {
                    if (typeof inst.getSelection === 'function') sel = inst.getSelection();
                    else if (typeof inst.GetSelection === 'function') sel = inst.GetSelection();
                } catch { }
                if (!sel) sel = state.activeSelection;
                if (!sel) return false;

                const r1 = Number(sel.topRowIndex ?? sel.startRowIndex ?? sel.activeCellRowIndex ?? -1);
                const r2 = Number(sel.bottomRowIndex ?? sel.endRowIndex ?? sel.activeCellRowIndex ?? -1);
                const c1 = Number(sel.leftColumnIndex ?? sel.startColumnIndex ?? sel.activeCellColumnIndex ?? -1);
                const c2 = Number(sel.rightColumnIndex ?? sel.endColumnIndex ?? sel.activeCellColumnIndex ?? -1);

                if (r1 < 0 || c1 < 0) return state.editableByA1.size > 0;

                if ((r2 - r1) > 200 || (c2 - c1) > 200) {
                    return state.editableByA1.size > 0;
                }

                for (let r = r1; r <= r2; r++) {
                    for (let c = c1; c <= c2; c++) {
                        const a1 = a1FromRowCol(r + 1, c + 1);
                        if (state.editableByA1.has(a1) && !state.dateA1Set.has(a1)) return true;
                    }
                }
                return false;
            }

            // ──────────────────────────────────────────
            // 에디터 플러시 아이들 대기
            // ──────────────────────────────────────────

            function getActiveDxEditorElement() {
                const host = document.getElementById('dxComposeWrap');
                if (!host) return null;

                const selectors = [
                    'input', 'textarea', '[contenteditable="true"]',
                    '.dx-texteditor-input', '.dxss-input-bar input',
                    '.dxss-cell-editor', '.dxss-cell-editor input', '.dxss-cell-editor textarea'
                ];

                for (const sel of selectors) {
                    const el = host.querySelector(sel);
                    if (el && document.activeElement === el) return el;
                }

                const ae = document.activeElement;
                return (ae && host.contains(ae)) ? ae : null;
            }

            function delay(ms) {
                return new Promise(resolve => setTimeout(resolve, ms));
            }

            async function waitForDxIdle(timeoutMs) {
                const started = Date.now();
                while ((Date.now() - started) < timeoutMs) {
                    if (!state.dxEditing && state.dxSyncDepth === 0 && !state.dxDirtySinceLastSync) {
                        await new Promise(requestAnimationFrame);
                        if (!state.dxEditing && state.dxSyncDepth === 0 && !state.dxDirtySinceLastSync)
                            return true;
                    }
                    await delay(40);
                }
                return false;
            }

            async function flushDxEditing() {
                const inst = getDxInstance();
                const sink = document.getElementById('dxCommitSink');
                const host = document.getElementById('dxComposeWrap');

                bindDxStateEvents(inst);

                const editor = getActiveDxEditorElement();
                if (editor) {
                    try { editor.dispatchEvent(new KeyboardEvent('keydown', { key: 'Enter', code: 'Enter', which: 13, keyCode: 13, bubbles: true })); } catch { }
                    try { editor.dispatchEvent(new KeyboardEvent('keyup', { key: 'Enter', code: 'Enter', which: 13, keyCode: 13, bubbles: true })); } catch { }
                    try { editor.dispatchEvent(new Event('change', { bubbles: true })); } catch { }
                    try { if (typeof editor.blur === 'function') editor.blur(); } catch { }
                }

                try { if (sink) sink.focus({ preventScroll: true }); } catch { }

                tryInvokeDxEditorCommit(inst);
                await new Promise(requestAnimationFrame);
                await new Promise(requestAnimationFrame);
                await delay(120);

                try {
                    const ae = document.activeElement;
                    if (ae && host && host.contains(ae) && typeof ae.blur === 'function') ae.blur();
                } catch { }

                tryInvokeDxEditorCommit(inst);
                await waitForDxIdle(1500);

                return true;
            }

            function ensureSaveCommitStarted() {
                if (!state.saveCommitPromise) {
                    state.saveCommitPromise = flushDxEditing().finally(() => {
                        state.saveCommitPromise = null;
                    });
                }
                return state.saveCommitPromise;
            }

            // ──────────────────────────────────────────
            // 날짜 처리
            // ──────────────────────────────────────────

            function getCurrentUiCulture() {
                return SERVER_UI_CULTURE || 'ko-KR';
            }

            function formatDateForCurrentUiCulture(ymd) {
                const m = String(ymd || '').match(/^(\d{4})-(\d{2})-(\d{2})$/);
                if (!m) return String(ymd || '');
                const [, y, mm, dd] = m;
                switch (getCurrentUiCulture()) {
                    case 'en-US': return `${parseInt(mm, 10)}/${parseInt(dd, 10)}/${y}`;
                    case 'vi-VN':
                    case 'id-ID': return `${parseInt(dd, 10)}/${parseInt(mm, 10)}/${y}`;
                    case 'zh-CN': return `${y}/${parseInt(mm, 10)}/${parseInt(dd, 10)}`;
                    default: return `${y}-${mm}-${dd}`;
                }
            }

            function parseDateTextByCurrentUiCulture(raw) {
                const s = String(raw || '').trim().replace(/^'/, '');
                if (!s) return '';

                let m;

                m = s.match(/^(\d{4})-(\d{1,2})-(\d{1,2})$/);
                if (m) return `${m[1]}-${m[2].padStart(2,'0')}-${m[3].padStart(2,'0')}`;

                m = s.match(/^(\d{4})[./](\d{1,2})[./](\d{1,2})\.?$/);
                if (m) return `${m[1]}-${m[2].padStart(2,'0')}-${m[3].padStart(2,'0')}`;

                m = s.match(/^(\d{1,2})\/(\d{1,2})\/(\d{4})$/);
                if (m) {
                    const [month, day] = getCurrentUiCulture() === 'en-US'
                        ? [m[1], m[2]]
                        : [m[2], m[1]];
                    return `${m[3]}-${String(month).padStart(2,'0')}-${String(day).padStart(2,'0')}`;
                }

                m = s.match(/^(\d{4})\.\s*(\d{1,2})\.\s*(\d{1,2})\.?$/);
                if (m) return `${m[1]}-${m[2].padStart(2,'0')}-${m[3].padStart(2,'0')}`;

                return '';
            }

            function normalizeDxValueByType(type, raw) {
                const t = String(type || 'Text').toLowerCase();
                if (raw == null) return '';

                if (t === 'date') {
                    if (raw instanceof Date && !isNaN(raw.getTime())) {
                        const y = raw.getFullYear();
                        const m = String(raw.getMonth() + 1).padStart(2, '0');
                        const d = String(raw.getDate()).padStart(2, '0');
                        return `${y}-${m}-${d}`;
                    }
                    const ymd = parseDateTextByCurrentUiCulture(raw);
                    return ymd || String(raw).trim();
                }

                if (t === 'num' || t === 'number') {
                    const s = String(raw).trim();
                    if (!s) return '';
                    const normalized = s.replace(/,/g, '');
                    return /^-?\d+(\.\d+)?$/.test(normalized) ? normalized : s;
                }

                return String(raw);
            }

            function setDateDisplayTextCell(inst, a1, ymd) {
                if (!inst || !a1 || !ymd) return false;
                return trySetCellValueByA1(inst, a1, "'" + formatDateForCurrentUiCulture(ymd));
            }

            function initDefaultDateValues() {
                if (state.dateDefaultsApplied) return;
                const inst = getDxInstance();
                if (!inst) return;

                const todayYmd = getTodayYmd();
                let changed = false;

                for (const a1 of state.dateA1Set) {
                    const got = tryReadCellValue(inst, a1);
                    if (!normalizeDxValueByType('date', got.value)) {
                        if (setDateDisplayTextCell(inst, a1, todayYmd)) changed = true;
                    }
                }

                if (changed) {
                    tryInvokeDxEditorCommit(inst);
                    state.dxDirtySinceLastSync = true;
                }

                state.dateDefaultsApplied = true;
            }

            // ──────────────────────────────────────────
            // DatePicker 브리지
            // ──────────────────────────────────────────

            function resolveDateAnchorElement(rawTarget) {
                const wrap = document.getElementById('dxComposeWrap');
                let el = rawTarget instanceof Element ? rawTarget : null;
                if (!wrap) return null;

                while (el && el !== wrap) {
                    const rect = el.getBoundingClientRect();
                    if (rect && rect.width >= 24 && rect.height >= 18 && rect.width <= 220 && rect.height <= 80)
                        return el;
                    el = el.parentElement;
                }
                return wrap;
            }

            function placeDateBridgeNearAnchor(anchorEl) {
                const bridge = document.getElementById('dxDatePickerBridge');
                if (!bridge) return;

                const anchor = (anchorEl instanceof Element)
                    ? anchorEl
                    : (state.lastDateAnchorEl instanceof Element
                        ? state.lastDateAnchorEl
                        : document.getElementById('dxComposeWrap'));

                const rect = anchor.getBoundingClientRect();
                let left = Math.round(rect.left + 1);
                let top = Math.round(rect.bottom - 1);

                left = Math.min(Math.max(2, left), Math.max(2, window.innerWidth - 3));
                top = Math.min(Math.max(2, top), Math.max(2, window.innerHeight - 3));

                Object.assign(bridge.style, {
                    left: left + 'px', top: top + 'px',
                    width: '1px', height: '1px',
                    opacity: '0.01', pointerEvents: 'auto'
                });
            }

            function hideDateBridgeOffscreen() {
                const bridge = document.getElementById('dxDatePickerBridge');
                if (!bridge) return;
                Object.assign(bridge.style, {
                    left: '-10000px', top: '-10000px',
                    width: '1px', height: '1px',
                    opacity: '0.01', pointerEvents: 'auto'
                });
            }

            function installDatePickerBridge() {
                const bridge = document.getElementById('dxDatePickerBridge');
                if (!bridge || bridge.__bound) return;
                bridge.__bound = true;

                bridge.addEventListener('change', function () {
                    try {
                        const a1 = state.lastDatePopupA1 || state.activeA1 || '';
                        const value = String(bridge.value || '').trim();
                        if (!a1 || !value) return;

                        const inst = getDxInstance();
                        if (!inst) return;

                        if (setDateDisplayTextCell(inst, a1, value)) {
                            tryInvokeDxEditorCommit(inst);
                            state.dxDirtySinceLastSync = true;
                        }
                    } finally {
                        state.datePickerOpen = false;
                        hideDateBridgeOffscreen();
                    }
                });

                bridge.addEventListener('blur', function () {
                    setTimeout(() => {
                        state.datePickerOpen = false;
                        hideDateBridgeOffscreen();
                    }, 50);
                });
            }

            function openDatePickerForA1(a1, anchorEl) {
                const bridge = document.getElementById('dxDatePickerBridge');
                const inst = getDxInstance();
                if (!bridge || !inst || !a1) return;
                if (!state.dateA1Set.has(a1) || state.datePickerOpen) return;

                const got = tryReadCellValue(inst, a1);
                const ymd = normalizeDxValueByType('date', got.value);

                state.datePickerOpen = true;
                state.lastDatePopupA1 = a1;
                if (anchorEl instanceof Element) state.lastDateAnchorEl = anchorEl;

                bridge.value = /^\d{4}-\d{2}-\d{2}$/.test(ymd) ? ymd : '';
                placeDateBridgeNearAnchor(state.lastDateAnchorEl);

                try { bridge.focus({ preventScroll: true }); } catch { }

                try {
                    if (typeof bridge.showPicker === 'function') bridge.showPicker();
                    else bridge.click();
                } catch (ex) {
                    console.warn('[DXDBG] showPicker failed', ex);
                    state.datePickerOpen = false;
                    hideDateBridgeOffscreen();
                }
            }

            function bindDatePickerOpenBridge() {
                if (state.dateBridgeBound) return;
                const wrap = document.getElementById('dxComposeWrap');
                if (!wrap) return;
                state.dateBridgeBound = true;

                function openFromEvent(evt) {
                    const inst = getDxInstance();
                    if (!inst) return;
                    refreshActiveSelection(inst);
                    const a1 = state.activeA1 || '';
                    if (!a1 || !state.dateA1Set.has(a1)) return;
                    openDatePickerForA1(a1, resolveDateAnchorElement(evt?.target || null));
                }

                wrap.addEventListener('pointerup', openFromEvent, true);
                wrap.addEventListener('click', openFromEvent, true);

                wrap.addEventListener('keydown', function (e) {
                    const inst = getDxInstance();
                    if (!inst) return;
                    refreshActiveSelection(inst);
                    const a1 = state.activeA1 || '';
                    if (!a1 || !state.dateA1Set.has(a1)) return;

                    const key = String(e.key || '');
                    const shouldBlock = key === 'Enter' || key === 'F2' || key === 'Backspace'
                        || key === 'Delete' || key.length === 1;
                    if (!shouldBlock) return;

                    e.preventDefault();
                    e.stopPropagation();
                    if (typeof e.stopImmediatePropagation === 'function') e.stopImmediatePropagation();
                    openFromEvent({ target: e.target || wrap });
                }, true);

                wrap.addEventListener('beforeinput', function (e) {
                    const inst = getDxInstance();
                    if (!inst) return;
                    refreshActiveSelection(inst);
                    const a1 = state.activeA1 || '';
                    if (!a1 || !state.dateA1Set.has(a1)) return;

                    e.preventDefault();
                    if (typeof e.stopImmediatePropagation === 'function') e.stopImmediatePropagation();
                    if (!state.datePickerOpen) openFromEvent({ target: e.target || wrap });
                }, true);
            }

            // ──────────────────────────────────────────
            // DX 레이아웃
            // ──────────────────────────────────────────

            function applyDxWrapSize() {
                const wrap = document.getElementById('dxComposeWrap');
                const ext = computePreviewExtent(state.preview);
                state.previewExtent = ext;
                wrap.style.setProperty('height', ext.height + 'px', 'important');
                wrap.style.setProperty('min-height', ext.height + 'px', 'important');
                wrap.style.setProperty('width', ext.width + 'px', 'important');
                wrap.style.setProperty('min-width', ext.width + 'px', 'important');
                wrap.style.setProperty('max-width', ext.width + 'px', 'important');
                wrap.style.setProperty('overflow', 'hidden', 'important');
                console.log('[DX] applyDxWrapSize:', { width: ext.width, height: ext.height, mode: state.serverExtent?.mode, lastA1: state.serverExtent?.lastA1 });
            }

            function clampDxHorizontalExtent() {
                const wrap = document.getElementById('dxComposeWrap');
                if (!wrap) return;

                const previewWidth = Number(state.previewExtent?.width || 0);
                const serverSafeWidth = Number(state.serverExtent?.safeWidth || 0);
                const serverWidth = Number(state.serverExtent?.width || 0);
                const finalWidth = previewWidth > 0
                    ? previewWidth
                    : (serverSafeWidth > 0 ? serverSafeWidth : (serverWidth > 0 ? serverWidth : 900));

                wrap.style.setProperty('width', finalWidth + 'px', 'important');
                wrap.style.setProperty('min-width', finalWidth + 'px', 'important');
                wrap.style.setProperty('max-width', finalWidth + 'px', 'important');

                const inner =
                    document.getElementById('dxComposeSheet_ScrollContainer')
                    || document.getElementById('dxComposeSheet_Grid')
                    || $('[id$="_ScrollContainer"]', wrap)
                    || $('[id$="_Grid"]', wrap);
                if (inner) { inner.scrollLeft = 0; inner.scrollTop = 0; }
            }

            function installOuterScrollOnly() {
                const outer = document.getElementById('doc-scroll');
                const wrap = document.getElementById('dxComposeWrap');
                if (!outer || !wrap) return;

                const inner =
                    document.getElementById('dxComposeSheet_ScrollContainer')
                    || document.getElementById('dxComposeSheet_Grid')
                    || $('[id$="_ScrollContainer"]', wrap)
                    || $('[id$="_Grid"]', wrap);

                if (!inner) return;

                function lockInnerScroll() {
                    if (inner.scrollTop !== 0) inner.scrollTop = 0;
                    if (inner.scrollLeft !== 0) inner.scrollLeft = 0;
                }

                lockInnerScroll();
                inner.addEventListener('scroll', lockInnerScroll, { passive: true });

                if (!window.__COMPOSE_DX_OUTER_WHEEL_INSTALLED__) {
                    window.__COMPOSE_DX_OUTER_WHEEL_INSTALLED__ = true;
                    document.addEventListener('wheel', function (e) {
                        if (!wrap.contains(e.target)) return;
                        e.preventDefault();
                        lockInnerScroll();
                        if (e.deltaY) outer.scrollTop += e.deltaY;
                        if (e.deltaX) outer.scrollLeft += e.deltaX;
                    }, { capture: true, passive: false });
                }
            }

            // ──────────────────────────────────────────
            // 입력값 수집
            // ──────────────────────────────────────────

            async function collectInputsFromDx() {
                const inst = getDxInstance();
                bindDxStateEvents(inst);
                await ensureSaveCommitStarted();
                await waitForDxIdle(1500);

                const result = {};
                for (const [key, meta] of state.editableMap.entries()) {
                    const one = normalizeSingleA1(meta.a1);
                    if (one) {
                        const got = tryReadCellValue(inst, one);
                        result[key] = normalizeDxValueByType(meta.type, got.value);
                        continue;
                    }

                    const singles = expandRangeToSingles(meta.a1);
                    if (!singles.length) { result[key] = ''; continue; }

                    result[key] = singles
                        .map(a1 => normalizeDxValueByType(meta.type, tryReadCellValue(inst, a1).value))
                        .join('\n');
                }
                return result;
            }

            // ──────────────────────────────────────────
            // 파일 첨부 UI
            // ──────────────────────────────────────────

            function sigOfFile(f) {
                return String(f?.name || '').trim().toLowerCase() + '|' + (Number(f?.size || 0) || 0);
            }

            function dedupeFilesKeepFirst(files) {
                const seen = new Set();
                const out = [];
                for (const f of (files || [])) {
                    if (!f) continue;
                    const sig = sigOfFile(f);
                    if (!sig || seen.has(sig)) continue;
                    seen.add(sig);
                    out.push(f);
                }
                return out;
            }

            function setFileInputFiles(inputEl, filesArr) {
                try {
                    const dt = new DataTransfer();
                    for (const f of (filesArr || [])) dt.items.add(f);
                    inputEl.files = dt.files;
                    return true;
                } catch { return false; }
            }

            function removePickedFileBySig(sig) {
                const inp = document.getElementById('doc-attachments');
                if (!inp) return false;

                const cur = Array.from(inp.files || []);
                if (!cur.length) return false;

                let removed = false;
                const next = cur.filter(f => {
                    if (!removed && sigOfFile(f) === sig) { removed = true; return false; }
                    return true;
                });

                return removed ? setFileInputFiles(inp, next) : false;
            }

            function setAttachCount(n) {
                const el = document.getElementById('doc-attach-count');
                if (!el) return;

                const v = Math.max(0, Number(n || 0) || 0);
                const noneText = window.__RESX?.['DOC_Attach_Count_None'] ?? '';
                const nTextTmpl = window.__RESX?.['DOC_Attach_Count_N'] ?? '';

                if (v === 0) { el.textContent = noneText; return; }
                el.textContent = nTextTmpl.includes('{0}')
                    ? nTextTmpl.replace('{0}', String(v))
                    : String(v);
            }

            function renderAttachListFromInput() {
                const box = document.getElementById('doc-attach-list');
                if (!box) return;

                const fileInput = document.getElementById('doc-attachments');
                const picked = dedupeFilesKeepFirst(Array.from(fileInput?.files || []));
                const failedArr = Array.isArray(state.filesFailed) ? state.filesFailed : [];

                setAttachCount(picked.length + failedArr.length);
                box.innerHTML = '';
                if (!picked.length && !failedArr.length) return;

                const wrap = Object.assign(document.createElement('div'), {
                    style: 'display:flex;flex-direction:column;gap:6px'
                });

                function makeRow(text, extra = '') {
                    const row = Object.assign(document.createElement('div'), {
                        style: 'display:flex;align-items:center;gap:8px;max-width:100%' + extra
                    });
                    const span = Object.assign(document.createElement('span'), {
                        style: 'flex:1 1 auto;min-width:0;overflow:hidden;text-overflow:ellipsis;white-space:nowrap'
                    });
                    row.appendChild(span);
                    return { row, span };
                }

                for (const f of picked) {
                    const { row, span } = makeRow('');
                    span.textContent = `${f.name} (${Number(f.size || 0) || 0})`;

                    const delBtn = Object.assign(document.createElement('button'), {
                        type: 'button',
                        className: 'btn btn-outline-secondary',
                        style: 'height:28px;padding:0 10px',
                        textContent: T('_CM_Delete')
                    });

                    const sig = sigOfFile(f);
                    delBtn.addEventListener('click', e => {
                        e.preventDefault(); e.stopPropagation();
                        if (removePickedFileBySig(sig)) renderAttachListFromInput();
                    });

                    row.appendChild(delBtn);
                    wrap.appendChild(row);
                }

                for (const ff of failedArr) {
                    const { row, span } = makeRow(';opacity:0.75');
                    const errKey = ff?.error ? String(ff.error) : 'DOC_Err_UploadFailed';
                    const nm = String(ff?.name || '').trim();
                    span.textContent = `${nm} (${Number(ff?.size || 0) || 0}) • ${T(errKey)}`;
                    wrap.appendChild(row);
                }

                box.appendChild(wrap);
            }

            function hookAttachmentUi() {
                const fileInput = document.getElementById('doc-attachments');
                const pickBtn = document.getElementById('doc-attach-pick');

                pickBtn?.addEventListener('click', e => {
                    e.preventDefault(); e.stopPropagation();
                    if (!fileInput) return;
                    state.fileCache = dedupeFilesKeepFirst(Array.from(fileInput.files || []));
                    try { fileInput.click(); } catch { }
                });

                fileInput?.addEventListener('change', () => {
                    state.filesFailed = [];
                    const merged = dedupeFilesKeepFirst([
                        ...(state.fileCache || []),
                        ...Array.from(fileInput.files || [])
                    ]);
                    setFileInputFiles(fileInput, merged);
                    state.fileCache = [];
                    renderAttachListFromInput();
                });

                renderAttachListFromInput();
            }

            // ──────────────────────────────────────────
            // 수신자 결재 저장
            // ──────────────────────────────────────────

            function collectSelectedRecipientUserIds() {
                function uniq(list) {
                    const seen = new Set(), out = [];
                    for (const raw of (list || [])) {
                        const s = String(raw || '').trim();
                        if (!s) continue;
                        const k = s.toLowerCase();
                        if (seen.has(k)) continue;
                        seen.add(k);
                        out.push(s);
                    }
                    return out;
                }

                function parseRaw(raw) {
                    raw = String(raw || '').trim();
                    if (!raw) return [];
                    if (raw.startsWith('[')) {
                        try {
                            const arr = JSON.parse(raw);
                            if (Array.isArray(arr)) return uniq(arr.map(x => String(x || '').trim()).filter(Boolean));
                        } catch { }
                    }
                    return uniq(raw.split(/[,\s;]+/g).map(s => (s || '').trim()).filter(Boolean));
                }

                const root = document.getElementById('doc-recipient-select');
                if (root) {
                    const one =
                        root.querySelector('input[name="SelectedRecipientUserIds"]')?.value ||
                        root.querySelector('textarea[name="SelectedRecipientUserIds"]')?.value || '';
                    const parsed = parseRaw(one);
                    if (parsed.length) return parsed;

                    const ds = root.getAttribute('data-selected') || root.dataset?.selected || '';
                    const parsedDs = parseRaw(ds);
                    if (parsedDs.length) return parsedDs;
                }
                return [];
            }

            function buildApprovalsForPost() {
                const approvals = Array.isArray(state.descriptor?.approvals) ? state.descriptor.approvals : [];
                let seq = 1;
                return {
                    steps: approvals.map(a => ({
                        roleKey: `A${seq++}`,
                        approverType: String(a?.approverType || a?.ApproverType || 'Person').trim() || 'Person',
                        required: !!a?.required,
                        value: String(a?.value || a?.ApproverValue || a?.approverValue || '').trim()
                    }))
                };
            }

            function buildCooperationsForPost() {
                const cooperations = Array.isArray(state.descriptor?.cooperations)
                    ? state.descriptor.cooperations
                    : (Array.isArray(state.descriptor?.Cooperations)
                        ? state.descriptor.Cooperations
                        : []);
                let seq = 1;
                return {
                    steps: cooperations.map(c => ({
                        roleKey: c?.roleKey || c?.RoleKey || `C${seq++}`,
                        approverType: String(c?.approverType || c?.ApproverType || 'Person').trim() || 'Person',
                        lineType: String(c?.lineType || c?.LineType || 'Cooperation').trim() || 'Cooperation',
                        value: String(c?.value || c?.ApproverValue || c?.approverValue || '').trim()
                    }))
                };
            }

            function buildRequestBody(templateCode, inputs) {
                const selectedIds = collectSelectedRecipientUserIds();
                return {
                    templateCode,
                    inputs,
                    approvals: buildApprovalsForPost(),
                    cooperations: buildCooperationsForPost(),
                    mail: { to: [], cc: [], bcc: [], subject: '', body: '', send: true, from: null },
                    SelectedRecipientUserIds: selectedIds,
                    selectedRecipientUserIds: selectedIds
                };
            }

            async function saveDocument() {
                const submitBtn = document.getElementById('btn-save');
                const fileInput = document.getElementById('doc-attachments');
                const picked = dedupeFilesKeepFirst(Array.from(fileInput?.files || []));
                const tpl = (getTemplateCode() || '').trim();

                if (!tpl) { err('DOC_Val_TemplateRequired'); return; }

                submitBtn.disabled = true;

                try {
                    const inputs = await collectInputsFromDx();
                    const bodyObj = buildRequestBody(tpl, inputs);
                    const csrf = await getCsrf();

                    const r = await fetch('/Doc/CreateDX', {
                        method: 'POST',
                        headers: {
                            'Content-Type': 'application/json',
                            [csrf.headerName]: csrf.token
                        },
                        credentials: 'same-origin',
                        body: JSON.stringify(bodyObj)
                    });

                    const res = await r.json().catch(() => null);
                    if (!r.ok || !res) {
                        const msgs = Array.isArray(res?.messages) ? res.messages : null;
                        err(msgs?.length ? msgs : 'DOC_Err_SaveFailed');
                        submitBtn.disabled = false;
                        return;
                    }

                    const docId = (res.docId || res.DocId || '').toString().trim();
                    if (!docId) {
                        err('DOC_Err_SaveFailed');
                        submitBtn.disabled = false;
                        return;
                    }

                    if (picked.length) {
                        const fd = new FormData();
                        for (const f of picked) fd.append('files', f, f.name);
                        if (csrf?.token) fd.append('__RequestVerificationToken', csrf.token);

                        const up = await fetch('/Doc/Upload?docId=' + encodeURIComponent(docId), {
                            method: 'POST',
                            headers: { [csrf.headerName]: csrf.token },
                            credentials: 'same-origin',
                            body: fd
                        });
                        const upRes = await up.json().catch(() => null);
                        if (!up.ok || !upRes) {
                            err('DOC_Err_UploadFailed');
                            submitBtn.disabled = false;
                            return;
                        }
                    }

                    ok('DOC_Msg_Saved');
                    markIntentionalLeave();
                    await deleteDxTemp();

                    try {
                        const u = new URL(location.origin + '/Doc/DetailDX');
                        u.searchParams.set('id', docId);
                        location.href = u.toString();
                    } catch {
                        location.href = '/Doc/DetailDX?id=' + encodeURIComponent(docId);
                    }
                } catch (ex) {
                    console.error(ex);
                    err('DOC_Err_SaveFailed');
                    submitBtn.disabled = false;
                }
            }

            // ──────────────────────────────────────────
            // 배경색 복원
            // ──────────────────────────────────────────

            const EDITABLE_BG = '#EAF6FF';
            const EDITABLE_BG_RGB = 'rgb(234, 246, 255)';

            let _bgCtbIds = new Set();

            function paintCtbBg(el) {
                if (!el) return;
                if (el.id && _bgCtbIds.has(el.id)) {
                    el.style.setProperty('background-color', EDITABLE_BG, 'important');
                    el.querySelectorAll('.dxss-ftc').forEach(function (ftc) {
                        ftc.style.setProperty('background-color', EDITABLE_BG, 'important');
                    });
                    return;
                }
                if (el.classList && el.classList.contains('dxss-ftc')) {
                    const ctb = el.closest('[id*="dxComposeSheet_ctb."]');
                    if (ctb && _bgCtbIds.has(ctb.id)) {
                        el.style.setProperty('background-color', EDITABLE_BG, 'important');
                    }
                }
            }

            function buildBgCtbIds() {
                const wrap = document.getElementById('dxComposeWrap');
                if (!wrap) return false;

                const found = new Set();

                wrap.querySelectorAll('[id*="dxComposeSheet_ctb."]').forEach(function (el) {
                    const cs = window.getComputedStyle(el).backgroundColor;
                    if (cs === EDITABLE_BG_RGB) found.add(el.id);
                });

                wrap.querySelectorAll('.dxss-ftc').forEach(function (ftc) {
                    const cs = window.getComputedStyle(ftc).backgroundColor;
                    if (cs === EDITABLE_BG_RGB) {
                        const ctb = ftc.closest('[id*="dxComposeSheet_ctb."]');
                        if (ctb) found.add(ctb.id);
                    }
                });

                if (found.size > 0) {
                    _bgCtbIds = found;
                    return true;
                }
                return false;
            }

            function restoreAllBg() {
                const wrap = document.getElementById('dxComposeWrap');
                if (!wrap || !_bgCtbIds.size) return;
                _bgCtbIds.forEach(function (id) {
                    const el = document.getElementById(id);
                    if (!el) return;
                    el.style.setProperty('background-color', EDITABLE_BG, 'important');
                    el.querySelectorAll('.dxss-ftc').forEach(function (ftc) {
                        ftc.style.setProperty('background-color', EDITABLE_BG, 'important');
                    });
                });
            }

            function installCellColorObserver() {
                const wrap = document.getElementById('dxComposeWrap');
                if (!wrap || wrap.__colorObserverBound) return;

                function tryStart() {
                    if (!buildBgCtbIds()) return false;

                    wrap.__colorObserverBound = true;

                    const observer = new MutationObserver(function (mutations) {
                        let needsRestore = false;

                        for (const mut of mutations) {
                            if (mut.addedNodes.length > 0) {
                                for (const node of mut.addedNodes) {
                                    if (node.nodeType !== 1) continue;

                                    if (node.id && node.id.includes('dxComposeSheet_ctb.')) {
                                        paintCtbBg(node);
                                        continue;
                                    }

                                    if (typeof node.querySelectorAll === 'function') {
                                        const ctbs = node.querySelectorAll('[id*="dxComposeSheet_ctb."]');
                                        ctbs.forEach(paintCtbBg);

                                        if (node.classList && node.classList.contains('dxss-ftc')) {
                                            needsRestore = true;
                                        }

                                        if (node.querySelectorAll('.dxss-ftc').length > 0) {
                                            needsRestore = true;
                                        }
                                    }
                                }
                            }

                            if (mut.type === 'attributes' && mut.attributeName === 'style') {
                                const el = mut.target;
                                if (el.id && el.id.includes('dxComposeSheet_ctb.') && _bgCtbIds.has(el.id)) {
                                    paintCtbBg(el);
                                }
                                if (el.classList && el.classList.contains('dxss-ftc')) {
                                    const ctb = el.closest('[id*="dxComposeSheet_ctb."]');
                                    if (ctb && _bgCtbIds.has(ctb.id)) {
                                        el.style.setProperty('background-color', EDITABLE_BG, 'important');
                                    }
                                }
                            }
                        }

                        if (needsRestore) restoreAllBg();
                    });

                    observer.observe(wrap, {
                        childList: true,
                        subtree: true,
                        attributes: true,
                        attributeFilter: ['style']
                    });

                    wrap.__colorObserver = observer;
                    return true;
                }

                if (tryStart()) return;

                let retries = 0;
                const retryTimer = setInterval(function () {
                    retries++;
                    if (tryStart() || retries >= 20) clearInterval(retryTimer);
                }, 500);
            }

            // ──────────────────────────────────────────
            // 붙여넣기 가드
            // ──────────────────────────────────────────

            function installPasteGuard() {
                function tryBind() {
                    const itFrame = document.getElementById('dxComposeSheet_IT');
                    if (!itFrame || itFrame.__pasteGuardBound) return false;

                    const iDoc = itFrame.contentDocument || itFrame.contentWindow?.document;
                    if (!iDoc) return false;

                    itFrame.__pasteGuardBound = true;

                    if (!iDoc.__keyBlockerBound) {
                        installKeyBlocker(iDoc);
                    }

                    iDoc.addEventListener('paste', function (e) {
                        const inst = getDxInstance();
                        if (!inst) return;
                        refreshActiveSelection(inst);
                        const a1 = state.activeA1 || '';
                        const meta = state.editableByA1.get(a1);

                        if (!meta || String(meta.type || '').toLowerCase() === 'date') {
                            e.preventDefault();
                            e.stopPropagation();
                            if (typeof e.stopImmediatePropagation === 'function') e.stopImmediatePropagation();
                            return;
                        }

                        e.preventDefault();
                        e.stopPropagation();
                        if (typeof e.stopImmediatePropagation === 'function') e.stopImmediatePropagation();

                        const plain = e.clipboardData?.getData('text/plain') ?? '';
                        if (!plain) return;

                        const rc = rowColFromA1(a1);
                        if (!rc) return;

                        const rawLines = plain.replace(/\r\n/g, '\n').replace(/\r/g, '\n').split('\n');

                        let groupLastRow = rc.row1;
                        {
                            let checkRow = rc.row1 + 1;
                            while (true) {
                                const nextA1 = a1FromRowCol(checkRow, rc.col1);
                                const nextMeta = state.editableByA1.get(nextA1);
                                if (!nextMeta) break;
                                if (String(nextMeta.type || '').toLowerCase() === 'date') break;
                                groupLastRow = checkRow;
                                checkRow++;
                            }
                        }
                        const maxRows = groupLastRow - rc.row1 + 1;

                        function getActiveCellMetrics() {
                            const styles = (state.preview || {}).styles || {};
                            const activeRc = rowColFromA1(state.activeA1 || '');
                            const row1 = activeRc ? activeRc.row1 : 9;
                            const col1 = activeRc ? activeRc.col1 : 3;
                            const cellStyle = styles[row1 + ',' + col1] || {};
                            const fontName = cellStyle.font?.name || '굴림체';
                            const fontSize = cellStyle.font?.size || 11;
                            const fontPx = fontSize * 96 / 72;
                            const bold = cellStyle.font?.bold ? 'bold ' : '';
                            const font = bold + fontPx + 'px ' + fontName;

                            const wrapEl = document.getElementById('dxComposeWrap');
                            let width = 0;
                            if (wrapEl) {
                                wrapEl.querySelectorAll('.dxss-ftc').forEach(function (ftc) {
                                    const bg = window.getComputedStyle(ftc).backgroundColor;
                                    if (bg !== 'rgb(234, 246, 255)') return;
                                    const ctb = ftc.closest('[id*="dxComposeSheet_ctb."]');
                                    if (!ctb) return;
                                    const tbEl = document.getElementById(ctb.id.replace('_ctb.', '_tb.'));
                                    if (!tbEl) return;
                                    const w = parseInt(tbEl.style.width);
                                    if (w > 100 && w < 700 && w > width) width = w;
                                });
                            }
                            if (!width) width = 565;
                            return { width, font };
                        }

                        function measureTextWidth(text, font) {
                            if (!measureTextWidth._canvas) {
                                measureTextWidth._canvas = document.createElement('canvas');
                            }
                            const ctx = measureTextWidth._canvas.getContext('2d');
                            ctx.font = font;
                            return ctx.measureText(text).width;
                        }

                        function wrapTextToWidth(text, maxWidth, font) {
                            if (!text) return [''];
                            const result = [];
                            let current = '';
                            for (let i = 0; i < text.length; i++) {
                                const ch = text[i];
                                const testLine = current + ch;
                                if (measureTextWidth(testLine, font) > maxWidth && current.length > 0) {
                                    result.push(current);
                                    current = ch;
                                } else {
                                    current = testLine;
                                }
                            }
                            if (current) result.push(current);
                            return result.length > 0 ? result : [''];
                        }

                        const { width: cellWidth, font: cellFont } = getActiveCellMetrics();
                        const maxWidth = Math.max(50, cellWidth - 4);

                        const wrappedLines = rawLines;

                        trySetCellValueByIndex(inst, rc.col1 - 1, rc.row1 - 1, plain);

                        tryInvokeDxEditorCommit(inst);
                        state.dxDirtySinceLastSync = true;

                    }, true);

                    return true;
                }

                if (tryBind()) return;

                const observer = new MutationObserver(function () {
                    if (tryBind()) observer.disconnect();
                });
                observer.observe(document.body, { childList: true, subtree: true });
            }

            // ──────────────────────────────────────────
            // 초기화
            // ──────────────────────────────────────────

            function hookCancel() {
                document.getElementById('btn-cancel')?.addEventListener('click', async () => {
                    markIntentionalLeave();
                    await deleteDxTemp();
                    history.length > 1 ? history.back() : (location.href = '/Doc/Newㅅ');
                });
            }

            function hookDxReady() {
                installOuterScrollOnly();

                function applySize() {
                    const ext = state.previewExtent;
                    if (!ext || ext.height <= 0 || ext.width <= 0) return;

                    const wrap = document.getElementById('dxComposeWrap');
                    if (!wrap) return;

                    wrap.style.setProperty('width', ext.width + 'px', 'important');
                    wrap.style.setProperty('min-width', ext.width + 'px', 'important');
                    wrap.style.setProperty('max-width', ext.width + 'px', 'important');
                    wrap.style.setProperty('height', ext.height + 'px', 'important');
                    wrap.style.setProperty('min-height', ext.height + 'px', 'important');
                    wrap.style.setProperty('overflow', 'hidden', 'important');

                    clampDxHorizontalExtent();

                    console.log('[DX] applySize width=', ext.width, 'height=', ext.height, 'mode=', state.serverExtent?.mode, 'lastA1=', state.serverExtent?.lastA1);

                    const scroll = document.getElementById('doc-scroll');
                    if (scroll) scroll.classList.add('dx-page-ready');
                }

                const wrap = document.getElementById('dxComposeWrap');
                if (!wrap) return;

                let applied = false;
                function tryApply() {
                    if (applied) return;
                    const wbc = document.getElementById('dxComposeSheet_WBC')
                             || document.querySelector('#dxComposeWrap [id$="_WBC"]');
                    if (wbc && wbc.offsetWidth > 0 && wbc.offsetHeight > 0) {
                        applied = true;
                        observer.disconnect();
                        applySize();
                    }
                }

                const observer = new MutationObserver(function () {
                    tryApply();
                });

                observer.observe(wrap, { childList: true, subtree: true, attributes: true });
                tryApply();
            }

            function hookDxReadyLoop() {
                let tries = 0;
                (function tick() {
                    tries++;
                    const inst = getDxInstance();
                    if (inst) {
                        bindDxStateEvents(inst);
                        refreshActiveSelection(inst);
                        initDefaultDateValues();
                        bindDatePickerOpenBridge();
                        installCellColorObserver();
                    }

                    const itFrame = document.getElementById('dxComposeSheet_IT');
                    if (itFrame) {
                        const iDoc = itFrame.contentDocument || itFrame.contentWindow?.document;
                        if (iDoc && !iDoc.__keyBlockerBound) {
                            installKeyBlocker(iDoc);
                        }
                        if (!itFrame.__pasteGuardBound) {
                            installPasteGuard();
                        }
                    }

                    installOuterScrollOnly();
                    if (tries < 24) setTimeout(tick, 150);
                })();
            }

            function run() {
                clearAlert();
                state.descriptor = readJson('DescriptorJson') || {};
                state.preview = readJson('PreviewJson') || {};
                buildEditableMap(state.descriptor);

                window.__COMPOSE_STATE = state;
                window.__COMPOSE_A1FromRC = a1FromRowCol;
                window.__COMPOSE_EditableByA1 = () => state.editableByA1;

                applyDxWrapSize();
                hookDxReady();
                installDatePickerBridge();
                hookAttachmentUi();
                hookCancel();

                installKeyBlocker(document);

                hookDxReadyLoop();

                const saveBtn = document.getElementById('btn-save');
                ['pointerdown', 'mousedown', 'touchstart'].forEach(ev =>
                    saveBtn?.addEventListener(ev, () => ensureSaveCommitStarted(), true)
                );
                saveBtn?.addEventListener('click', saveDocument);
            }

            if (document.readyState === 'loading') document.addEventListener('DOMContentLoaded', run);
            else run();
        })();
    </script>
}