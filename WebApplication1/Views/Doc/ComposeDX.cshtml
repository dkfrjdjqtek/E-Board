@using System.IO
@using System.Text.Json
@using System.Text.Encodings.Web
@using WebApplication1.Models
@model WebApplication1.Models.DocTLViewModel
@inject Microsoft.AspNetCore.Hosting.IWebHostEnvironment Env
@inject Microsoft.Extensions.Localization.IStringLocalizer<SharedResource> S

@{
    ViewData["Title"] = S["DOC_Title_Compose"];
    ViewData["DisableDxAll"] = true;

    var workDir = Env.ContentRootPath;
    var isAjax = string.Equals(Context.Request.Headers["X-Requested-With"], "XMLHttpRequest", StringComparison.OrdinalIgnoreCase);
    Layout = isAjax ? null : "~/Views/Shared/_Layout.cshtml";

    var templateCode = (string?)ViewBag.TemplateCode
    ?? (Context?.Request?.Query["templateCode"].ToString() ?? string.Empty);
    var templateTitle = (string?)ViewBag.TemplateTitle ?? string.Empty;
    var descJson = (string?)ViewBag.DescriptorJson ?? "{}";
    var previewJson = (string?)ViewBag.PreviewJson ?? "{}";
    var excelPath = (string?)ViewBag.ExcelPath ?? string.Empty;
    var dxCallbackUrl = (string?)ViewBag.DxCallbackUrl ?? "/Doc/dx-callback";
    var dxDocumentId = (string?)ViewBag.DxDocumentId ?? ("compose_" + Guid.NewGuid().ToString("N"));

    var dxTargetHeightPx = (ViewBag.TargetHeightPx is int) ? (int)ViewBag.TargetHeightPx : 900;
    var dxTargetWidthPx = (ViewBag.TargetWidthPx is int) ? (int)ViewBag.TargetWidthPx : 900;
    var dxLastRow = (ViewBag.LastRow is int) ? (int)ViewBag.LastRow : 0;
    var dxLastCol = (ViewBag.LastCol is int) ? (int)ViewBag.LastCol : 0;
    var dxLastA1 = (string?)ViewBag.LastA1 ?? "A1";
    var dxTargetA1 = (string?)ViewBag.TargetA1 ?? dxLastA1;
    var dxTargetRow1 = (ViewBag.TargetRow1 is int) ? (int)ViewBag.TargetRow1 : 1;
    var dxTargetCol1 = (ViewBag.TargetCol1 is int) ? (int)ViewBag.TargetCol1 : 1;
    var dxVisualMode = (string?)ViewBag.DxVisualMode ?? string.Empty;

    var __padH = Math.Max(24, Math.Min(72, (int)Math.Ceiling(dxTargetHeightPx * 0.02)));
    var __padW = Math.Max(24, Math.Min(72, (int)Math.Ceiling(dxTargetWidthPx * 0.02)));

    var dxTargetHeightSafePx = dxTargetHeightPx + __padH;
    var dxTargetWidthSafePx = dxTargetWidthPx + __padW;

    var openRel = excelPath;
    try
    {
        if (!string.IsNullOrWhiteSpace(excelPath) && System.IO.Path.IsPathRooted(excelPath))
            openRel = System.IO.Path.GetRelativePath(workDir, excelPath);
        else
            openRel = excelPath;
    }
    catch
    {
        openRel = excelPath;
    }
}

@if (isAjax)
{
    <script>
        (function () {
            try {
                window.DevExpress = window.DevExpress || {};
                window.DevExpress.trial = window.DevExpress.trial || {};
                if (typeof window.DevExpress.trial.registerTrialPanelComponents !== 'function') {
                    window.DevExpress.trial.registerTrialPanelComponents = function () { };
                }
            } catch (e) { }
        })();
    </script>
    <script src="~/dxresources/js/dx.all.js" asp-append-version="true"></script>
    <link rel="stylesheet" href="~/devex-spreadsheet/dist/dx-aspnetcore-spreadsheet.css" asp-append-version="true" />
    <script src="~/devex-spreadsheet/dist/dx-aspnetcore-spreadsheet.js" asp-append-version="true"></script>
}
else
{
    @section DxHead {
        <script>
            (function () {
                try {
                    window.DevExpress = window.DevExpress || {};
                    window.DevExpress.trial = window.DevExpress.trial || {};
                    if (typeof window.DevExpress.trial.registerTrialPanelComponents !== 'function') {
                        window.DevExpress.trial.registerTrialPanelComponents = function () { };
                    }
                } catch (e) { }
            })();
        </script>
        <script src="~/dxresources/js/dx.all.js" asp-append-version="true"></script>
        <link rel="stylesheet" href="~/devex-spreadsheet/dist/dx-aspnetcore-spreadsheet.css" asp-append-version="true" />
        <script src="~/devex-spreadsheet/dist/dx-aspnetcore-spreadsheet.js" asp-append-version="true"></script>
    }
}

