File: Views/Doc/DocManage.cshtml
@* 2026.06.09 Changed: DocControllerHelper.js 공용 날짜 헬퍼를 사용하도록 작성일 컬럼을 정리하고 DocManage DataGrid 초기화를 복원 *@
@model WebApplication1.Controllers.DocManageController.DocManageIndexVm
@using System
@using System.Globalization
@using System.Text.Json
@using Microsoft.Extensions.Localization
@inject IStringLocalizer<SharedResource> L

@{
    ViewData["Title"] = L["DM_Title_Manage"];
    ViewData["DisableDxAll"] = false;
    ViewData["UseDxSpreadsheet"] = false;

    var jsonOptions = new JsonSerializerOptions
    {
        Encoder = System.Text.Encodings.Web.JavaScriptEncoder.Default
    };

    var rowsJson = JsonSerializer.Serialize(Model.Items, jsonOptions);

    var fromDateText = Model.Search.FromDate?.ToString("yyyy-MM-dd", CultureInfo.InvariantCulture) ?? "";
    var toDateText = Model.Search.ToDate?.ToString("yyyy-MM-dd", CultureInfo.InvariantCulture) ?? "";

    var currentCulture = CultureInfo.CurrentUICulture.Name;
    if (string.IsNullOrWhiteSpace(currentCulture))
    {
        currentCulture = "ko-KR";
    }

    var datePattern = WebApplication1.Controllers.DocControllerHelper.GetLocalDatePattern(currentCulture);

    var textJson = JsonSerializer.Serialize(new
    {
        currentCulture,
        datePattern,

        noData = L["DM_Message_NoData"].Value,
        gridLoadFail = L["_CM_Error"].Value,

        title = L["DM_Title_Manage"].Value,
        desc = L["DM_Desc_Manage"].Value,
        fromDate = L["DM_Label_FromDate"].Value,
        toDate = L["DM_Label_ToDate"].Value,
        search = L["_CM_Search"].Value,
        reset = L["_CM_Reset"].Value,

        colCreatedAt = L["DM_Col_CreatedAt"].Value,
        colTitle = L["DM_Col_Title"].Value,
        colCompCd = L["DM_Col_CompCd"].Value,
        colDepartmentId = L["DM_Col_DepartmentId"].Value,
        colCreatedBy = L["DM_Col_CreatedBy"].Value,
        colStatus = L["DM_Col_Status"].Value,
        colHasFiles = L["DTM_Col_FileExists"].Value,
        colDocId = L["DM_Col_DocId"].Value,
        colTemplateCode = L["DM_Col_TemplateCode"].Value,
        colTemplateVersion = L["DTM_Col_VersionNo"].Value,
        hasFileYes = L["DTM_Text_Yes"].Value,
        hasFileNo = L["DTM_Text_No"].Value,

        all = L["_CM_All"].Value,

        empty = L["DM_Text_Empty"].Value,
        pending = L["DOC_Status_Pending"].Value,
        approved = L["DOC_Filter_ApprovalView_Approved"].Value,
        rejected = L["DOC_Filter_ApprovalView_Rejected"].Value,
        vetoed = L["DOC_Filter_ApprovalView_Vetoed"].Value,
        onHold = L["DOC_Status_OnHold"].Value,
        recalled = L["DOC_Filter_ApprovalView_Recalled"].Value,
        statusFilterApprovalPending = L["DM_Filter_ApprovalPending"].Value,
        statusFilterCoopPending = L["DM_Filter_CoopPending"].Value,

        ok = L["_CM_OK"].Value,
        cancel = L["_CM_Cancel"].Value,
        today = L["_CM_Today"].Value
    }, jsonOptions);
}

<div id="dm-scroll">
    <div class="container-fluid py-3" id="docManagePage">
        <div class="d-flex align-items-center justify-content-between mb-3 flex-wrap gap-2">
            <div>
                <h4 class="mb-1">@L["DM_Title_Manage"]</h4>
                <div class="text-muted small">@L["DM_Desc_Manage"]</div>
            </div>
        </div>

        <form method="get" action="/DocManage" class="card dm-search-card mb-3">
            <div class="card-body">
                <div class="row g-2 align-items-end">
                    <div class="col-12 col-md-3 col-xl-2">
                        <label class="form-label mb-1" for="FromDate">@L["DM_Label_FromDate"]</label>
                        <input type="date"
                               class="form-control"
                               id="FromDate"
                               name="FromDate"
                               value="@fromDateText" />
                    </div>

                    <div class="col-12 col-md-3 col-xl-2">
                        <label class="form-label mb-1" for="ToDate">@L["DM_Label_ToDate"]</label>
                        <input type="date"
                               class="form-control"
                               id="ToDate"
                               name="ToDate"
                               value="@toDateText" />
                    </div>

                    <div class="col-12 col-md-auto d-flex gap-2">
                        <button type="submit" class="btn btn-primary">
                            @L["_CM_Search"]
                        </button>
                        <a class="btn btn-outline-secondary" href="/DocManage">
                            @L["_CM_Reset"]
                        </a>
                    </div>
                </div>
            </div>
        </form>

        <div class="card dm-card">
            <div class="card-header d-flex justify-content-between align-items-center">
                <span>@L["DM_Grid_Title"]</span>
                <span class="text-muted small">@L["DM_Grid_Count", Model.Items.Count]</span>
            </div>
            <div class="card-body p-0">
                <div id="dmDocumentGrid" class="dm-grid-host"></div>
            </div>
        </div>
    </div>
</div>

