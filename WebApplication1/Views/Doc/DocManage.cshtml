<script type="application/json" id="dm-rows-json">
    @Html.Raw(rowsJson)
</script>

<script type="application/json" id="dm-text-json">
    @Html.Raw(textJson)
</script>

<script src="~/js/eb.doc.board.js" asp-append-version="true"></script>
<script src="~/js/DocControllerHelper.js" asp-append-version="true"></script>

<script>
    (() => {
        const page = document.getElementById('docManagePage');
        const gridEl = document.getElementById('dmDocumentGrid');
        const scrollHost = document.getElementById('dm-scroll');

        if (!page || !gridEl || !scrollHost) return;

        const H = window.DocControllerHelper;
        if (!H) {
            console.error('DocControllerHelper.js가 로드되지 않았습니다.');
            gridEl.innerHTML = '<div class="alert alert-danger m-3">@L["_CM_Error"]</div>';
            return;
        }

        const rows = H.readJsonScript('dm-rows-json', []);
        const text = H.readJsonScript('dm-text-json', {});

        const statusDotI18n = {
            DOT_LABELS: {
                ApprovedDone: text.approved || '승인됨',
                RejectedDone: text.rejected || '반려됨',
                VetoedDone: text.vetoed || '부결됨',
                RecalledDone: text.recalled || '회수됨',
                Pending: text.pending || '대기'
            }
        };

        function unwrap(container) {
            return H.unwrap(container);
        }

        function valueOrEmpty(value) {
            return value === null || value === undefined || String(value).trim() === ''
                ? text.empty
                : String(value);
        }

        function appendEllipsis(container, value) {
            const el = unwrap(container);
            const span = document.createElement('span');
            span.className = 'dm-ellipsis';
            span.title = valueOrEmpty(value);
            span.textContent = valueOrEmpty(value);
            el.appendChild(span);
        }

        function appendBadge(container, label, className) {
            const el = unwrap(container);
            const span = document.createElement('span');
            span.className = className;
            span.textContent = label;
            el.appendChild(span);
        }

        function dmNorm(value) {
            return String(value || '').trim().toUpperCase();
        }

        function dmAsInt(value) {
            const n = parseInt(String(value ?? '0'), 10);
            return Number.isFinite(n) ? n : 0;
        }

        function dmHasAnyKeyList(value) {
            return String(value || '')
                .split(',')
                .map(x => dmAsInt(x))
                .some(x => x > 0);
        }

        function dmStepType(step) {
            const status = dmNorm(step && (step.status || step.Status));
            const action = dmNorm(step && (step.action || step.Action));

            if (action === 'APPROVE' || status.indexOf('APPROVED') === 0) return 'approve';
            if (action === 'REJECT' || status.indexOf('REJECTED') === 0) return 'reject';
            if (action === 'RECALL' || status.indexOf('RECALLED') === 0) return 'recall';
            if (action === 'HOLD' || status === 'HOLD' || status.indexOf('ONHOLD') === 0 || status.indexOf('PENDINGHOLD') === 0) return 'hold';
            if (action === 'VETO' || status === 'VETO' || status.indexOf('VETOED') === 0) return 'veto';

            return 'todo';
        }

        function dmTextOrFallback(value, key, fallbackValue) {
            return H.textOrFallback(value, key, fallbackValue);
        }

        function dmStatusFilterText(item) {
            const kind = String(item && item.kind || '');
            const code = String(item && item.code || '');
            const name = String(item && item.name || '').trim();

            if (kind === 'status') {
                if (code === 'Approved') return text.approved || '승인됨';
                if (code === 'Rejected') return text.rejected || '반려됨';
                if (code === 'OnHold') return text.onHold || '보류됨';
                if (code === 'Recalled') return text.recalled || '회수됨';
                if (code === 'Vetoed') return text.vetoed || '부결됨';
            }

            if (kind === 'approvalPending') {
                const prefix = dmTextOrFallback(
                    text.statusFilterApprovalPending,
                    'DM_Filter_ApprovalPending',
                    '결재대기'
                );
                return prefix + ' - ' + name;
            }

            if (kind === 'coopPending') {
                const prefix = dmTextOrFallback(
                    text.statusFilterCoopPending,
                    'DM_Filter_CoopPending',
                    '협조대기'
                );
                return prefix + ' - ' + name;
            }

            return name || valueOrEmpty(item && item.key);
        }

        function dmBuildStatusHeaderFilterDataSource(dataRows) {
            const map = new Map();

            (dataRows || []).forEach(row => {
                const items = Array.isArray(row.statusFilterItems)
                    ? row.statusFilterItems
                    : [];

                items.forEach(item => {
                    const key = String(item && item.key || '').trim();
                    if (!key || map.has(key)) return;

                    map.set(key, {
                        text: dmStatusFilterText(item),
                        value: key,
                        sortGroup: dmAsInt(item.sortGroup),
                        sortText: String(item.sortText || item.name || item.key || '')
                    });
                });
            });

            return Array.from(map.values()).sort((a, b) => {
                if (a.sortGroup !== b.sortGroup) return a.sortGroup - b.sortGroup;
                return a.sortText.localeCompare(b.sortText, undefined, { sensitivity: 'base' });
            });
        }

        function dmBuildStatusFilterKeyText(row) {
            const items = Array.isArray(row.statusFilterItems)
                ? row.statusFilterItems
                : (Array.isArray(row.StatusFilterItems) ? row.StatusFilterItems : []);

            const keys = [];

            items.forEach(item => {
                const key = String(item && (item.key || item.Key) || '').trim();
                if (!key) return;
                if (!keys.includes(key)) keys.push(key);
            });

            return keys.length > 0 ? '|' + keys.join('|') + '|' : '';
        }

        function dmBuildStatusHeaderFilterExpression(filterValue) {
            const values = Array.isArray(filterValue) ? filterValue : [filterValue];

            const filters = values
                .map(x => String(x || '').trim())
                .filter(x => x.length > 0)
                .map(key => [
                    'statusFilterKeyText',
                    'contains',
                    '|' + key + '|'
                ]);

            if (filters.length === 0) return null;
            if (filters.length === 1) return filters[0];

            return filters.reduce((acc, item) => acc ? [acc, 'or', item] : item, null);
        }

        function dmIsCompletedBoardRow(row) {
            const status = dmNorm(row.statusCode || row.StatusCode || row.status || row.Status);

            if (status === 'APPROVED' || status === 'APPROVE') return true;
            if (status === 'REJECTED' || status === 'REJECT') return true;
            if (status === 'RECALLED' || status === 'RECALL') return true;
            if (status === 'VETOED' || status === 'VETO') return true;

            const approvalSteps = Array.isArray(row.approvalSteps)
                ? row.approvalSteps
                : (Array.isArray(row.ApprovalSteps) ? row.ApprovalSteps : []);

            if (approvalSteps.some(x => {
                const t = dmStepType(x);
                return t === 'reject' || t === 'veto' || t === 'recall';
            })) {
                return true;
            }

            if (approvalSteps.length > 0 && approvalSteps.every(x => dmStepType(x) === 'approve')) {
                return true;
            }

            const totalApprovers = dmAsInt(row.totalApprovers ?? row.TotalApprovers);
            const completedApprovers = dmAsInt(row.completedApprovers ?? row.CompletedApprovers);

            if (totalApprovers > 0 && completedApprovers >= totalApprovers) {
                return true;
            }

            if (dmHasAnyKeyList(row.coopRejectedKeys ?? row.CoopRejectedKeys)) return true;
            if (dmHasAnyKeyList(row.coopRecalledKeys ?? row.CoopRecalledKeys)) return true;

            return false;
        }

        function dmBoardStateForRow(row) {
            if (dmIsCompletedBoardRow(row)) {
                return {
                    tab: 'created',
                    createdSub: 'completed'
                };
            }

            return {
                tab: 'created',
                createdSub: 'ongoing'
            };
        }

        function pickFirstVisible(selectors) {
            for (const selector of selectors) {
                const el = document.querySelector(selector);
                if (!el) continue;

                const style = window.getComputedStyle(el);
                if (style.display === 'none' || style.visibility === 'hidden') continue;

                const rect = el.getBoundingClientRect();
                if (rect.width <= 0 || rect.height <= 0) continue;

                return el;
            }

            return null;
        }

        function readCssPx(varName, fallback) {
            const raw = getComputedStyle(document.documentElement).getPropertyValue(varName || '').trim();
            const value = parseFloat(raw);
            return Number.isFinite(value) ? value : fallback;
        }

        function dmAddUnique(parts, value) {
            const s = String(value || '').trim();
            if (!s) return;
            if (!parts.includes(s)) parts.push(s);
        }

        function dmCountKeyList(value) {
            return String(value || '')
                .split(',')
                .map(x => dmAsInt(x))
                .filter(x => x > 0)
                .length;
        }

        function dmGetTerminalStatusLabel(row) {
            const status = dmNorm(row.statusCode || row.StatusCode || row.status || row.Status);

            if (status === 'APPROVED' || status === 'APPROVE') {
                return text.approved || '승인됨';
            }

            if (status === 'REJECTED' || status === 'REJECT') {
                return text.rejected || '반려됨';
            }

            if (status === 'VETOED' || status === 'VETO') {
                return text.vetoed || '부결됨';
            }

            if (status === 'RECALLED' || status === 'RECALL') {
                return text.recalled || '회수됨';
            }

            if (status === 'HOLD' || status === 'ONHOLD' || status === 'PENDINGHOLD') {
                return text.onHold || '보류됨';
            }

            const approvalSteps = Array.isArray(row.approvalSteps)
                ? row.approvalSteps
                : (Array.isArray(row.ApprovalSteps) ? row.ApprovalSteps : []);

            if (approvalSteps.some(x => dmStepType(x) === 'reject')) {
                return text.rejected || '반려됨';
            }

            if (approvalSteps.some(x => dmStepType(x) === 'veto')) {
                return text.vetoed || '부결됨';
            }

            if (approvalSteps.some(x => dmStepType(x) === 'recall')) {
                return text.recalled || '회수됨';
            }

            if (approvalSteps.some(x => dmStepType(x) === 'hold')) {
                return text.onHold || '보류됨';
            }

            if (approvalSteps.length > 0 && approvalSteps.every(x => dmStepType(x) === 'approve')) {
                return text.approved || '승인됨';
            }

            return '';
        }

        function dmGetApprovalVisibleText(row) {
            const terminalLabel = dmGetTerminalStatusLabel(row);
            if (terminalLabel) {
                return terminalLabel;
            }

            const approvalSteps = Array.isArray(row.approvalSteps)
                ? row.approvalSteps
                : (Array.isArray(row.ApprovalSteps) ? row.ApprovalSteps : []);

            const pending = approvalSteps.find(x => dmStepType(x) === 'todo');
            if (pending) {
                return String(pending.approverName || pending.ApproverName || row.resultSummary || row.ResultSummary || '').trim();
            }

            return String(row.resultSummary || row.ResultSummary || '').trim();
        }

        function dmGetCoopVisibleText(row) {
            const total = dmAsInt(row.coopTotalSteps ?? row.CoopTotalSteps);
            if (total <= 0) {
                return '';
            }

            const terminalLabel = dmGetTerminalStatusLabel(row);
            if (terminalLabel) {
                return terminalLabel;
            }

            if (dmHasAnyKeyList(row.coopRejectedKeys ?? row.CoopRejectedKeys)) {
                return text.rejected || '반려됨';
            }

            if (dmHasAnyKeyList(row.coopRecalledKeys ?? row.CoopRecalledKeys)) {
                return text.recalled || '회수됨';
            }

            if (dmHasAnyKeyList(row.coopHoldKeys ?? row.CoopHoldKeys)) {
                return text.onHold || '보류됨';
            }

            if (dmCountKeyList(row.coopDoneKeys ?? row.CoopDoneKeys) >= total) {
                return text.approved || '승인됨';
            }

            return String(row.coopPendingName || row.CoopPendingName || '').trim();
        }

        function dmBuildStatusSearchText(row) {
            const parts = [];

            dmAddUnique(parts, dmGetApprovalVisibleText(row));
            dmAddUnique(parts, dmGetCoopVisibleText(row));

            return parts.join(' ');
        }

        rows.forEach(row => {
            H.normalizeLocalDateRow(row, {
                localTextField: 'CreatedAtLocalText',
                localDateKeyField: 'CreatedAtLocalDateKey'
            });

            row.statusSearchText = dmBuildStatusSearchText(row);
            row.statusFilterKeyText = dmBuildStatusFilterKeyText(row);
        });

        function syncScrollHostLayout() {
            let top = readCssPx('--header-h', 64);
            let left = readCssPx('--sidebar-w', 200);
            let bottom = readCssPx('--footer-h', 28);

            const header = pickFirstVisible([
                'header',
                '.navbar',
                '.main-header',
                '.app-header',
                '.topbar',
                '.layout-navbar'
            ]);

            const sidebar = pickFirstVisible([
                '.main-sidebar',
                '.sidebar',
                'aside',
                '.app-sidebar',
                '.layout-menu'
            ]);

            const footer = pickFirstVisible([
                'footer',
                '.main-footer',
                '.footer'
            ]);

            if (header) {
                const rect = header.getBoundingClientRect();
                if (rect.bottom > 0) {
                    top = Math.max(top, Math.round(rect.bottom));
                }
            }

            if (window.innerWidth < 992) {
                left = 0;
            } else if (sidebar) {
                const rect = sidebar.getBoundingClientRect();
                if (rect.right > 0) {
                    left = Math.max(left, Math.round(rect.right));
                }
            }

            if (footer) {
                const rect = footer.getBoundingClientRect();
                const footerHeight = Math.max(0, Math.round(window.innerHeight - rect.top));
                bottom = Math.max(bottom, footerHeight);
            }

            scrollHost.style.top = top + 'px';
            scrollHost.style.left = left + 'px';
            scrollHost.style.right = '0px';
            scrollHost.style.bottom = bottom + 'px';
        }

        if (!window.DevExpress || !DevExpress.ui || !DevExpress.ui.dxDataGrid) {
            console.error('DevExtreme DataGrid가 로드되지 않았습니다.');
            gridEl.innerHTML = '<div class="alert alert-danger m-3">' + text.gridLoadFail + '</div>';
            return;
        }

        new DevExpress.ui.dxDataGrid(gridEl, {
            dataSource: rows,
            keyExpr: 'DocId',
            showBorders: true,
            rowAlternationEnabled: true,
            hoverStateEnabled: true,
            allowColumnResizing: true,
            columnResizingMode: 'widget',
            columnAutoWidth: false,
            wordWrapEnabled: false,
            width: '100%',
            noDataText: text.noData,
            columnFixing: {
                enabled: false
            },
            scrolling: {
                mode: 'standard',
                columnRenderingMode: 'standard',
                showScrollbar: 'never',
                useNative: true
            },
            paging: {
                pageSize: 50
            },
            pager: {
                visible: true,
                showInfo: true,
                showNavigationButtons: true,
                showPageSizeSelector: true,
                allowedPageSizes: [50, 100, 200]
            },
            sorting: {
                mode: 'multiple'
            },
            filterRow: {
                visible: true,
                applyFilter: 'auto',
                showAllText: text.all || '(All)'
            },
            headerFilter: {
                visible: true
            },
            searchPanel: {
                visible: false
            },
            columns: [
                H.createLocalDateColumn({
                    caption: text.colCreatedAt,
                    text: text,
                    localTextField: 'CreatedAtLocalText',
                    localDateKeyField: 'CreatedAtLocalDateKey',
                    sortFields: ['CreatedAtUtc', 'createdAtUtc', 'CreatedAt', 'createdAt', 'CreatedAtLocalText', 'createdAtLocalText'],
                    width: 150,
                    alignment: 'center',
                    cssClass: 'dm-cell-center',
                    allowHeaderFiltering: false
                }),
                {
                    caption: text.colCompCd,
                    dataField: 'CompName',
                    dataType: 'string',
                    width: 120,
                    alignment: 'center',
                    cssClass: 'dm-cell-center',
                    calculateCellValue: function (row) {
                        return row.CompName || row.CompCd || text.empty;
                    },
                    cellTemplate: function (container, options) {
                        appendEllipsis(container, options.value);
                    }
                },
                {
                    caption: text.colDepartmentId,
                    dataField: 'DepartmentName',
                    dataType: 'string',
                    width: 130,
                    alignment: 'center',
                    cssClass: 'dm-cell-center',
                    calculateCellValue: function (row) {
                        return row.DepartmentName || row.DepartmentId || text.empty;
                    },
                    cellTemplate: function (container, options) {
                        appendEllipsis(container, options.value);
                    }
                },
                {
                    caption: text.colTitle,
                    dataField: 'Title',
                    dataType: 'string',
                    width: 220,
                    cellTemplate: function (container, options) {
                        appendEllipsis(container, options.value);
                    }
                },
                {
                    caption: text.colCreatedBy,
                    dataField: 'AuthorDisplayName',
                    dataType: 'string',
                    width: 140,
                    calculateCellValue: function (row) {
                        return row.AuthorDisplayName || row.CreatedByName || row.CreatedBy || text.empty;
                    },
                    cellTemplate: function (container, options) {
                        appendEllipsis(container, options.value);
                    }
                },
                {
                    caption: text.colStatus,
                    dataField: 'Status',
                    dataType: 'string',
                    width: 430,
                    alignment: 'left',
                    calculateDisplayValue: function (row) {
                        return row.resultSummary || row.ResultSummary || row.statusCode || row.Status || '';
                    },
                    calculateFilterExpression: function (filterValue, selectedFilterOperation, target) {
                        if (!filterValue) return null;

                        if (target === 'headerFilter') {
                            return dmBuildStatusHeaderFilterExpression(filterValue);
                        }

                        if (target === 'filterRow' || target === 'search') {
                            return [
                                'statusSearchText',
                                selectedFilterOperation || 'contains',
                                filterValue
                            ];
                        }

                        if (Array.isArray(filterValue)) {
                            return filterValue;
                        }

                        if (this.defaultCalculateFilterExpression) {
                            return this.defaultCalculateFilterExpression.apply(this, arguments);
                        }

                        return [
                            'Status',
                            selectedFilterOperation || 'contains',
                            filterValue
                        ];
                    },
                    headerFilter: {
                        dataSource: dmBuildStatusHeaderFilterDataSource(rows)
                    },
                    cellTemplate: function (container, options) {
                        const el = unwrap(container);
                        const row = options.data || {};

                        el.innerHTML = '';

                        if (window.EBDocStatusDots && typeof window.EBDocStatusDots.renderStatusCell === 'function') {
                            el.appendChild(
                                window.EBDocStatusDots.renderStatusCell(
                                    row,
                                    statusDotI18n,
                                    dmBoardStateForRow(row)
                                )
                            );
                            return;
                        }

                        appendEllipsis(container, row.resultSummary || row.ResultSummary || row.statusCode || row.Status || '');
                    }
                },
                {
                    caption: text.colHasFiles,
                    dataField: 'HasFiles',
                    dataType: 'boolean',
                    width: 95,
                    alignment: 'center',
                    allowHeaderFiltering: true,
                    trueText: text.hasFileYes || '있음',
                    falseText: text.hasFileNo || '없음',
                    lookup: {
                        dataSource: [
                            {
                                value: true,
                                text: text.hasFileYes || '있음'
                            },
                            {
                                value: false,
                                text: text.hasFileNo || '없음'
                            }
                        ],
                        valueExpr: 'value',
                        displayExpr: 'text'
                    },
                    headerFilter: {
                        dataSource: [
                            {
                                text: text.hasFileYes || '있음',
                                value: true
                            },
                            {
                                text: text.hasFileNo || '없음',
                                value: false
                            }
                        ]
                    },
                    cellTemplate: function (container, options) {
                        if (options.value === true) {
                            appendBadge(container, text.hasFileYes || '있음', 'badge bg-success');
                        } else {
                            appendBadge(container, text.hasFileNo || '없음', 'badge bg-danger');
                        }
                    }
                },
                {
                    caption: text.colDocId,
                    dataField: 'DocId',
                    dataType: 'string',
                    width: 240,
                    cellTemplate: function (container, options) {
                        appendEllipsis(container, options.value);
                    }
                },
                {
                    caption: text.colTemplateCode,
                    dataField: 'TemplateCode',
                    dataType: 'string',
                    width: 220,
                    cellTemplate: function (container, options) {
                        appendEllipsis(container, options.value);
                    }
                },
                {
                    caption: text.colTemplateVersion,
                    dataField: 'TemplateVersionNo',
                    dataType: 'number',
                    width: 110,
                    alignment: 'center'
                },
                {
                    caption: '',
                    dataField: '__filler',
                    cssClass: 'dm-filler-col',
                    allowSorting: false,
                    allowFiltering: false,
                    allowHeaderFiltering: false,
                    allowSearch: false,
                    cellTemplate: function (container) {
                        const el = unwrap(container);
                        el.innerHTML = '';
                    }
                }
            ],
            onContentReady: function () {
                syncScrollHostLayout();
            }
        });

        window.addEventListener('resize', syncScrollHostLayout);
        window.addEventListener('load', syncScrollHostLayout);
        setTimeout(syncScrollHostLayout, 0);
        setTimeout(syncScrollHostLayout, 150);
        setTimeout(syncScrollHostLayout, 400);
    })();
</script>