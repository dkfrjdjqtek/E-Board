@* 2026.03.23 Changed: 문서함 메인 탭을 상신 결재 협조 공유 순으로 재구성하고 협조 문서함 진행 완료 서브탭과 배지를 추가함 *@
@* 2026.02.02 Changed: 일괄 승인 버튼 클릭 시 서버 BulkApprove로 실제 요청을 보내고 성공 시 리로드 없이 리스트와 배지를 부분 갱신하도록 보강 *@
@* 2026.02.02 Changed 보드 후처리 MutationObserver가 스스로 DOM을 계속 변경해 무한 루프가 발생하는 문제를 차단하고 결재 진행 탭에서만 체크박스를 표시하도록 정리 *@
@* 2026.02.02 Changed 보드 상태 결과 표시를 좌우 정렬로 통합하고 결과 컬럼을 열람 미열람으로 표시 *@
@* 2026.02.02 Changed 보드 스크립트 캐시 방지 및 중복 초기화 제거 외부 스크립트 오류로 배지 갱신이 누락되는 문제를 방지하기 위해 BoardBadges 폴백 갱신 로직을 추가 *@
@* 2026.01.30 Changed Board 페이지 inline script를 wwwroot/js/eb.doc.board.js로 분리하고 i18n JSON을 script 태그로 전달하도록 정리 *@
@* 2026.01.30 Changed 선택탭 하단 라운딩을 제거하고 상단만 라운딩하여 안쪽 굽음과 삼각형 잔상과 선 끊김을 구조적으로 제거 하단선은 border bottom 단일화 *@
@using System.Text.Json
@inject Microsoft.Extensions.Localization.IStringLocalizer<SharedResource> S
@{
    ViewData["Title"] = S["DOC_Board_Title"];

    var __docBoardI18n = new
    {
        STATUS_LABELS = new
        {
            Pending = S["DOC_Status_Pending"].Value,
            Approved = S["DOC_Status_Approved"].Value,
            Rejected = S["DOC_Status_Rejected"].Value,
            OnHold = S["DOC_Status_OnHold"].Value,
            Recalled = S["DOC_Status_Recalled"].Value
        },
        DOT_LABELS = new
        {
            ApprovedDone = S["DOC_Filter_ApprovalView_Approved"].Value,
            RejectedDone = S["DOC_Filter_ApprovalView_Rejected"].Value,
            VetoedDone = S["DOC_Filter_ApprovalView_Vetoed"].Value,
            RecalledDone = S["DOC_Filter_ApprovalView_Recalled"].Value,
            Pending = S["DOC_Filter_ApprovalView_Pending"].Value
        },
        READ_LABEL = S["DOC_Result_Viewed"].Value,
        UNREAD_LABEL = S["DOC_Result_Unviewed"].Value,
        LIST_LOADING = S["DOC_List_Loading"].Value,
        LIST_EMPTY = S["DOC_List_Empty"].Value,
        PAGINATION_PREV = S["DOC_Pagination_Prev"].Value,
        PAGINATION_NEXT = S["DOC_Pagination_Next"].Value,
        DOC_Toast_BulkApproved = S["DOC_Toast_BulkApproved"].Value,
        BULK_FAIL = S["DOC_Toast_BulkApproveFailed"].Value
    };
}

<style>
    :root {
        --tab-sel-border: 2px;
        --tab-radius-top: 14px;
        --tabbar-bg: #bfbfbf;
        --tabline: #111827;
        --tab-h: 44px;
    }

    .doc-board-wrap {
        position: fixed;
        top: var(--header-h,56px);
        right: 0;
        bottom: var(--footer-h,32px);
        left: var(--sidebar-w,270px);
        padding: 0;
        box-sizing: border-box;
        overflow-y: auto;
        overflow-x: auto;
        overscroll-behavior: contain;
    }

    .doc-board {
        display: flex;
        flex-direction: column;
        gap: .75rem;
        margin-top: 16px;
        margin-bottom: 16px;
        width: 100%;
        padding: 0 24px;
        box-sizing: border-box;
        min-width: 1176px;
    }

    .doc-tabs,
    .doc-subtabs {
        display: flex;
        gap: 10px;
        align-items: flex-end;
        padding: 12px 12px 0 12px;
        background: var(--tabbar-bg);
        position: relative;
        z-index: 2;
        overflow: visible;
        box-sizing: border-box;
        border: 1px solid #cfcfcf;
        border-bottom: var(--tab-sel-border) solid var(--tabline);
        border-radius: 2px 2px 0 0;
        box-shadow: inset 0 1px 0 #cfcfcf;
        background-clip: padding-box;
    }

    .doc-subtabs {
        display: none;
        margin: -14px -14px 12px -14px;
        padding: 12px calc(12px + 14px) 0 calc(12px + 14px);
    }

    .doc-tab,
    .doc-subtab {
        display: inline-flex;
        align-items: center;
        gap: 10px;
        height: var(--tab-h);
        padding: 0 18px;
        cursor: pointer;
        background: var(--tabbar-bg);
        color: var(--tabline);
        border: 1px solid transparent;
        border-radius: 2px;
        font-weight: 400;
        font-size: 16px;
        line-height: 1;
        margin: 0;
        overflow: visible;
        -webkit-appearance: none;
        appearance: none;
        box-sizing: border-box;
        background-clip: padding-box;
        position: relative;
        z-index: 2;
    }

        .doc-tab:hover,
        .doc-subtab:hover {
            opacity: .92;
        }

        .doc-tab:focus,
        .doc-subtab:focus {
            outline: none;
        }

        .doc-tab:focus-visible,
        .doc-subtab:focus-visible {
            outline: 2px solid rgba(255,255,255,.35);
            outline-offset: 2px;
        }

        .doc-tab[aria-selected="true"],
        .doc-subtab[aria-selected="true"] {
            background: #ffffff;
            color: var(--tabline);
            border: var(--tab-sel-border) solid var(--tabline);
            border-radius: var(--tab-radius-top) var(--tab-radius-top) 0 0;
            margin-bottom: calc(var(--tab-sel-border) * -1);
            border-bottom-color: #ffffff;
            background-clip: padding-box;
            box-shadow: none;
            z-index: 3;
            font-weight: 700;
            font-size: 17px;
        }

        .doc-tab .badge,
        .doc-subtab .badge {
            display: inline-flex;
            align-items: center;
            justify-content: center;
            min-width: 22px;
            height: 22px;
            padding: 0 8px;
            font-size: 14px;
            font-weight: 700;
            line-height: 1;
            background: #ef4444;
            color: #fff;
            border-radius: 9999px;
            position: relative;
            z-index: 5;
            pointer-events: none;
        }

    .doc-sheet {
        border: 0;
        border-top: 0;
        border-radius: 0 0 2px 2px;
        background: #ffffff;
        position: relative;
        z-index: 1;
        padding: 14px;
        box-sizing: border-box;
    }

    .doc-filter {
        display: flex;
        flex-wrap: wrap;
        gap: 10px;
        align-items: center;
        padding: 10px 10px;
        border: 1px solid #e6e6e6;
        border-radius: 2px;
        background: #fff;
        margin-bottom: 12px;
        margin-left: -14px;
        margin-right: -14px;
        padding-left: 24px;
        padding-right: 24px;
    }

        .doc-filter select,
        .doc-filter input {
            padding: 10px 12px;
            border: 1px solid #cfcfcf;
            border-radius: 2px;
            background: #fff;
            font-size: 15px;
        }

    #filterApply {
        padding: 10px 14px;
        border: 1px solid #2c2c2c;
        border-radius: 2px;
        background: #2c2c2c;
        color: #fff;
        font-weight: 900;
        font-size: 15px;
        line-height: 1.1;
        cursor: pointer;
    }

        #filterApply:hover {
            opacity: .92;
        }

    .doc-tablewrap {
        border: 1px solid #e6e6e6;
        border-radius: 2px;
        background: #fff;
        overflow-x: visible;
        margin-left: -14px;
        margin-right: -14px;
    }

    .doc-list {
        width: 100%;
        border-collapse: collapse;
        min-width: 1100px;
        background: #fff;
        font-size: 15px;
    }

        .doc-list th {
            padding: 12px 10px;
            font-weight: 900;
            color: #2c2c2c;
            background: #f4f4f4;
            text-align: center;
            border-bottom: 1px solid #d8d8d8;
            font-size: 15px;
            white-space: nowrap;
        }

        .doc-list td {
            padding: 12px 10px;
            border-bottom: 1px solid #e6e6e6;
            font-size: 15px;
        }

        .doc-list tbody td:nth-child(1) {
            text-align: center;
        }

        .doc-list tbody td:nth-child(2) {
            text-align: left;
        }

        .doc-list tbody td:nth-child(3) {
            text-align: left;
        }

        .doc-list tbody td:nth-child(4) {
            text-align: center;
        }

        .doc-list tbody td:nth-child(5) {
            text-align: center;
        }

        .doc-list tbody td:nth-child(6) {
            text-align: center;
        }

        .doc-list tbody td:nth-child(7) {
            text-align: center;
        }

    .doc-status-join {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        gap: 10px;
        width: auto;
        max-width: 100%;
        white-space: nowrap;
        margin: 0 auto;
    }

        .doc-status-join .st-left,
        .doc-status-join .st-right {
            flex: 0 0 auto;
            min-width: 0;
            overflow: hidden;
            text-overflow: ellipsis;
            text-align: center;
            white-space: nowrap;
        }

    .doc-title a.doc-unread {
        font-weight: 900;
        font-size: 17px;
    }

    .doc-paging-wrap {
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 12px;
        padding-top: 12px;
        position: relative;
    }

    .doc-paging {
        display: flex;
        gap: 8px;
        justify-content: center;
        padding-top: 0;
    }

        .doc-paging button {
            min-width: 34px;
            height: 34px;
            border: 1px solid #cfcfcf;
            background: #fff;
            border-radius: 2px;
            cursor: pointer;
            font-weight: 400;
            font-size: 15px;
        }

            .doc-paging button[aria-current="page"] {
                background: #2c2c2c;
                color: #fff;
                border-color: #2c2c2c;
                font-weight: 400;
            }

    .sr-only {
        position: absolute;
        width: 1px;
        height: 1px;
        padding: 0;
        margin: 0;
        overflow: hidden;
        clip: rect(0,0,0,0);
        border: 0;
    }

    .doc-paging-tools {
        position: absolute;
        right: 0;
        display: inline-flex;
        align-items: center;
        gap: 10px;
    }

        .doc-paging-tools .chk-all {
            display: inline-flex;
            align-items: center;
            gap: 6px;
            white-space: nowrap;
            font-size: 14px;
        }

        .doc-paging-tools .btn-approve-bulk {
            padding: 9px 14px;
            border: 1px solid #2c2c2c;
            border-radius: 2px;
            background: #2c2c2c;
            color: #fff;
            font-weight: 900;
            font-size: 14px;
            line-height: 1.1;
            cursor: pointer;
        }

            .doc-paging-tools .btn-approve-bulk[disabled] {
                opacity: .45;
                cursor: not-allowed;
            }

    .doc-no-cell {
        display: inline-flex;
        align-items: center;
        gap: 8px;
    }

        .doc-no-cell input[type="checkbox"] {
            width: 16px;
            height: 16px;
            transform: translateY(1px);
        }

    #ebTopToastHost {
        position: fixed;
        left: 50%;
        transform: translateX(-50%);
        top: calc(var(--header-h,56px) + 10px);
        z-index: 20000;
        pointer-events: none;
        width: min(920px, calc(100vw - 24px));
    }

    .eb-topbar-toast {
        pointer-events: auto;
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 12px;
        padding: 12px 16px;
        border-radius: 6px;
        box-shadow: 0 6px 22px rgba(0,0,0,.18);
        font-weight: 700;
        font-size: 14px;
        line-height: 1.2;
    }

    .eb-topbar-toast--success {
        background: #198754;
        color: #fff;
    }

    .eb-topbar-toast--danger {
        background: #dc3545;
        color: #fff;
    }

    .eb-topbar-toast__msg {
        overflow: hidden;
        text-overflow: ellipsis;
        white-space: nowrap;
    }

    .eb-topbar-toast__close {
        all: unset;
        cursor: pointer;
        width: 28px;
        height: 28px;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        border-radius: 6px;
        color: currentColor;
        opacity: .95;
    }

        .eb-topbar-toast__close:hover {
            background: rgba(255,255,255,.18);
        }

        .eb-topbar-toast__close svg {
            width: 14px;
            height: 14px;
            display: block;
        }
</style>

<div class="doc-board-wrap">
    <div class="doc-board" id="docBoard"
         data-api-list="/Doc/BoardData"
         data-api-badges="/Doc/BoardBadges"
         data-detail-url="/Doc/DetailDX/{docId}">

        <div class="doc-tabs" role="tablist" aria-label="@S["DOC_Board_Tablist_Aria"]">
            <button class="doc-tab" type="button" role="tab" data-tab="created" aria-selected="true">
                @S["DOC_Tab_CreatedByMe"] <span class="badge" id="badge-created" hidden>0</span>
            </button>
            <button class="doc-tab" type="button" role="tab" data-tab="approval" aria-selected="false">
                @S["DOC_Tab_Approval"] <span class="badge" id="badge-approval" hidden>0</span>
            </button>
            <button class="doc-tab" type="button" role="tab" data-tab="cooperation" aria-selected="false">
                @S["DOC_Tab_Cooperation"] <span class="badge" id="badge-cooperation" hidden>0</span>
            </button>
            <button class="doc-tab" type="button" role="tab" data-tab="shared" aria-selected="false">
                @S["DOC_Tab_SharedWithMe"] <span class="badge" id="badge-shared" hidden>0</span>
            </button>
        </div>

        <div class="doc-sheet" id="docSheet">

            <div class="doc-subtabs" id="createdSubtabs" role="tablist" aria-label="@S["DOC_Approval_SubTablist_Aria"]">
                <button class="doc-subtab" type="button" role="tab" data-created-sub="ongoing" aria-selected="true">
                    @S["DOC_Approval_Sub_Ongoing"]
                </button>
                <button class="doc-subtab" type="button" role="tab" data-created-sub="completed" aria-selected="false">
                    @S["DOC_Approval_Sub_Completed"]
                </button>
            </div>

            <div class="doc-subtabs" id="approvalSubtabs" role="tablist" aria-label="@S["DOC_Approval_SubTablist_Aria"]">
                <button class="doc-subtab" type="button" role="tab" data-approval-sub="ongoing" aria-selected="true">
                    @S["DOC_Approval_Sub_Ongoing"]
                </button>
                <button class="doc-subtab" type="button" role="tab" data-approval-sub="completed" aria-selected="false">
                    @S["DOC_Approval_Sub_Completed"]
                </button>
            </div>

            <div class="doc-subtabs" id="cooperationSubtabs" role="tablist" aria-label="@S["DOC_Approval_SubTablist_Aria"]">
                <button class="doc-subtab" type="button" role="tab" data-cooperation-sub="ongoing" aria-selected="true">
                    @S["DOC_Approval_Sub_Ongoing"]
                </button>
                <button class="doc-subtab" type="button" role="tab" data-cooperation-sub="completed" aria-selected="false">
                    @S["DOC_Approval_Sub_Completed"]
                </button>
            </div>

            <div class="doc-subtabs" id="sharedSubtabs" role="tablist" aria-label="@S["DOC_Approval_SubTablist_Aria"]">
                <button class="doc-subtab" type="button" role="tab" data-shared-sub="ongoing" aria-selected="true">
                    @S["DOC_Approval_Sub_Ongoing"]
                </button>
                <button class="doc-subtab" type="button" role="tab" data-shared-sub="completed" aria-selected="false">
                    @S["DOC_Approval_Sub_Completed"]
                </button>
            </div>

            <div class="doc-filter">
                <label class="sr-only" for="filterTitle">@S["DOC_Filter_Title_Label"]</label>
                <select id="filterTitle">
                    <option value="all">@S["DOC_Filter_Title_All"]</option>
                    <option value="viewed" data-shared-only="true">@S["DOC_Result_Viewed"]</option>
                    <option value="unviewed" data-shared-only="true">@S["DOC_Result_Unviewed"]</option>
                    <option value="approved" data-nonshared-only="true">@S["DOC_Filter_Title_Approved"]</option>
                    <option value="rejected" data-nonshared-only="true">@S["DOC_Filter_Title_Rejected"]</option>
                    <option value="pending" data-nonshared-only="true">@S["DOC_Filter_Title_Pending"]</option>
                    <option value="onhold" data-nonshared-only="true">@S["DOC_Filter_Title_OnHold"]</option>
                    <option value="recalled" data-created-only="true" data-nonshared-only="true">@S["DOC_Filter_Title_Recalled"]</option>
                </select>

                <label class="sr-only" for="filterSort">@S["DOC_Filter_Sort_Label"]</label>
                <select id="filterSort">
                    <option value="created_desc">@S["DOC_Filter_Sort_CreatedDesc"]</option>
                    <option value="created_asc">@S["DOC_Filter_Sort_CreatedAsc"]</option>
                    <option value="title_asc">@S["DOC_Filter_Sort_TitleAsc"]</option>
                    <option value="title_desc">@S["DOC_Filter_Sort_TitleDesc"]</option>
                </select>

                <label class="sr-only" for="filterQuery">@S["DOC_Filter_Search_Label"]</label>
                <input id="filterQuery" type="search" placeholder="@S["DOC_Filter_Search_Placeholder"]" />
                <button type="button" id="filterApply">@S["DOC_Filter_Apply"]</button>
            </div>

            <div class="doc-tablewrap">
                <table class="doc-list" aria-live="polite" id="docListTable">
                    <thead>
                        <tr>
                            <th style="width:72px">
                                <span id="docNoHeaderWrap">@S["DOC_Col_No"]</span>
                            </th>
                            <th>@S["DOC_Col_Title"]</th>
                            <th style="width:180px">@S["DOC_Col_Author"]</th>
                            <th style="width:160px">@S["DOC_Col_Date"]</th>
                            <th style="width:420px">@S["DOC_Col_Status"]</th>
                            <th style="width:160px">@S["DOC_Result_Viewed"]</th>
                        </tr>
                    </thead>
                    <tbody id="docListBody">
                        <tr>
                            <td colspan="6">@S["DOC_List_Loading"]</td>
                        </tr>
                    </tbody>
                </table>
            </div>

            <div class="doc-paging-wrap">
                <div class="doc-paging" id="docPaging" aria-label="@S["DOC_Pagination_Label"]"></div>

                <div class="doc-paging-tools" id="docPagingTools" hidden>
                    <label class="chk-all">
                        <input type="checkbox" id="chkAllBottom" />
                        <span>@S["DOC_Filter_Title_All"]</span>
                    </label>
                    <button type="button" class="btn-approve-bulk" id="btnApproveBulk" disabled>승인</button>
                </div>
            </div>
        </div>

        <script type="application/json" id="docBoardI18n">@Html.Raw(JsonSerializer.Serialize(__docBoardI18n))</script>
        <script src="~/js/eb.doc.board.js" asp-append-version="true"></script>
    </div>
</div>
<div id="ebTopToastHost" aria-live="polite" aria-atomic="true"></div>