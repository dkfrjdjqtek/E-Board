@* 2026.06.10 Added: Board 최초 진입 시 DetailDX/DevExpress Spreadsheet warm-up 요청 URL 추가 *@
@* 2026.06.09 Changed: Board 작성일 표시/필터를 DocManage/DocTemplateManage와 동일하게 DocControllerHelper 공용 날짜 헬퍼 기준으로 통일 *@
@* 2026.06.05 Changed: 문서함 목록 table/search 영역을 제거하고 DevExtreme DataGrid 기반 구조로 교체 *@
@using System.Text.Json
@using System.Globalization
@inject Microsoft.Extensions.Localization.IStringLocalizer<SharedResource> S
@{
    ViewData["Title"] = S["DOC_Board_Title"];
    ViewData["DisableDxAll"] = false;
    ViewData["UseDxSpreadsheet"] = false;

    var currentCulture = WebApplication1.Controllers.DocControllerHelper.NormalizeCultureName(CultureInfo.CurrentUICulture.Name);
    if (string.IsNullOrWhiteSpace(currentCulture))
    {
        currentCulture = "ko-KR";
    }

    var datePattern = WebApplication1.Controllers.DocControllerHelper.GetLocalDatePattern(currentCulture);

    var __docBoardI18n = new
    {
        STATUS_LABELS = new
        {
            Pending = S["DOC_Status_Pending"].Value,
            Approved = S["DOC_Status_Approved"].Value,
            Rejected = S["DOC_Status_Rejected"].Value,
            OnHold = S["DOC_Status_OnHold"].Value,
            Recalled = S["DOC_Status_Recalled"].Value
        },
        DOT_LABELS = new
        {
            ApprovedDone = S["DOC_Filter_ApprovalView_Approved"].Value,
            RejectedDone = S["DOC_Filter_ApprovalView_Rejected"].Value,
            VetoedDone = S["DOC_Filter_ApprovalView_Vetoed"].Value,
            RecalledDone = S["DOC_Filter_ApprovalView_Recalled"].Value,
            Pending = S["DOC_Filter_ApprovalView_Pending"].Value
        },
        READ_LABEL = S["DOC_Result_Viewed"].Value,
        UNREAD_LABEL = S["DOC_Result_Unviewed"].Value,
        LIST_LOADING = S["DOC_List_Loading"].Value,
        LIST_EMPTY = S["DOC_List_Empty"].Value,
        PAGINATION_PREV = S["DOC_Pagination_Prev"].Value,
        PAGINATION_NEXT = S["DOC_Pagination_Next"].Value,
        DOC_Toast_BulkApproved = S["DOC_Toast_BulkApproved"].Value,
        BULK_FAIL = S["DOC_Toast_BulkApproveFailed"].Value,

        CURRENT_CULTURE = currentCulture,
        DATE_PATTERN = datePattern,
        DATE_OK = S["_CM_OK"].Value,
        DATE_CANCEL = S["_CM_Cancel"].Value,
        DATE_TODAY = S["_CM_Today"].Value,

        COL_NO = S["DOC_Col_No"].Value,
        COL_TITLE = S["DOC_Col_Title"].Value,
        COL_AUTHOR = S["DOC_Col_Author"].Value,
        COL_DATE = S["DOC_Col_Date"].Value,
        COL_STATUS = S["DOC_Col_Status"].Value,
        COL_READ = S["DOC_Result_Viewed"].Value,

        GRID_ALL = S["_CM_All"].Value,
        BULK_APPROVE = S["DOC_Btn_Approve"].Value,

        TAB_CREATED = S["DOC_Tab_CreatedByMe"].Value,
        TAB_APPROVAL = S["DOC_Tab_Approval"].Value,
        TAB_COOPERATION = S["DOC_Tab_Cooperation"].Value,
        TAB_SHARED = S["DOC_Tab_SharedWithMe"].Value,

        SUB_ONGOING = S["DOC_Approval_Sub_Ongoing"].Value,
        SUB_COMPLETED = S["DOC_Approval_Sub_Completed"].Value
    };
}

<style>
    :root {
        --tab-sel-border: 2px;
        --tab-radius-top: 14px;
        --tabbar-bg: #bfbfbf;
        --tabline: #111827;
        --tab-h: 44px;
        --board-grid-min-w: 1440px;
    }

    .doc-board-wrap {
        position: fixed;
        top: var(--header-h,56px);
        right: 0;
        bottom: var(--footer-h,32px);
        left: var(--sidebar-w,270px);
        padding: 0;
        box-sizing: border-box;
        overflow-y: auto;
        overflow-x: auto;
        overscroll-behavior: contain;
    }

    .doc-board {
        display: flex;
        flex-direction: column;
        gap: .75rem;
        margin-top: 16px;
        margin-bottom: 16px;
        width: 100%;
        min-width: var(--board-grid-min-w);
        padding: 0 24px;
        box-sizing: border-box;
    }


    .doc-tabs,
    .doc-subtabs {
        display: flex;
        gap: 10px;
        align-items: flex-end;
        padding: 12px 12px 0 12px;
        background: var(--tabbar-bg);
        position: relative;
        z-index: 2;
        overflow: visible;
        box-sizing: border-box;
        border: 1px solid #cfcfcf;
        border-bottom: var(--tab-sel-border) solid var(--tabline);
        border-radius: 2px 2px 0 0;
        box-shadow: inset 0 1px 0 #cfcfcf;
        background-clip: padding-box;
    }

    .doc-subtabs {
        display: none;
        margin: -14px -14px 12px -14px;
        padding: 12px calc(12px + 14px) 0 calc(12px + 14px);
    }

    .doc-tab,
    .doc-subtab {
        display: inline-flex;
        align-items: center;
        gap: 10px;
        height: var(--tab-h);
        padding: 0 18px;
        cursor: pointer;
        background: var(--tabbar-bg);
        color: var(--tabline);
        border: 1px solid transparent;
        border-radius: 2px;
        font-weight: 400;
        font-size: 16px;
        line-height: 1;
        margin: 0;
        overflow: visible;
        -webkit-appearance: none;
        appearance: none;
        box-sizing: border-box;
        background-clip: padding-box;
        position: relative;
        z-index: 2;
    }

        .doc-tab:hover,
        .doc-subtab:hover {
            opacity: .92;
        }

        .doc-tab:focus,
        .doc-subtab:focus {
            outline: none;
        }

        .doc-tab:focus-visible,
        .doc-subtab:focus-visible {
            outline: 2px solid rgba(255,255,255,.35);
            outline-offset: 2px;
        }

        .doc-tab[aria-selected="true"],
        .doc-subtab[aria-selected="true"] {
            background: #ffffff;
            color: var(--tabline);
            border: var(--tab-sel-border) solid var(--tabline);
            border-radius: var(--tab-radius-top) var(--tab-radius-top) 0 0;
            margin-bottom: calc(var(--tab-sel-border) * -1);
            border-bottom-color: #ffffff;
            background-clip: padding-box;
            box-shadow: none;
            z-index: 3;
            font-weight: 700;
            font-size: 17px;
        }

        .doc-tab .badge,
        .doc-subtab .badge {
            display: inline-flex;
            align-items: center;
            justify-content: center;
            min-width: 22px;
            height: 22px;
            padding: 0 8px;
            font-size: 14px;
            font-weight: 700;
            line-height: 1;
            background: #ef4444;
            color: #fff;
            border-radius: 9999px;
            position: relative;
            z-index: 5;
            pointer-events: none;
        }

    .doc-sheet {
        border: 0;
        border-top: 0;
        border-radius: 0 0 2px 2px;
        background: #ffffff;
        position: relative;
        z-index: 1;
        padding: 14px;
        width: 100%;
        min-width: var(--board-grid-min-w);
        box-sizing: border-box;
    }

    .doc-grid-host {
        width: 100%;
        min-width: var(--board-grid-min-w);
        background: #fff;
        box-sizing: border-box;
    }

    .doc-board .dx-datagrid-pager,
    .doc-board .dx-pager {
        width: 100% !important;
        min-width: var(--board-grid-min-w) !important;
        max-width: none !important;
        box-sizing: border-box;
    }


    .doc-board .dx-datagrid-rowsview .dx-scrollable-container {
        scrollbar-width: none;
        -ms-overflow-style: none;
    }

        .doc-board .dx-datagrid-rowsview .dx-scrollable-container::-webkit-scrollbar:horizontal {
            height: 0 !important;
        }

    .doc-board .dx-datagrid-rowsview .dx-scrollable-scrollbar,
    .doc-board .dx-datagrid-rowsview .dx-scrollable-scrollbar-horizontal,
    .doc-board .dx-datagrid-rowsview .dx-scrollbar-horizontal {
        display: none !important;
        height: 0 !important;
        opacity: 0 !important;
        pointer-events: none !important;
    }

    .doc-board .dx-datagrid {
        width: 100% !important;
        min-width: var(--board-grid-min-w) !important;
        font-size: 0.875rem;
        box-sizing: border-box;
    }

    .doc-board .dx-datagrid-headers .dx-header-row > td {
        font-weight: 600;
        color: #212529;
        text-align: center !important;
    }

    .doc-board .dx-datagrid-filter-row .dx-editor-cell {
        text-align: left !important;
    }

        .doc-board .dx-datagrid-filter-row .dx-editor-cell .dx-editor-with-menu {
            display: flex !important;
            align-items: center !important;
            width: 100% !important;
            min-width: 0 !important;
        }

            .doc-board .dx-datagrid-filter-row .dx-editor-cell .dx-editor-with-menu > .dx-menu,
            .doc-board .dx-datagrid-filter-row .dx-editor-cell .dx-editor-with-menu > .dx-menu-base {
                flex: 0 0 24px !important;
                width: 24px !important;
                min-width: 24px !important;
                max-width: 24px !important;
                overflow: visible !important;
            }

                .doc-board .dx-datagrid-filter-row .dx-editor-cell .dx-editor-with-menu > .dx-menu .dx-menu-items-container,
                .doc-board .dx-datagrid-filter-row .dx-editor-cell .dx-editor-with-menu > .dx-menu .dx-menu-item-wrapper,
                .doc-board .dx-datagrid-filter-row .dx-editor-cell .dx-editor-with-menu > .dx-menu .dx-menu-item {
                    width: 24px !important;
                    min-width: 24px !important;
                    max-width: 24px !important;
                }

        .doc-board .dx-datagrid-filter-row .dx-editor-cell .dx-editor-container {
            flex: 1 1 auto !important;
            min-width: 0 !important;
            width: auto !important;
        }

        .doc-board .dx-datagrid-filter-row .dx-editor-cell .dx-texteditor {
            width: 100% !important;
            min-width: 0 !important;
            min-height: 30px;
        }

        .doc-board .dx-datagrid-filter-row .dx-editor-cell .dx-texteditor-container,
        .doc-board .dx-datagrid-filter-row .dx-editor-cell .dx-texteditor-input-container,
        .doc-board .dx-datagrid-filter-row .dx-editor-cell .dx-texteditor-input {
            width: 100% !important;
            min-width: 0 !important;
            box-sizing: border-box !important;
        }

    .doc-board .doc-no-cell {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        gap: 8px;
        width: 100%;
    }

        .doc-board .doc-no-cell input[type="checkbox"] {
            width: 16px;
            height: 16px;
            transform: translateY(1px);
        }

    .doc-title a.doc-unread {
        font-weight: 900;
        font-size: 17px;
    }

    .doc-title a {
        color: inherit;
        text-decoration: none;
    }

        .doc-title a:hover {
            text-decoration: underline;
        }

    .doc-status-join {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        gap: 10px;
        width: auto;
        max-width: 100%;
        white-space: nowrap;
        margin: 0 auto;
    }

        .doc-status-join .st-left,
        .doc-status-join .st-right {
            flex: 0 0 auto;
            min-width: 0;
            overflow: hidden;
            text-overflow: ellipsis;
            text-align: center;
            white-space: nowrap;
        }

    .doc-bulk-tools {
        display: none;
        align-items: center;
        justify-content: flex-end;
        gap: 10px;
        padding: 10px 0 0 0;
    }

        .doc-bulk-tools.is-visible {
            display: flex;
        }

        .doc-bulk-tools .chk-all {
            display: inline-flex;
            align-items: center;
            gap: 6px;
            white-space: nowrap;
            font-size: 14px;
        }

        .doc-bulk-tools .btn-approve-bulk {
            padding: 9px 14px;
            border: 1px solid #2c2c2c;
            border-radius: 2px;
            background: #2c2c2c;
            color: #fff;
            font-weight: 900;
            font-size: 14px;
            line-height: 1.1;
            cursor: pointer;
        }

            .doc-bulk-tools .btn-approve-bulk[disabled] {
                opacity: .45;
                cursor: not-allowed;
            }

    #ebTopToastHost {
        position: fixed;
        left: 50%;
        transform: translateX(-50%);
        top: calc(var(--header-h,56px) + 10px);
        z-index: 20000;
        pointer-events: none;
        width: min(920px, calc(100vw - 24px));
    }

    .eb-topbar-toast {
        pointer-events: auto;
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 12px;
        padding: 12px 16px;
        border-radius: 6px;
        box-shadow: 0 6px 22px rgba(0,0,0,.18);
        font-weight: 700;
        font-size: 14px;
        line-height: 1.2;
    }

    .eb-topbar-toast--success {
        background: #198754;
        color: #fff;
    }

    .eb-topbar-toast--danger {
        background: #dc3545;
        color: #fff;
    }

    .eb-topbar-toast__msg {
        overflow: hidden;
        text-overflow: ellipsis;
        white-space: nowrap;
    }

    .eb-topbar-toast__close {
        all: unset;
        cursor: pointer;
        width: 28px;
        height: 28px;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        border-radius: 6px;
        color: currentColor;
        opacity: .95;
    }

        .eb-topbar-toast__close:hover {
            background: rgba(255,255,255,.18);
        }

        .eb-topbar-toast__close svg {
            width: 14px;
            height: 14px;
            display: block;
        }

    @@media (max-width: 991.98px) {
        .doc-board-wrap {
            left: 0;
        }
    }
</style>

<div class="doc-board-wrap">
    <div class="doc-board" id="docBoard"
         data-api-list="/Doc/BoardData"
         data-api-badges="/Doc/BoardBadges"
         data-detail-url="/Doc/DetailDX/{docId}"
         
        @Html.AntiForgeryToken()

        <div class="doc-tabs" role="tablist" aria-label="@S["DOC_Board_Tablist_Aria"]">
            <button class="doc-tab" type="button" role="tab" data-tab="created" aria-selected="true">
                @S["DOC_Tab_CreatedByMe"] <span class="badge" id="badge-created" hidden>0</span>
            </button>
            <button class="doc-tab" type="button" role="tab" data-tab="approval" aria-selected="false">
                @S["DOC_Tab_Approval"] <span class="badge" id="badge-approval" hidden>0</span>
            </button>
            <button class="doc-tab" type="button" role="tab" data-tab="cooperation" aria-selected="false">
                @S["DOC_Tab_Cooperation"] <span class="badge" id="badge-cooperation" hidden>0</span>
            </button>
            <button class="doc-tab" type="button" role="tab" data-tab="shared" aria-selected="false">
                @S["DOC_Tab_SharedWithMe"] <span class="badge" id="badge-shared" hidden>0</span>
            </button>
        </div>

        <div class="doc-sheet" id="docSheet">
            <div class="doc-subtabs" id="createdSubtabs" role="tablist" aria-label="@S["DOC_Approval_SubTablist_Aria"]">
                <button class="doc-subtab" type="button" role="tab" data-created-sub="ongoing" aria-selected="true">
                    @S["DOC_Approval_Sub_Ongoing"]
                </button>
                <button class="doc-subtab" type="button" role="tab" data-created-sub="completed" aria-selected="false">
                    @S["DOC_Approval_Sub_Completed"]
                </button>
            </div>

            <div class="doc-subtabs" id="approvalSubtabs" role="tablist" aria-label="@S["DOC_Approval_SubTablist_Aria"]">
                <button class="doc-subtab" type="button" role="tab" data-approval-sub="ongoing" aria-selected="true">
                    @S["DOC_Approval_Sub_Ongoing"]
                </button>
                <button class="doc-subtab" type="button" role="tab" data-approval-sub="completed" aria-selected="false">
                    @S["DOC_Approval_Sub_Completed"]
                </button>
            </div>

            <div class="doc-subtabs" id="cooperationSubtabs" role="tablist" aria-label="@S["DOC_Approval_SubTablist_Aria"]">
                <button class="doc-subtab" type="button" role="tab" data-cooperation-sub="ongoing" aria-selected="true">
                    @S["DOC_Approval_Sub_Ongoing"]
                </button>
                <button class="doc-subtab" type="button" role="tab" data-cooperation-sub="completed" aria-selected="false">
                    @S["DOC_Approval_Sub_Completed"]
                </button>
            </div>

            <div class="doc-subtabs" id="sharedSubtabs" role="tablist" aria-label="@S["DOC_Approval_SubTablist_Aria"]">
                <button class="doc-subtab" type="button" role="tab" data-shared-sub="ongoing" aria-selected="true">
                    @S["DOC_Approval_Sub_Ongoing"]
                </button>
                <button class="doc-subtab" type="button" role="tab" data-shared-sub="completed" aria-selected="false">
                    @S["DOC_Approval_Sub_Completed"]
                </button>
            </div>

            <div id="docBoardGrid" class="doc-grid-host"></div>

            <div class="doc-bulk-tools" id="docBulkTools">
                <label class="chk-all">
                    <input type="checkbox" id="chkAllBottom" />
                    <span>@S["_CM_All"]</span>
                </label>
                <button type="button" class="btn-approve-bulk" id="btnApproveBulk" disabled>
                    @S["DOC_Btn_Approve"]
                </button>
            </div>
        </div>

        <script type="application/json" id="docBoardI18n">@Html.Raw(JsonSerializer.Serialize(__docBoardI18n))</script>
        <script src="~/js/DocControllerHelper.js" asp-append-version="true"></script>
        <script src="~/js/eb.doc.board.js" asp-append-version="true"></script>
    </div>
</div>

<div id="ebTopToastHost" aria-live="polite" aria-atomic="true"></div>